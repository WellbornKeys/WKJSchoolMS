function previewRollover() {
  const newYear = +document.getElementById('yr-new-year').value;
  const newTerm = +document.getElementById('yr-new-term').value;
  if (!newYear || newYear < 2020 || newYear > 2060) { showAlert('Enter a valid year (e.g. 2026).'); return; }
  const curYear = DB.settings.year || new Date().getFullYear();
  if (newYear <= curYear) { showAlert('New year must be greater than current year ('+curYear+').'); return; }

  // Build class mapping
  const classMap = {};
  DB.classes.forEach(c=>{
    const sel = document.getElementById('yrmap-'+c.replace(/[^a-z0-9]/gi,'_'));
    if (sel) classMap[c] = sel.value || null;
  });

  let advanced=0, graduated=0;
  const preview = DB.students.map(s=>{
    const toClass = classMap[s.cls];
    if (toClass) advanced++;
    else graduated++;
    return `<tr><td>${s.fn} ${s.ln}</td><td>${s.cls}</td><td>${toClass ? '→ '+toClass : '<span style="color:var(--danger)">Graduate/Remove</span>'}</td></tr>`;
  }).join('');

  const prevEl = document.getElementById('yr-preview');
  prevEl.innerHTML = `
    <div class="alert-box info" style="margin-bottom:10px">
      <strong>Preview:</strong> ${advanced} students will be advanced to next class · ${graduated} students will be marked as graduated/removed from active list.
      <br>New year: <strong>${newYear}</strong> starting <strong>Term ${newTerm}</strong>
    </div>
    <div style="max-height:280px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius)">
      <table style="font-size:11.5px"><thead><tr><th>Student</th><th>Current Class</th><th>After Rollover</th></tr></thead>
      <tbody>${preview}</tbody></table>
    </div>`;
  document.getElementById('yr-execute-btn').style.display = '';
}

function executeRollover() {
  showConfirm('This will roll over to the next academic year. A full backup will be taken first. Proceed?', ()=>{
    const newYear = +document.getElementById('yr-new-year').value;
    const newTerm = +document.getElementById('yr-new-term').value;
    const classMap = {};
    DB.classes.forEach(c=>{
      const sel = document.getElementById('yrmap-'+c.replace(/[^a-z0-9]/gi,'_'));
      if (sel) classMap[c] = sel.value || null;
    });

    // Archive current year
    if (!DB.academicHistory) DB.academicHistory = [];
    DB.academicHistory.push({
      year: DB.settings.year,
      term: DB.settings.term,
      studentCount: DB.students.length,
      date: new Date().toISOString(),
      snapshot: {
        students: JSON.parse(JSON.stringify(DB.students)),
        marks: JSON.parse(JSON.stringify(DB.marks)),
        attendance: JSON.parse(JSON.stringify(DB.attendance))
      }
    });
    if (DB.academicHistory.length > 10) DB.academicHistory = DB.academicHistory.slice(-10);

    // Carry forward outstanding fee balances
    DB.students.forEach(s=>{
      const bal = Math.max(0, getBalance(s.id, DB.settings.term));
      if (bal > 0) {
        if (!s.carryForward) s.carryForward = {};
        const key = `${newYear}_${newTerm}`;
        s.carryForward[key] = (s.carryForward[key]||0) + bal;
      }
    });

    // Advance classes
    const toRemove = [];
    DB.students.forEach(s=>{
      const nextClass = classMap[s.cls];
      if (nextClass) {
        s.cls = nextClass;
        s.enrolledYear = newYear;
      } else {
        s.graduated = true;
        s.graduationYear = DB.settings.year;
        toRemove.push(s.id);
      }
    });

    // Move graduated students to archive
    if (!DB.graduatedStudents) DB.graduatedStudents = [];
    toRemove.forEach(id=>{
      const idx = DB.students.findIndex(s=>s.id===id);
      if (idx>=0) { DB.graduatedStudents.push(DB.students[idx]); DB.students.splice(idx,1); }
    });

    // Update year/term
    DB.settings.year = newYear;
    DB.settings.term = newTerm;
    updateTopbarInfo();
    saveDB();
    addAct(`Academic year rollover: ${newYear} Term ${newTerm} — ${DB.students.length} students advanced, ${toRemove.length} graduated`);
    showAlert(`Year rollover complete! Year is now ${newYear} Term ${newTerm}.\n${DB.students.length} students advanced · ${toRemove.length} graduated.`, '🎓 Rollover Complete');
    renderYearRolloverTab();
    renderSettings();
    document.getElementById('yr-execute-btn').style.display = 'none';
    document.getElementById('yr-preview').innerHTML = '';
  });
}

// Override getCarryForward to also look at per-year carry-forward
const _origCarryForward = window.getCarryForward;
window.getCarryForward = function(sid, term) {
  // Original carry-forward logic
  let orig = _origCarryForward ? _origCarryForward(sid, term) : 0;
  // Additional: check carryForward set during year rollover
  const s = DB.students.find(x=>x.id===sid);
  if (s && s.carryForward) {
    const key = `${DB.settings.year}_${term}`;
    orig += (s.carryForward[key]||0);
  }
  return orig;
};

