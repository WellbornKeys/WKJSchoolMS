function generateReports() {
  const cls = document.getElementById('rpt-class').value;
  const term = +document.getElementById('rpt-term').value;
  const fmtSel = document.getElementById('rpt-format');
  const format = fmtSel ? fmtSel.value : DB.reportSettings.format;
  const rs = DB.reportSettings;
  const termName = ['Term 1','Term 2','Term 3'][term-1];
  const sch = DB.settings;
  if (!cls) {
    document.getElementById('rpt-preview').innerHTML='<div class="empty"><i class="ti ti-report"></i><p>Select a class to preview report cards.</p></div>';
    return;
  }

  const subjects = cls ? getClassSubjects(cls) : getSubjectsForFormat(format);
  const sts = DB.students.filter(s=>s.cls===cls);

  // Calculate aggregates for ranking
  const studentData = sts.map(s=>{
    let aggPoints=0, subjectCount=0;
    const subs = subjects.map(sub=>{
      const key = cls+'||'+sub+'||'+term;
      if (!DB.marks[key]||!DB.marks[key][s.id]) return null;
      const m = DB.marks[key][s.id];
      const tot = Math.min(100, (+m.bot||0)+(+m.mid||0)+(+m.eot||0));
      const gd = getGrade(tot, format);
      aggPoints += gd.p; subjectCount++;
      return {sub, bot:m.bot||0, mid:m.mid||0, eot:m.eot||0, tot, gd};
    }).filter(Boolean);
    return {s, subs, agg: subjectCount>0?aggPoints:null, subjectCount};
  });

  // Rank by aggregate (lower = better for UNEB; higher = better for UACE)
  const ranked = [...studentData].filter(d=>d.agg!==null).sort((a,b)=>{
    if (format==='secondary_uace') return b.agg - a.agg; // higher pts = better
    return a.agg - b.agg; // lower pts = better (UNEB/UCE)
  });
  let posCounter = 1;
  ranked.forEach((d,i)=>{
    if (i>0&&d.agg===ranked[i-1].agg) d.position = ranked[i-1].position;
    else d.position = posCounter;
    posCounter++;
  });
  const posMap = {}; ranked.forEach(d=>posMap[d.s.id]=d.position);
  const isTrialLic = getLicense()&&getLicense().type==='trial';

  const cards = studentData.map(({s, subs, agg, subjectCount})=>{
    const bf = getCarryForward(s.id, term);
    const termFee = getTermFeeTotal(s.id, term);
    const paid = getTotalPaid(s.id, term);
    const balance = Math.max(0, termFee+bf-paid);
    const pos2 = posMap[s.id];
    const avgMark = subs.length>0 ? Math.round(subs.reduce((a,b)=>a+b.tot,0)/subs.length) : 0;
    const overallGrade = subs.length>0 ? getGrade(avgMark, format) : null;

    let presCount=0, absCount=0, lateCount=0;
    Object.values(DB.attendance).forEach(dayAtt=>{
      const v = dayAtt[s.id];
      if (v==='P') presCount++; else if (v==='A') absCount++; else if (v==='L') lateCount++;
    });

    // Grade header row varies by format and gradeMode
    const gradeMode = rs.gradeMode || 'grade_and_marks';
    const showMarks = gradeMode !== 'grade_only';
    const showGrade = gradeMode !== 'marks_only';
    const gradeHeaders = format==='secondary_uace'
      ? `<th style="padding:7px 8px;text-align:center">Paper 1</th><th style="padding:7px 8px;text-align:center">Paper 2</th><th style="padding:7px 8px;text-align:center">Total</th>`
      : (showMarks
          ? `<th style="padding:7px 8px;text-align:center">BOT<br><small>/30</small></th><th style="padding:7px 8px;text-align:center">Mid<br><small>/20</small></th><th style="padding:7px 8px;text-align:center">EOT<br><small>/50</small></th><th style="padding:7px 8px;text-align:center">Total<br><small>/100</small></th>`
          : `<th style="padding:7px 8px;text-align:center">Total<br><small>/100</small></th>`);

    const subRows = subjects.map(sub=>{
      const key = cls+'||'+sub+'||'+term;
      const m = DB.marks[key]&&DB.marks[key][s.id];
      const colCount = (showMarks ? 4 : 1) + (showGrade ? 2 : 0);
      if (!m) return `<tr style="border-bottom:1px solid #e0e0d8"><td style="padding:6px 8px">${sub}</td><td colspan="${colCount}" style="text-align:center;color:#bbb">—</td></tr>`;
