function renderStudentOtherFeesUI(currentIds, cls) {
  const sec = document.getElementById('s-other-fees-section');
  if (!sec) return;
  const fees = DB.otherFees || [];
  if (!fees.length) {
    sec.innerHTML = '<div style="font-size:11.5px;color:var(--text3);font-style:italic;padding:4px 0">No other fees defined in Fee Settings yet.</div>';
    return;
  }
  const getTermIds = (t) => {
    if (Array.isArray(currentIds)) return currentIds;
    return (currentIds && currentIds["t"+t]) || [];
  };
  const termNames = ["Term 1","Term 2","Term 3"];
  let html = "<div style=\"font-size:11.5px;color:var(--text3);margin-bottom:8px\">Assign other fees per term for this student. Only checked terms will be charged.</div>";
  html += "<div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:8px\">";
  [1,2,3].forEach(t => {
    const ids = getTermIds(t);
    html += `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:8px 10px">
      <div style="font-weight:700;font-size:11px;color:#7c3aed;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px">${termNames[t-1]}</div>
      ${fees.map(f => {
        const checked = ids.includes(f.id);
        const amt = getEffectiveOtherFeeAmount(f, cls, t);
        return "<label style=\"display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;margin-bottom:4px;font-weight:400;padding:3px 5px;border-radius:4px;background:"+(checked?"#f5f3ff":"transparent")+"\">"
          +"<input type=\"checkbox\" id=\"s-otherfee-t"+t+"-"+f.id+"\" "+(checked?"checked":"")
          +" style=\"width:13px;height:13px;accent-color:#7c3aed;cursor:pointer\""
          +" onchange=\"this.closest('label').style.background=this.checked?'#f5f3ff':'transparent'\">"
          +"<span style=\"flex:1\">"+f.name+"</span>"
          +"<span style=\"color:var(--text3);font-size:10.5px\">UGX "+fmt(amt)+"</span>"
          +"</label>";
      }).join("")}
    </div>`;
  });
  html += "</div>";
  sec.innerHTML = html;
}

function editStudent(id) {
  const s = DB.students.find(x=>x.id===id); if(!s) return;
  document.getElementById('m-student-title').textContent = 'Edit Student';
  document.getElementById('s-fn').value=s.fn; document.getElementById('s-ln').value=s.ln;
  document.getElementById('s-adm').value=s.adm; document.getElementById('s-par').value=s.par||'';
  document.getElementById('s-con').value=s.con||''; document.getElementById('s-gen').value=s.gen;
  document.getElementById('s-dob').value=s.dob||''; document.getElementById('s-brd').value=s.brd||'day';
  document.getElementById('s-ps').value=s.ps||'';
  const healthEl=document.getElementById('s-health'); if(healthEl) healthEl.value=s.health||'';
