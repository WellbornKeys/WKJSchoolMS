<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ============================================================
//  DASHBOARD CHARTS
// ============================================================
let _chartFees = null, _chartAtt = null, _chartMarks = null;

function renderDashboardCharts() {
  renderFeeChart();
  renderAttendanceChart();
  renderMarksChart();
}

function renderFeeChart() {
  const ctx = document.getElementById('chart-fees');
  if (!ctx) return;
  const t = DB.settings.term || 2;
  const labels = DB.classes.length ? DB.classes : ['No Classes'];
  const paid = labels.map(c => {
    const sts = DB.students.filter(s => s.cls === c);
    return sts.reduce((a, s) => a + getTotalPaid(s.id, t), 0);
  });
  const owed = labels.map(c => {
    const sts = DB.students.filter(s => s.cls === c);
    return sts.reduce((a, s) => a + Math.max(0, getTotalOwed(s.id, t) - getTotalPaid(s.id, t)), 0);
  });
  if (_chartFees) _chartFees.destroy();
  _chartFees = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Collected', data: paid, backgroundColor: '#27ae60cc', borderRadius: 4 },
        { label: 'Outstanding', data: owed, backgroundColor: '#e74c3ccc', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { font: { size: 10 } } } },
      scales: {
        x: { stacked: true, ticks: { font: { size: 9 } } },
        y: { stacked: true, ticks: { font: { size: 9 }, callback: v => 'UGX '+Math.round(v/1000)+'k' } }
      }
    }
  });
}

function renderAttendanceChart() {
  const ctx = document.getElementById('chart-att');
  if (!ctx) return;
  const todayKey = typeof today === 'function' ? today() : new Date().toISOString().slice(0,10);
  const rec = DB.attendance[todayKey] || {};
  let P=0, A=0, L=0, unmarked=0;
  DB.students.forEach(s => {
    const v = rec[s.id];
    if (v==='P') P++; else if (v==='A') A++; else if (v==='L') L++; else unmarked++;
  });
  if (_chartAtt) _chartAtt.destroy();
  _chartAtt = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Present','Absent','Late','Unmarked'],
      datasets: [{ data: [P,A,L,unmarked], backgroundColor: ['#27ae60','#e74c3c','#f39c12','#bdc3c7'], borderWidth: 0 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 9 }, boxWidth: 10, padding: 8 } }
      }
    }
  });
}

function renderMarksChart() {
  const ctx = document.getElementById('chart-marks');
  if (!ctx) return;
  const t = DB.settings.term || 2;
  const labels = DB.classes.length ? DB.classes : [];
  const avgs = labels.map(c => {
    const sts = DB.students.filter(s => s.cls === c);
    const subs = (DB.reportSettings?.classSubjects||{})[c] || [];
    if (!sts.length || !subs.length) return 0;
    let total = 0, count = 0;
    sts.forEach(s => {
      subs.forEach(sub => {
        const key = `${c}||${sub}||${t}`;
        const m = (DB.marks[key]||{})[s.id]||{};
        const tot = Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
        if (tot > 0) { total += tot; count++; }
      });
    });
    return count ? Math.round(total/count) : 0;
  });
  const colors = avgs.map(v => v>=70?'#27ae60cc':v>=50?'#f39c12cc':'#e74c3ccc');
  if (_chartMarks) _chartMarks.destroy();
  _chartMarks = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{ label: 'Avg Score', data: avgs, backgroundColor: colors, borderRadius: 4 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { font: { size: 9 } } },
        y: { min: 0, max: 100, ticks: { font: { size: 9 }, callback: v => v+'%' } }
      }
    }
  });
}

// Charts are already triggered by the renderDashboard wrapper above; no second hook needed.

// ============================================================
//  TIMETABLE MODULE
// ============================================================
const TT_DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday'];
const TT_PERIODS = ['P1 (7:30–8:30)','P2 (8:30–9:30)','P3 (9:30–10:30)','Break','P4 (11:00–12:00)','P5 (12:00–13:00)','Lunch','P6 (14:00–15:00)','P7 (15:00–16:00)'];
const TT_BREAK_ROWS = ['Break','Lunch'];

function initTimetablePage() {
  if (!DB.timetable) DB.timetable = {};
  const sel = document.getElementById('tt-class');
  if (!sel) return;
  sel.innerHTML = '<option value="">Select Class</option>' + DB.classes.map(c=>`<option value="${c}">${c}</option>`).join('');
  const t = DB.settings.term || 2;
  const ts = document.getElementById('tt-term');
  if (ts) ts.value = t;
  renderTimetable();
}

function renderTimetable() {
  const cls = document.getElementById('tt-class')?.value;
  const term = document.getElementById('tt-term')?.value || DB.settings.term || 2;
  const wrap = document.getElementById('tt-grid-wrap');
  if (!wrap) return;

  // Show/hide subjects hint
  const hint = document.getElementById('tt-subjects-hint');
  const link = document.getElementById('tt-subjects-link');
  if (hint) {
    const hasSubjects = cls && ((DB.reportSettings?.classSubjects||{})[cls]||[]).length > 0;
    hint.style.display = cls && !hasSubjects ? '' : 'none';
    if (link) link.onclick = (e) => {
      e.preventDefault();
      nav('reports', document.getElementById('nav-reports'));
      setTimeout(() => {
        const settingsTab = document.querySelector('#page-reports .tab:last-child');
        if (settingsTab) reportTab('settings', settingsTab);
        // Pre-select the class in the subject selector
        setTimeout(() => {
          const sel = document.getElementById('rs-class-sel');
          if (sel && cls) { sel.value = cls; renderClassSubjects(); }
        }, 100);
      }, 200);
    };
  }

  if (!cls) { wrap.innerHTML = '<div class="empty"><i class="ti ti-layout-grid"></i><p>Select a class to view its timetable.</p></div>'; return; }
  if (!DB.timetable) DB.timetable = {};
  const key = `${cls}||${term}`;
  const tt = DB.timetable[key] || {};

  let html = `<table style="border-collapse:collapse;min-width:700px;width:100%">
    <thead><tr><th style="background:var(--primary);color:#fff;padding:8px 12px;border:1px solid var(--border);min-width:140px">Period</th>
    ${TT_DAYS.map(d=>`<th style="background:var(--primary);color:#fff;padding:8px 12px;border:1px solid var(--border);text-align:center">${d}</th>`).join('')}
    </tr></thead><tbody>`;

  TT_PERIODS.forEach(period => {
    const isBreak = TT_BREAK_ROWS.includes(period);
    const bg = isBreak ? 'background:var(--surface2);font-style:italic;' : '';
    html += `<tr>
      <td style="padding:7px 12px;border:1px solid var(--border);font-weight:600;font-size:12px;${bg}">${period}</td>`;
    TT_DAYS.forEach(day => {
      const cell = (tt[day]||{})[period] || {};
      if (isBreak) {
        html += `<td style="padding:7px 8px;border:1px solid var(--border);text-align:center;${bg}color:var(--text3);font-size:11px">—</td>`;
      } else {
        const hasSub = cell.subject;
        const pSafe = encodeURIComponent(period);
        html += `<td style="padding:4px 6px;border:1px solid var(--border);cursor:pointer;vertical-align:top;min-width:110px"
          onclick="openTTSlotEditor(this)"
          data-cls="${_esc(cls)}" data-term="${_esc(String(term))}" data-day="${_esc(day)}" data-period="${pSafe}">
          ${hasSub ? `<div style="background:var(--primary-light);border-radius:4px;padding:4px 7px;font-size:11.5px">
            <div style="font-weight:700;color:var(--primary)">${_esc(cell.subject)}</div>
            <div style="font-size:10.5px;color:var(--text2)">${_esc(cell.teacher||'')}</div>
            <div style="font-size:10px;color:var(--text3)">${_esc(cell.room||'')}</div>
          </div>` : `<div style="height:44px;display:flex;align-items:center;justify-content:center;color:var(--text3);font-size:20px">+</div>`}
        </td>`;
      }
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  html += `<div style="margin-top:10px;font-size:11.5px;color:var(--text3)"><i class="ti ti-info-circle"></i> Click any cell to add/edit a lesson slot.</div>`;
  wrap.innerHTML = html;
}

function openTTSlotEditor(tdEl) {
  // Read context from data attributes — avoids all quoting/escaping issues
  const cls    = tdEl.dataset.cls;
  const term   = tdEl.dataset.term;
  const day    = tdEl.dataset.day;
  const period = decodeURIComponent(tdEl.dataset.period);

  if (!DB.timetable) DB.timetable = {};
  const key = `${cls}||${term}`;
  if (!DB.timetable[key]) DB.timetable[key] = {};
  if (!DB.timetable[key][day]) DB.timetable[key][day] = {};
  const cell = DB.timetable[key][day][period] || {};
  const subs = (DB.reportSettings?.classSubjects||{})[cls] || [];
  const staffList = DB.staff || [];

  // Store pending slot context so saveTTSlot can read it without inline args
  window._ttPending = { cls, term, day, period };

  const hasConfiguredSubs = subs.length > 0;
  // Fallback: use class defaults from getClassSubjects if no configured subjects
  const subList = hasConfiguredSubs ? subs : (typeof getClassSubjects === 'function' ? getClassSubjects(cls) : []);
  const subOpts = subList.map(s=>`<option value="${_esc(s)}" ${cell.subject===s?'selected':''}>${_esc(s)}</option>`).join('');
  const teacherOpts = staffList.map(s=>`<option value="${_esc(s.fn+' '+s.ln)}" ${cell.teacher===(s.fn+' '+s.ln)?'selected':''}>${_esc(s.fn+' '+s.ln)}</option>`).join('');

  const subjectField = subList.length
    ? `<select id="tt-edit-sub" style="width:100%"><option value="">— None (clear slot) —</option>${subOpts}</select>
       ${!hasConfiguredSubs ? `<div style="font-size:11px;color:var(--warning);margin-top:4px"><i class="ti ti-info-circle"></i> Using default subjects. <a href="#" onclick="event.preventDefault();closeM('m-generic');nav('reports',document.getElementById('nav-reports'));setTimeout(()=>{reportTab('settings',document.querySelector('#page-reports .tab:last-child'))},200)" style="color:var(--primary)">Configure subjects for ${_esc(cls)}</a> in Report Settings.</div>` : ''}`
    : `<input id="tt-edit-sub" value="${_esc(cell.subject||'')}" placeholder="e.g. Mathematics" style="width:100%">
       <div style="font-size:11px;color:var(--warning);margin-top:4px"><i class="ti ti-alert-triangle"></i> No subjects configured for <strong>${_esc(cls)}</strong>. <a href="#" onclick="event.preventDefault();closeM('m-generic');nav('reports',document.getElementById('nav-reports'));setTimeout(()=>{reportTab('settings',document.querySelector('#page-reports .tab:last-child'))},200)" style="color:var(--primary)">Add subjects in Report Settings →</a></div>`;

  const html = `<div style="padding:4px">
    <div style="font-weight:700;font-size:13px;margin-bottom:12px">📅 ${_esc(day)} — ${_esc(period)} &nbsp;·&nbsp; ${_esc(cls)} Term ${_esc(term)}</div>
    <div class="field"><label>Subject</label>
      ${subjectField}
    </div>
    <div class="field"><label>Teacher</label>
      <select id="tt-edit-teacher" style="width:100%"><option value="">— Select —</option>${teacherOpts}</select>
    </div>
    <div class="field"><label>Room / Location</label>
      <input id="tt-edit-room" value="${_esc(cell.room||'')}" placeholder="e.g. Room 3, Lab">
    </div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn btn-primary" onclick="saveTTSlot()"><i class="ti ti-device-floppy"></i>Save</button>
      <button class="btn" onclick="closeM('m-generic')">Cancel</button>
    </div>
  </div>`;

  // Use a generic modal if available, else create a simple overlay
  let modal = document.getElementById('m-generic');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'm-generic';
    modal.className = 'overlay';
    modal.innerHTML = '<div class="modal" style="width:420px"><div class="modal-hd"><span id="m-generic-title">Edit Slot</span><button class="btn btn-icon btn-sm" onclick="closeM(\'m-generic\')"><i class="ti ti-x"></i></button></div><div id="m-generic-body" style="padding:16px"></div></div>';
    document.body.appendChild(modal);
  }
  document.getElementById('m-generic-title').textContent = 'Edit Timetable Slot';
  document.getElementById('m-generic-body').innerHTML = html;
  openM('m-generic');
}

function saveTTSlot() {
  const { cls, term, day, period } = window._ttPending || {};
  if (!cls || !period) { toast('No slot selected', 'warning'); return; }
  if (!DB.timetable) DB.timetable = {};
  const key = `${cls}||${term}`;
  if (!DB.timetable[key]) DB.timetable[key] = {};
  if (!DB.timetable[key][day]) DB.timetable[key][day] = {};
  // Support both <select> and free-text <input> for subject field
  const subEl = document.getElementById('tt-edit-sub');
  const sub = subEl ? subEl.value.trim() : '';
  if (!sub) {
    delete DB.timetable[key][day][period];
  } else {
    DB.timetable[key][day][period] = {
      subject: sub,
      teacher: document.getElementById('tt-edit-teacher').value,
      room: document.getElementById('tt-edit-room').value.trim()
    };
  }
  saveDB();
  closeM('m-generic');
  renderTimetable();
  toast('Slot saved', 'success');
}

function openAddTTSlot() {
  const cls = document.getElementById('tt-class')?.value;
  if (!cls) { showAlert('Please select a class first.', '⚠️'); return; }
  toast('Click any cell in the grid to add a lesson', 'info', 3000);
}

function clearTimetable() {
  const cls = document.getElementById('tt-class')?.value;
  const term = document.getElementById('tt-term')?.value;
  if (!cls) { showAlert('Select a class first.', '⚠️'); return; }
  showConfirm(`Clear the entire timetable for ${cls} Term ${term}?`, () => {
    const key = `${cls}||${term}`;
    if (DB.timetable) delete DB.timetable[key];
    saveDB();
    renderTimetable();
    toast('Timetable cleared', 'warning');
  });
}

function printTimetable() {
  const cls = document.getElementById('tt-class')?.value;
  const term = document.getElementById('tt-term')?.value;
  if (!cls) { showAlert('Select a class first.', '⚠️'); return; }
  const content = document.getElementById('tt-grid-wrap').innerHTML;
  const sch = DB.settings;
  const html = `<!DOCTYPE html><html><head><title>Timetable — ${cls}</title>
  <style>*{box-sizing:border-box}body{font-family:Arial,sans-serif;font-size:10pt;color:#000;padding:16px}
  h2{text-align:center;color:#1e4d35;margin-bottom:4px}h4{text-align:center;color:#555;font-weight:400;margin-bottom:16px}
  table{width:100%;border-collapse:collapse}th,td{border:1px solid #ccc;padding:5px 8px;font-size:9pt}
  th{background:#1e4d35;color:#fff}
  @media print{@page{size:A4 landscape;margin:8mm}}</style></head>
  <body>
  <h2>${sch.name||'School'}</h2>
  <h4>Class Timetable — ${cls} · Term ${term} · ${sch.year||new Date().getFullYear()}</h4>
  ${content}
  <div style="text-align:center;font-size:9pt;color:#aaa;margin-top:12px">Printed: ${new Date().toLocaleString('en-UG')} · SchoolMS Uganda v30 · WKJSoftwares</div>
  <script>window.onload=function(){window.print();setTimeout(()=>window.close(),1500)}<\/script>
  </body></html>`;
  const w = window.open('','_blank','width=900,height=600');
  if (w) { w.document.write(html); w.document.close(); }
}

