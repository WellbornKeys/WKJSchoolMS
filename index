let _periodMode = 'day';

function initPeriodTab() {
  const di = document.getElementById('period-date-input');
  if (!di.value) di.value = today();
  const mn = new Date().getMonth();
  document.getElementById('period-month-input').value = mn;
  document.getElementById('period-year-input').value = new Date().getFullYear();
  setPeriodMode(_periodMode);
}

function setPeriodMode(mode) {
  _periodMode = mode;
  ['day','week','month'].forEach(m => {
    const btn = document.getElementById('period-btn-' + m);
    if (!btn) return;
    btn.style.background = m === mode ? 'var(--primary)' : 'var(--surface)';
    btn.style.color      = m === mode ? '#fff'           : 'var(--text)';
  });
  const di = document.getElementById('period-date-input');
  const mi = document.getElementById('period-month-input');
  const yi = document.getElementById('period-year-input');
  di.style.display = mode === 'month' ? 'none' : '';
  mi.style.display = mode === 'month' ? ''     : 'none';
  yi.style.display = mode === 'month' ? ''     : 'none';
  renderPeriodTotals();
}

function renderPeriodTotals() {
  const mode = _periodMode;
  let filtered = [], rangeLabel = '';

  if (mode === 'day') {
    const dv = document.getElementById('period-date-input').value;
    if (!dv) { document.getElementById('period-totals-content').innerHTML = '<div class="empty"><i class="ti ti-calendar"></i><p>Select a date above.</p></div>'; return; }
    filtered = DB.payments.filter(p => p.date === dv);
    rangeLabel = new Date(dv + 'T12:00:00').toLocaleDateString('en-UG', {weekday:'long',year:'numeric',month:'long',day:'numeric'});

  } else if (mode === 'week') {
    const dv = document.getElementById('period-date-input').value;
    if (!dv) { document.getElementById('period-totals-content').innerHTML = '<div class="empty"><i class="ti ti-calendar"></i><p>Select any day in the week.</p></div>'; return; }
    const ref = new Date(dv + 'T12:00:00');
    const day = ref.getDay();
    const mon = new Date(ref); mon.setDate(ref.getDate() - ((day + 6) % 7));
    const sun = new Date(mon); sun.setDate(mon.getDate() + 6);
    const f2  = d => d.toLocaleDateString('en-UG', {month:'short', day:'numeric'});
    rangeLabel = `${f2(mon)} – ${f2(sun)}, ${sun.getFullYear()}`;
    const monStr = mon.toISOString().slice(0,10);
    const sunStr = sun.toISOString().slice(0,10);
    filtered = DB.payments.filter(p => p.date >= monStr && p.date <= sunStr);

  } else {
    const m  = parseInt(document.getElementById('period-month-input').value);
    const yr = parseInt(document.getElementById('period-year-input').value) || new Date().getFullYear();
    const mn = ['January','February','March','April','May','June','July','August','September','October','November','December'][m];
    rangeLabel = `${mn} ${yr}`;
    filtered   = DB.payments.filter(p => {
      const d = new Date(p.date + 'T12:00:00');
      return d.getMonth() === m && d.getFullYear() === yr;
    });
  }

  const total    = filtered.reduce((a,b) => a + b.amount, 0);
  const byMethod = {}, byClass = {};
  filtered.forEach(p => {
    const m  = p.method || 'Unknown';
    byMethod[m] = (byMethod[m]||0) + p.amount;
    const st = DB.students.find(s => s.id === p.studentId);
    const c  = st ? st.cls : 'Unknown';
    byClass[c]  = (byClass[c]||0)  + p.amount;
  });

  const methodRows = Object.entries(byMethod).sort((a,b) => b[1]-a[1]);
  const classRows  = Object.entries(byClass).sort((a,b)  => b[1]-a[1]);

  document.getElementById('period-totals-content').innerHTML = `
    <div style="background:var(--primary-light);border-left:4px solid var(--primary);border-radius:var(--radius);padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px">
      <div>
        <div style="font-size:10.5px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;font-weight:700">Total Collected</div>
        <div style="font-size:26px;font-weight:700;color:var(--primary);font-variant-numeric:tabular-nums">UGX ${fmt(total)}</div>
        <div style="font-size:11.5px;color:var(--text2);margin-top:2px">${filtered.length} payment${filtered.length!==1?'s':''} · ${rangeLabel}</div>
      </div>
      <i class="ti ti-coins" style="font-size:36px;color:var(--primary);opacity:0.25"></i>
    </div>
    <div class="g2" style="margin-bottom:16px">
      <div class="card">
        <div class="section-hd">By Payment Method</div>
        ${methodRows.length ? methodRows.map(([m,v]) => `
          <div class="fee-breakdown-row">
            <span style="font-size:12.5px">${m}</span>
            <span style="font-weight:600;color:var(--success)">UGX ${fmt(v)}</span>
          </div>`).join('') : '<p style="color:var(--text3);font-size:12px;padding:8px 0">No payments in this period.</p>'}
      </div>
      <div class="card">
        <div class="section-hd">By Class</div>
        ${classRows.length ? classRows.map(([c,v]) => `
          <div class="fee-breakdown-row">
            <span class="badge badge-info">${c}</span>
            <span style="font-weight:600;color:var(--success)">UGX ${fmt(v)}</span>
          </div>`).join('') : '<p style="color:var(--text3);font-size:12px;padding:8px 0">No payments in this period.</p>'}
      </div>
    </div>
    ${filtered.length ? `
    <div class="section-hd">Payment Records (${filtered.length})</div>
    <div class="card-flush">
      <table>
        <thead><tr><th>Date</th><th>Receipt</th><th>Student</th><th>Class</th><th>Method</th><th style="text-align:right">Amount (UGX)</th></tr></thead>
        <tbody>
          ${filtered.sort((a,b)=>b.date.localeCompare(a.date)).map(p=>{
            const st = DB.students.find(s=>s.id===p.studentId);
            return `<tr>
              <td>${p.date}</td>
              <td style="font-family:monospace;font-size:11.5px">${p.receipt||'—'}</td>
              <td>${st ? st.fn+' '+st.ln : 'Unknown'}</td>
              <td>${st ? '<span class="badge badge-info">'+st.cls+'</span>' : '—'}</td>
              <td>${p.method||'—'}</td>
              <td style="text-align:right;font-weight:600;color:var(--success)">UGX ${fmt(p.amount)}</td>
            </tr>`;
          }).join('')}
        </tbody>
        <tfoot><tr>
          <td colspan="5" style="font-weight:700;padding-top:8px;border-top:2px solid var(--border)">Total</td>
          <td style="text-align:right;font-weight:700;color:var(--success);padding-top:8px;border-top:2px solid var(--border)">UGX ${fmt(total)}</td>
        </tr></tfoot>
      </table>
    </div>` : ''}`;
}

