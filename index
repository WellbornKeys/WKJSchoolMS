      const latest = (data.tag_name||'').replace(/^v/,'');
      const current = '33.0';
      if (latest && latest !== current) {
        el.innerHTML = `<div class="alert-box warning" style="margin-bottom:0">🆕 <strong>Update available: v${latest}</strong> — <a href="${data.html_url}" target="_blank" style="color:var(--primary)">Download from WKJSoftwares GitHub</a></div>`;
      } else if (latest) {
        el.innerHTML = '<div class="alert-box success" style="margin-bottom:0">✅ You are running the latest version (v33.0) — WKJSoftwares</div>';
      } else {
        el.innerHTML = '<div class="alert-box info" style="margin-bottom:0">ℹ️ Could not determine latest version. Visit <a href="mailto:wellbornkeys234@gmail.com" style="color:var(--primary)">wellbornkeys234@gmail.com</a> for updates.</div>';
      }
    } else {
      throw new Error('HTTP '+res.status);
    }
  } catch(e) {
    // Offline or repo not configured yet
    el.innerHTML = '<div class="alert-box info" style="margin-bottom:0">ℹ️ Could not reach update server. Check your connection or contact <strong>WKJSoftwares</strong> at <a href="mailto:wellbornkeys234@gmail.com" style="color:var(--primary)">wellbornkeys234@gmail.com</a> for the latest version.</div>';
  }
}

// ============================================================
//  INIT  (async — waits for IndexedDB before rendering)
// ============================================================

// Theme can be applied immediately from localStorage (tiny value, no size concern)
const savedTheme = localStorage.getItem('sms_theme')||'default';
if (savedTheme&&savedTheme!=='default') document.documentElement.setAttribute('data-theme', savedTheme);
document.querySelectorAll('.theme-swatch').forEach(s=>{
  const onclick = s.getAttribute('onclick')||'';
  const t = onclick.match(/setTheme\('(\w+)'/);
  if (t&&t[1]===savedTheme) s.classList.add('active');
  else if (savedTheme==='default'&&onclick.includes("'default'")) s.classList.add('active');
});

// loadDB() is now async — wrap everything that depends on DB in its .then()
loadDB().then(function _afterLoad() {

  // License check FIRST — synchronous expiry gate + async integrity verification
  (function checkLicenseOnLoad(){
    const lic = DB.license;
    const warn = document.getElementById('li-lic-warn');
    // Mark as expired if the date has passed (use end-of-day to avoid timezone edge cases)
    const _today = today();
    // Derive validity purely from the date — no status mutation on load.
    // Writing status='expired' to disk caused it to persist and block valid licenses on refresh.
    const licValid = lic && lic.key && lic.expires && lic.expires >= _today;
    if (!licValid) {
      if (warn) warn.style.display = '';
    }
    updateLicenseBadge();

    // Run the full async integrity check shortly after load (100ms delay lets the UI settle first)
    if (licValid) {
      // Delay the first integrity check long enough for getMachineId()/saveDB() to fully settle.
      setTimeout(() => runLicenseIntegrityCheck(), 3000);
    }
  })();

// Periodic enforcement: every 10 minutes check expiry AND integrity
setInterval(async function enforceLicensePeriodic() {
  const lic = DB.license;
  if (!lic || !lic.key) return;
  // Expiry check
  // Derive expiry from date only — no status mutation.
  if (lic.expires && lic.expires < today()) {
    updateLicenseBadge();
    if (currentUser) {
      showAlert('Your license has expired. Your data is safe — please renew at WKJSoftwares — wellbornkeys234@gmail.com\n\nYou will be logged out now.', '🔐 License Expired');
      setTimeout(doLogout, 5000);
    }
    return;
  }
  // Full integrity check (machine binding + seal) — run regardless of status field
  await runLicenseIntegrityCheck();
}, 10 * 60 * 1000);

  // ── Demo seed (runs ONCE on genuine first launch only) ───────────────────
  // Guard: only seed if the 'sms_seeded_v1' flag has never been set.
  // This prevents the seed from running again if DB is temporarily empty
  // due to a load race, IDB migration, or any other transient condition.
  (function seedDemoIfEmpty() {
    const alreadySeeded = localStorage.getItem('sms_seeded_v1');
    if (!alreadySeeded && DB.students.length === 0 && DB.staff.length === 0 && DB.payments.length === 0) {
      _runDemoSeed();
      try { localStorage.setItem('sms_seeded_v1', '1'); } catch(_) {}
    }
  })();

}); // end loadDB().then()

// Run storage check after a brief delay (lets IDB finish writing)
setTimeout(function() {
  checkStorageUsage();
  // Also run every 30 minutes to catch gradual fill-up
  setInterval(checkStorageUsage, 30 * 60 * 1000);
}, 2000);
</script>

