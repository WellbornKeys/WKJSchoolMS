function parseOtherFeeAssignFile(input) {
  const file = input.files[0]; if (!file) return;
  document.getElementById('fee-bulk-preview').innerHTML =
    '<div class="alert-box info" style="font-size:11.5px">⏳ Reading file…</div>';
  document.getElementById('fee-bulk-import-btn').style.display = 'none';
  window._feeBulkRows = [];

  const isCSV = file.name.toLowerCase().endsWith('.csv');
  if (isCSV) {
    const reader = new FileReader();
    reader.onload = e => _parseOtherFeeAssignData([[e.target.result]], true);
    reader.readAsText(file);
  } else {
    xlsxParseReady(function() {
      const reader = new FileReader();
      reader.onload = async function(e) {
        try {
          const wb  = await XLSXReader.readAsync(new Uint8Array(e.target.result));
          const ws  = wb.Sheets[wb.SheetNames[0]];
          const rows = XLSXReader.utils.sheet_to_json(ws, {header:1, defval:''});
          _parseOtherFeeAssignData(rows, false);
        } catch(err) {
          document.getElementById('fee-bulk-preview').innerHTML =
            `<div class="alert-box danger" style="font-size:12px">❌ Could not read file: ${err.message}</div>`;
        }
      };
      reader.readAsArrayBuffer(file);
    });
  }
}

function _parseOtherFeeAssignData(rawRows, isCSV) {
  const otherFees = DB.otherFees || [];
  const students  = DB.students  || [];

  // Parse rows
  let rows;
  if (isCSV) {
    const text = rawRows[0];
    const csvLines = text.trim().split(/\r?\n/);
    const csvParse = line => {
      const re = /(?:^|,)("(?:[^"]*(?:""[^"]*)*)"|[^,]*)/g;
      const vals = []; let m;
      while ((m = re.exec(line)) !== null) {
        let v = m[1];
        if (v.startsWith('"') && v.endsWith('"')) v = v.slice(1,-1).replace(/""/g,'"');
        vals.push(String(v).trim());
      }
      return vals;
    };
    rows = csvLines.map(csvParse);
  } else {
    rows = rawRows.map(r => r.map(c => String(c||'').trim()));
  }

  if (!rows || rows.length < 2) {
    document.getElementById('fee-bulk-preview').innerHTML =
      '<div class="alert-box danger" style="font-size:12px">File is empty or has no data rows.</div>';
    return;
  }

  // Find header row
  let hIdx = 0;
  for (let i = 0; i < Math.min(5, rows.length); i++) {
    const lower = rows[i].map(c => c.toLowerCase());
    if (lower.some(c => c.includes('adm') || c.includes('fee'))) { hIdx = i; break; }
  }
  const headers = rows[hIdx].map(h => h.toLowerCase().replace(/[^a-z0-9]/g,''));

  function col(keywords) {
    const idx = headers.findIndex(h => keywords.some(k => h.includes(k)));
    return idx >= 0 ? idx : -1;
  }
  const cAdm  = col(['adm','admission','reg']);
  const cFee  = col(['fee','name']);
  const cT1   = col(['term1','t1','1']);
  const cT2   = col(['term2','t2','2']);
  const cT3   = col(['term3','t3','3']);

  if (cAdm < 0 || cFee < 0) {
    document.getElementById('fee-bulk-preview').innerHTML =
      '<div class="alert-box danger" style="font-size:12px">❌ Could not find required columns "Admission No" and "Fee Name". Check the template.</div>';
    return;
  }

  const isTruthy = v => ['yes','1','true','y','✓','x'].includes(String(v||'').toLowerCase().trim());

  const parsed = [], errors = [];
  const feeNames = otherFees.map(f => f.name.trim().toLowerCase());

  for (let r = hIdx + 1; r < rows.length; r++) {
    const row = rows[r];
    if (row.every(c => !c)) continue;
    const adm     = row[cAdm] || '';
    const feeName = row[cFee] || '';
    const t1      = cT1 >= 0 ? isTruthy(row[cT1]) : false;
    const t2      = cT2 >= 0 ? isTruthy(row[cT2]) : false;
    const t3      = cT3 >= 0 ? isTruthy(row[cT3]) : false;

    if (!adm)     { errors.push(`Row ${r+1}: Missing admission number`); continue; }
    if (!feeName) { errors.push(`Row ${r+1}: Missing fee name`); continue; }

    const student = students.find(s => s.adm.toLowerCase() === adm.toLowerCase());
    if (!student) { errors.push(`Row ${r+1}: Adm "${adm}" not found`); continue; }

    const feeIdx = feeNames.indexOf(feeName.trim().toLowerCase());
    if (feeIdx < 0) {
      errors.push(`Row ${r+1}: Other fee "${feeName}" not found — valid names: ${otherFees.map(f=>f.name).join(', ')}`);
      continue;
    }
    const fee = otherFees[feeIdx];
    if (!t1 && !t2 && !t3) { errors.push(`Row ${r+1}: No terms selected for ${adm} / ${feeName} — row skipped`); continue; }

    parsed.push({ studentId: student.id, adm: student.adm, name: student.fn+' '+student.ln,
      cls: student.cls, feeId: fee.id, feeName: fee.name, t1, t2, t3 });
  }

  window._feeBulkRows = parsed;

  let html = '';
  if (errors.length) {
    html += `<div class="alert-box warning" style="font-size:11.5px;margin-bottom:10px;max-height:120px;overflow-y:auto">
      <strong>⚠ ${errors.length} row(s) skipped:</strong><br>${errors.slice(0,8).map(e=>'• '+e).join('<br>')}
      ${errors.length>8?`<br>…and ${errors.length-8} more`:''}
    </div>`;
  }
  if (!parsed.length) {
    html += '<div style="color:var(--text3);font-size:12.5px;font-style:italic;padding:8px 0">No valid assignments found.</div>';
    document.getElementById('fee-bulk-preview').innerHTML = html;
    document.getElementById('fee-bulk-import-btn').style.display = 'none';
    return;
  }

  const stuCount = new Set(parsed.map(p => p.studentId)).size;
  const feeCount = new Set(parsed.map(p => p.feeId)).size;
  html += `<div style="font-size:12.5px;font-weight:600;margin-bottom:8px">
    Preview: <strong>${parsed.length} assignment(s)</strong> — ${stuCount} student(s), ${feeCount} other fee(s)
  </div>
  <div style="overflow-x:auto">
  <table class="tbl" style="font-size:12px">
    <thead><tr><th>Adm No.</th><th>Student</th><th>Class</th><th>Fee</th><th>T1</th><th>T2</th><th>T3</th></tr></thead>
    <tbody>${parsed.slice(0,20).map((p,i)=>`<tr style="${i%2===0?'background:var(--surface2)':''}">
      <td style="font-family:monospace;font-size:11px">${p.adm}</td>
      <td>${p.name}</td>
      <td><span class="badge badge-info">${p.cls}</span></td>
      <td style="color:#7c3aed;font-weight:600">${p.feeName}</td>
      <td style="text-align:center">${p.t1?'<span style="color:var(--success)">✓</span>':'<span style="color:var(--text3)">—</span>'}</td>
      <td style="text-align:center">${p.t2?'<span style="color:var(--success)">✓</span>':'<span style="color:var(--text3)">—</span>'}</td>
      <td style="text-align:center">${p.t3?'<span style="color:var(--success)">✓</span>':'<span style="color:var(--text3)">—</span>'}</td>
    </tr>`).join('')}
    ${parsed.length>20?`<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:8px">…and ${parsed.length-20} more</td></tr>`:''}
    </tbody>
  </table></div>
  <div style="font-size:11.5px;color:var(--text3);margin-top:8px">
    Existing per-term assignments are <strong>merged</strong> — checked terms are added, unchecked terms are left untouched.
  </div>`;

  document.getElementById('fee-bulk-preview').innerHTML = html;
  document.getElementById('fee-bulk-import-btn').style.display = '';
}

function importOtherFeeAssignments() {
  const rows = window._feeBulkRows || [];
  if (!rows.length) return;
  clearFeeCache();
  rows.forEach(p => {
    const student = DB.students.find(s => s.id === p.studentId);
    if (!student) return;
    if (!student.otherFeeIds || typeof student.otherFeeIds !== 'object' || Array.isArray(student.otherFeeIds)) {
      student.otherFeeIds = { t1: [], t2: [], t3: [] };
    }
    if (p.t1 && !student.otherFeeIds.t1.includes(p.feeId)) student.otherFeeIds.t1.push(p.feeId);
    if (p.t2 && !student.otherFeeIds.t2.includes(p.feeId)) student.otherFeeIds.t2.push(p.feeId);
    if (p.t3 && !student.otherFeeIds.t3.includes(p.feeId)) student.otherFeeIds.t3.push(p.feeId);
  });
  saveDB(); clearFeeCache();
  closeM('m-fee-bulk-upload');
  const stuCount = new Set(rows.map(p => p.studentId)).size;
  showToast(`✅ Assigned ${rows.length} other fee term(s) across ${stuCount} student(s).`);
  addAct(`Bulk assigned other fees: ${rows.length} assignment(s) to ${stuCount} student(s)`);
}
