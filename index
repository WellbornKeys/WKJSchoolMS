const JB_BASE = 'https://api.jsonbin.io/v3';

function jbCfg() { return DB.syncMeta?.jsonbin || {}; }
function jbReady() { const c = jbCfg(); return !!(c.apiKey && c.binId); }

function jbSaveConfig() {
  const apiKey = document.getElementById('jb-api-key')?.value.trim();
  const binId  = document.getElementById('jb-bin-id')?.value.trim();
  const label  = document.getElementById('jb-label')?.value.trim();
  if (!apiKey) { jbStatus('⚠️ API Key is required.', 'danger'); return; }
  if (!DB.syncMeta) DB.syncMeta = {};
  DB.syncMeta.jsonbin = { apiKey, binId: binId || '', label: label || '' };
  saveDB();
  jbStatus(binId ? '✅ Config saved. You can now Push or Pull.' : '✅ API Key saved. Click <strong>Create Sync Bin</strong> to create a new bin.', 'success');
  syncLog('JSONBin config saved.', 'ok');
  renderSyncPage();
}

function jbStatus(msg, type='info') {
  const el = document.getElementById('jb-config-status');
  const colours = { success:'var(--success)', danger:'var(--danger)', info:'var(--info)', warning:'var(--warning)' };
  if (el) el.innerHTML = `<span style="color:${colours[type]||colours.info}">${msg}</span>`;
}

async function jbRequest(path, method='GET', body=null) {
  const cfg = jbCfg();
  const headers = { 'Content-Type': 'application/json', 'X-Master-Key': cfg.apiKey };
  if (method === 'GET') headers['X-Bin-Meta'] = 'false'; // return just the record, not metadata
  const opts = { method, headers };
  if (body !== null) opts.body = JSON.stringify(body);
  const res = await fetch(JB_BASE + path, opts);
  const text = await res.text();
  let data;
  try { data = JSON.parse(text); } catch { throw new Error('Non-JSON response: ' + text.slice(0,120)); }
  if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
  return data;
}

async function jbCreateBin() {
  const apiKey = document.getElementById('jb-api-key')?.value.trim();
  const label  = document.getElementById('jb-label')?.value.trim() || 'SchoolMS Sync';
  if (!apiKey) { jbStatus('⚠️ Enter your API Key first.', 'danger'); return; }
  jbStatus('⏳ Creating sync bin…', 'info');
  // Temporarily set apiKey so jbRequest can use it
  if (!DB.syncMeta) DB.syncMeta = {};
  DB.syncMeta.jsonbin = { apiKey, binId: '', label };
  try {
    const seed = { schoolms: true, created: new Date().toISOString(), devices: [] };
    const data = await jbRequest('/b', 'POST', seed);
    const binId = data.metadata?.id || data.record?.metadata?.id;
    if (!binId) throw new Error('No Bin ID in response: ' + JSON.stringify(data).slice(0,200));
    DB.syncMeta.jsonbin.binId = binId;
    saveDB();
    if (document.getElementById('jb-bin-id')) document.getElementById('jb-bin-id').value = binId;
    jbStatus(`✅ Sync Bin created! Bin ID: <strong>${binId}</strong> — copy this to other devices.`, 'success');
    syncLog('✅ Sync bin created: ' + binId, 'ok');
  } catch(e) {
    jbStatus('❌ Create failed: ' + e.message, 'danger');
    syncLog('❌ Create bin failed: ' + e.message, 'err');
  }
}

async function jbTestConnection() {
  if (!jbReady()) { jbStatus('⚠️ Save config with API Key and Bin ID first.', 'danger'); return; }
  jbStatus('⏳ Testing connection…', 'info');
  try {
    const data = await jbRequest('/b/' + jbCfg().binId);
    jbStatus('✅ Connection works! Bin is accessible.', 'success');
    syncLog('✅ JSONBin connection test passed.', 'ok');
  } catch(e) {
    jbStatus('❌ Failed: ' + e.message + '. Check your API Key and Bin ID.', 'danger');
