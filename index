function doLogout() {
  currentUser = null;
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  // Show the trusted-device bar if a valid trusted session exists, but NEVER auto-login on logout
  try {
    const raw = localStorage.getItem('sms_trusted_user_v1');
    if (raw) {
      const trust = JSON.parse(raw);
      const age = Date.now() - (trust.ts||0);
      if (age <= 30*24*60*60*1000 && DB.users.find(x=>x.username===trust.username)) {
        _showTrustedBar(true, trust.username);
        return;
      }
    }
  } catch(e) {}
  _showTrustedBar(false);
}

// Called only on fresh page load (not on logout) — auto-logins the user if trusted
function checkTrustedDevice() {
  try {
    const raw = localStorage.getItem('sms_trusted_user_v1');
    if (!raw) { _showTrustedBar(false); return; }
    const trust = JSON.parse(raw);
    // Expire after 30 days
    const age = Date.now() - (trust.ts||0);
    if (age > 30*24*60*60*1000) { localStorage.removeItem('sms_trusted_user_v1'); _showTrustedBar(false); return; }
    const user = DB.users.find(x=>x.username===trust.username);
    if (!user) { _showTrustedBar(false); return; }
    // Must have a valid license
    const lic = DB.license||{};
    if (!lic.key||!lic.expires||lic.expires < today()) { // date-only check
      _showTrustedBar(false); return;
    }
    // Show trusted bar first, then auto-login after brief pause so user sees it
    _showTrustedBar(true, trust.username);
    setTimeout(()=>{
      // Only auto-login if we are still on the login screen (not already logged in)
      if (document.getElementById('login-screen').style.display === 'none') return;
      currentUser = user;
      const ui = DB.users.findIndex(x=>x.id===user.id);
      if (ui>=0) DB.users[ui].lastLogin = new Date().toLocaleString('en-UG');
      saveDB();
      document.getElementById('login-screen').style.display='none';
      document.getElementById('app').style.display='flex';
      applyRoleAccess(); updateTopbarInfo(); renderDashboard(); checkOnlineStatus();
      scheduleAutoBackup();
    }, 1200);
  } catch(e) { _showTrustedBar(false); }
}

function _showTrustedBar(show, username) {
  const badge = document.getElementById('li-trusted-badge');
  const forgetBtn = document.getElementById('li-forget-btn');
  const userEl = document.getElementById('li-user');
  const passEl = document.getElementById('li-pass');
  if (show) {
    if (badge) badge.style.display='';
    if (forgetBtn) forgetBtn.style.display='flex';
    if (userEl) userEl.value = username||'';
    if (passEl) passEl.value = '';
  } else {
    if (badge) badge.style.display='none';
    if (forgetBtn) forgetBtn.style.display='none';
    if (userEl && !userEl.value) userEl.value='';
    if (passEl) passEl.value='';
  }
}

