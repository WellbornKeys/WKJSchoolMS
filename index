<script>
(function() {
  'use strict';

  // ── 1. DEBOUNCE UTILITY ──────────────────────────────────────
  function debounce(fn, delay) {
    let t;
    return function(...args) { clearTimeout(t); t = setTimeout(() => fn.apply(this, args), delay); };
  }

  // Wire debounce to all search inputs after DOM is ready
  function wireSearchDebounce() {
    const searchMap = [
      { id: 'st-search',       fn: () => typeof renderStudents === 'function' && renderStudents() },
      { id: 'sd-search',       fn: () => typeof renderStudentDashboard === 'function' && renderStudentDashboard() },
      { id: 'fee-search',      fn: () => typeof renderFees === 'function' && renderFees() },
      { id: 'pay-tab-search',  fn: () => typeof renderPaymentsTab === 'function' && renderPaymentsTab() },
      { id: 'phist-search',    fn: () => typeof renderPayHistory === 'function' && renderPayHistory() },
      { id: 'sf-search',       fn: () => typeof renderStaff === 'function' && renderStaff() },
      { id: 'disc-search',     fn: () => typeof renderDisciplinePage === 'function' && renderDisciplinePage() },
      { id: 'pv-search',       fn: () => typeof renderPaymentsPage === 'function' && renderPaymentsPage() },
      { id: 'cca-search',      fn: () => typeof renderCCA === 'function' && renderCCA() },
      { id: 'att-search',      fn: () => typeof renderAttendance === 'function' && renderAttendance() },
      { id: 'mk-search',       fn: () => typeof renderMarks === 'function' && renderMarks() },
    ];
    searchMap.forEach(({ id, fn }) => {
      const el = document.getElementById(id);
      if (!el) return;
      const debouncedFn = debounce(fn, 60);
      // Replace oninput with a proper debounced listener
      el.removeAttribute('oninput');
      el.addEventListener('input', debouncedFn);
    });
  }

  // ── 2. PRINT POPUP FALLBACK ──────────────────────────────────
  // Override window.open to detect blocked popups gracefully
  const _origWindowOpen = window.open.bind(window);
  window._safePrint = function(htmlContent, filename) {
    const w = _origWindowOpen('', '_blank', 'width=650,height=800');
    if (w) {
      w.document.write(htmlContent);
      w.document.close();
    } else {
      // Offer blob download as fallback
      const blob = new Blob([htmlContent], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = filename || 'SchoolMS_Print.html';
      a.click();
      setTimeout(() => URL.revokeObjectURL(url), 2000);
      if (typeof toast === 'function') toast('Popups blocked — file downloaded instead. Open it to print.', 'warning', 5000);
    }
  };

  // ── 3. ANIMATED METRIC COUNTER ────────────────────────────────
  function animateCounter(el, target, duration) {
    if (isNaN(target) || target < 0) return;
    const start = performance.now();
    const startVal = 0;
    function update(now) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // ease-out-cubic
      const current = Math.round(startVal + (target - startVal) * eased);
      el.textContent = current.toLocaleString();
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  // Patch renderDashboard to animate metric values after render
  const _origRenderDashboard = window.renderDashboard;
  if (typeof _origRenderDashboard === 'function') {
    window.renderDashboard = function() {
      _origRenderDashboard.apply(this, arguments);
      setTimeout(() => {
        document.querySelectorAll('#page-dashboard .m-val').forEach(el => {
          const raw = el.textContent.replace(/,/g, '').replace(/[^0-9]/g, '');
          const num = parseInt(raw, 10);
          if (!isNaN(num) && num > 0 && num < 1000000) animateCounter(el, num, 700);
        });
      }, 50);
    };
  }

  // ── 4. MODAL CLOSE ON BACKDROP CLICK ─────────────────────────
  document.addEventListener('click', function(e) {
    if (e.target.classList.contains('overlay') && e.target.classList.contains('open')) {
      const id = e.target.id;
      // Don't close confirm modals on backdrop click
      if (id === 'm-confirm') return;
      if (typeof closeM === 'function') closeM(id);
    }
  });

  // ── 5. ESC KEY CLOSES TOP MODAL ──────────────────────────────
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      const open = [...document.querySelectorAll('.overlay.open')];
      if (open.length) {
        const top = open[open.length - 1];
        if (top.id !== 'm-confirm' && typeof closeM === 'function') closeM(top.id);
      }
    }
  });

  // ── 6. PAGE TITLE FADE ON NAV ────────────────────────────────
  const _origNav = window.nav;
  if (typeof _origNav === 'function') {
    window.nav = function(page, el) {
      const titleEl = document.getElementById('page-title');
      if (titleEl) { titleEl.style.opacity = '0'; }
      _origNav.apply(this, arguments);
      if (titleEl) { setTimeout(() => { titleEl.style.opacity = '1'; }, 50); }
    };
  }

  // ── 7. INIT ON LOAD ──────────────────────────────────────────
  window.addEventListener('load', function() {
    wireSearchDebounce();
    // Also re-wire after any nav (for dynamically loaded search inputs)
    const _origNav2 = window.nav;
    if (typeof _origNav2 === 'function') {
      window.nav = function() {
        _origNav2.apply(this, arguments);
        setTimeout(wireSearchDebounce, 300);
      };
    }
  });

})();
