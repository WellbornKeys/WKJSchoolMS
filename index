function showUndoToast(msg, undoFn, durationMs=5000) {
  let existing = document.getElementById('undo-toast');
  if (existing) existing.remove();
  const t = document.createElement('div');
  t.id = 'undo-toast';
  t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:10px 18px;border-radius:8px;display:flex;align-items:center;gap:12px;font-size:13px;z-index:9999;box-shadow:0 4px 16px rgba(0,0,0,.35)';
  t.innerHTML = '<span>'+msg+'</span><button style="background:var(--primary);color:#fff;border:none;padding:4px 10px;border-radius:5px;cursor:pointer;font-weight:600;font-size:12px">Undo</button>';
  document.body.appendChild(t);
  t.querySelector('button').addEventListener('click', ()=>{ undoFn(); t.remove(); showToast && showToast('Undo successful','success'); });
  setTimeout(()=>{ if(document.body.contains(t)) t.remove(); }, durationMs);
}


