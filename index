// ============================================================
function showStudentHistory(sid) {
  const s = DB.students.find(x=>x.id===sid); if(!s) return;
  const sch = DB.settings;

  // Gather marks across all years and terms
  const allKeys = Object.keys(DB.marks);
  const byTerm = {};
  [1,2,3].forEach(t=>{
    const termKeys = allKeys.filter(k=>k.endsWith('||'+t) && k.startsWith(s.cls+'||'));
    let sum=0, cnt=0;
    termKeys.forEach(key=>{
      const m=(DB.marks[key]||{})[s.id]||{};
      const tot=Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
      if(tot>0){sum+=tot;cnt++;}
    });
    if(cnt>0) byTerm['Term '+t] = Math.round(sum/cnt);
  });

  // Historical (from academicHistory snapshots)
  const history = (DB.academicHistory||[]).map(h=>{
    const snap = h.snapshot?.students?.find(x=>x.id===sid);
    const snapMarks = h.snapshot?.marks||{};
    let sum=0,cnt=0;
    Object.keys(snapMarks).forEach(key=>{
      if(key.includes('||')) {
        const m=(snapMarks[key]||{})[sid]||{};
        const tot=Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
        if(tot>0){sum+=tot;cnt++;}
      }
    });
    return snap ? {year:h.year, cls:snap.cls, avg:cnt>0?Math.round(sum/cnt):null} : null;
  }).filter(Boolean);

  let html = `<div style="font-size:13px;font-weight:700;color:var(--primary);margin-bottom:10px">📖 Academic History — ${s.fn} ${s.ln} (${s.adm})</div>`;
  html += `<div style="font-size:12px;color:var(--text2);margin-bottom:10px">Class: <strong>${s.cls}</strong> · Year: <strong>${sch.year}</strong></div>`;

  if (Object.keys(byTerm).length) {
    html += `<div style="font-weight:600;font-size:11.5px;margin-bottom:6px;color:var(--text)">Current Year Performance</div>`;
    html += `<div style="display:flex;gap:10px;margin-bottom:12px">`;
    Object.entries(byTerm).forEach(([t,avg])=>{
      const col=avg>=75?'var(--success)':avg>=50?'var(--warning)':'var(--danger)';
      html+=`<div style="flex:1;text-align:center;padding:8px;background:var(--surface2);border-radius:var(--radius)"><div style="font-size:18px;font-weight:700;color:${col}">${avg}%</div><div style="font-size:11px;color:var(--text3)">${t}</div></div>`;
    });
    html += `</div>`;
  }

  if (history.length) {
    html += `<div style="font-weight:600;font-size:11.5px;margin-bottom:6px;color:var(--text)">Previous Years</div>`;
    html += `<table style="width:100%;font-size:12px"><thead><tr><th>Year</th><th>Class</th><th>Avg Mark</th><th>Performance</th></tr></thead><tbody>`;
    history.forEach(h=>{
      const col=!h.avg?'var(--text3)':h.avg>=75?'var(--success)':h.avg>=50?'var(--warning)':'var(--danger)';
      const remark=!h.avg?'—':h.avg>=80?'Excellent':h.avg>=70?'Very Good':h.avg>=60?'Good':h.avg>=50?'Fair':'Needs Improvement';
      html+=`<tr><td><strong>${h.year}</strong></td><td>${h.cls}</td><td style="color:${col};font-weight:700">${h.avg!==null?h.avg+'%':'—'}</td><td style="color:${col}">${remark}</td></tr>`;
    });
    html += `</tbody></table>`;
  } else {
    html += `<div style="font-size:12px;color:var(--text3);font-style:italic">No previous year records. History will appear after year rollover.</div>`;
  }

  // Attendance history
  const year = sch.year||new Date().getFullYear();
  const allDates = Object.keys(DB.attendance||{}).filter(d=>d.startsWith(year+'-'));
  let P=0,A=0,L=0;
  allDates.forEach(d=>{const v=(DB.attendance[d]||{})[s.id]||'';if(v==='P')P++;else if(v==='A')A++;else if(v==='L')L++;});
  const pct=P+A+L>0?Math.round((P+L)/(P+A+L)*100):null;
  html += `<div style="margin-top:12px;padding:10px;background:var(--primary-light);border-radius:var(--radius)">
    <div style="font-weight:600;font-size:11.5px;margin-bottom:4px;color:var(--primary)">Attendance ${year}</div>
    <div style="font-size:12px;display:flex;gap:14px">
      <span>✅ Present: <strong>${P}</strong></span>
      <span>❌ Absent: <strong>${A}</strong></span>
      <span>⏱ Late: <strong>${L}</strong></span>
      ${pct!==null?`<span style="color:var(--primary);font-weight:700">${pct}% Rate</span>`:''}
    </div>
  </div>`;

  // Show in modal
  const overlay = document.getElementById('m-alert');
  const titleEl = document.getElementById('m-alert-title');
  const msgEl = document.getElementById('m-alert-msg');
  if (overlay && titleEl && msgEl) {
    titleEl.textContent = '📖 Student History';
    msgEl.innerHTML = `<div style="max-height:380px;overflow-y:auto">${html}</div>`;
    openM('m-alert');
  }
}

