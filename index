function importData() {
  const inp = document.createElement('input'); inp.type='file'; inp.accept='.json';
  inp.onchange = e=>{
    const file = e.target.files[0]; if(!file) return;
    const r = new FileReader();
    r.onload = ev=>{
      try {
        const imported = JSON.parse(ev.target.result);
        if (!imported || typeof imported !== 'object') throw new Error('invalid');
        // Preserve the current machine's license — never overwrite it from a backup.
        // Importing a backup from another machine or an older backup would replace the
        // locally-activated license with one that has a different _seal/_mid, causing an
        // immediate integrity failure and logout on the next 10-minute check.
        const _currentLicense = DB.license;
        DB = {
          ...DB,
          ...imported,
          license: _currentLicense,          // always keep the local active license
          settings: {...DB.settings, ...(imported.settings||{}), _machineId: DB.settings._machineId},
          reportSettings: {...DB.reportSettings, ...(imported.reportSettings||{})},
          syncMeta: {...DB.syncMeta, ...(imported.syncMeta||{})},
          students: Array.isArray(imported.students) ? imported.students : DB.students,
          staff: Array.isArray(imported.staff) ? imported.staff : DB.staff,
          payments: Array.isArray(imported.payments) ? imported.payments : DB.payments,
          expenses: Array.isArray(imported.expenses) ? imported.expenses : (DB.expenses||[]),
          feeStructures: Array.isArray(imported.feeStructures) ? imported.feeStructures : DB.feeStructures,
          users: Array.isArray(imported.users) ? imported.users : DB.users
        };
        saveDB();
        showAlert('Data imported and merged successfully.','✅ Imported');
        setTimeout(()=>location.reload(), 1000);
      } catch {
        showAlert('Invalid backup file format.');
      }
    };
    r.readAsText(file);
  };
  inp.click();
}

