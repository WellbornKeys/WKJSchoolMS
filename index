<script>
// ============================================================
//  EXCEL / XLSX INTEGRATION  — SchoolMS Uganda
//  Uses SheetJS (xlsx) loaded from CDN
// ============================================================


// ═══════════════════════════════════════════════════════════
//  APP CONFIG — edit here for white-labelling / versioning
// ═══════════════════════════════════════════════════════════
const APP_VERSION = '1.0';
const APP_CONFIG = {
  currency:     'UGX',
  defaultTerm:  1,
  gradingScheme: 'Uganda',
  supportEmail: 'support@wkjsoftwares.com',
  vendor:       'WKJSoftwares · Wellborn Keys Junior',
};
// ═══════════════════════════════════════════════════════════
// ── XLSX readiness guard ──────────────────────────────────────
// xlsxReady: for TEMPLATE DOWNLOADS — uses XLSXLite inline (no internet, always instant)
// Never touches window.XLSX so the CDN parser stays unaffected.
function xlsxReady(action) {
  action(); // XLSXLite is always available — no waiting needed
}

// xlsxParseReady: uses inline XLSXReader — always available, no internet needed.
function xlsxParseReady(action) {
  action(); // XLSXReader is always available inline — no waiting needed
}

// ── Helpers ──────────────────────────────────────────────────
function xlsxSave(wb, filename) {
  try {
    // Use XLSXLite (inline) or full XLSX, both support write() returning Uint8Array
    var writer = (typeof XLSXLite !== 'undefined') ? XLSXLite : XLSX;
    var wbout = writer.write(wb, { bookType: 'xlsx', type: 'array' });
    var blob = new Blob([wbout], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
    var ok = downloadBlob(blob, filename);
    if (!ok) {
      writer.writeFile(wb, filename);
    }
  } catch(e) {
    console.error('xlsxSave error:', e);
    try {
      var writer2 = (typeof XLSXLite !== 'undefined') ? XLSXLite : XLSX;
      writer2.writeFile(wb, filename);
    } catch(e2) {
      toast('Export failed: ' + (e2.message || 'Unknown error') + '. Try a different browser.', 'danger');
    }
  }
}

function xlsxFmt(n) { return (n||0).toLocaleString('en-UG'); }

// ── 1. Download Student Template ──────────────────────────────
function xlsxDownloadStudentTemplate() {
  xlsxReady(function() {
  const XLSX = XLSXLite;
  const otherFees = DB.otherFees || [];

  const coreHeaders = [
    'First Name*', 'Last Name*', 'Admission No*', 'Class*',
    'Gender (Male/Female)', 'Date of Birth (YYYY-MM-DD)',
    'Parent/Guardian', 'Contact (+256...)', 'Boarding (day/boarding)',
    'Previous School', 'Join Term (1/2/3)'
  ];
  // Each other fee gets one column — user enters which terms e.g. "1" or "1,2" or "1,2,3"
  const feeHeaders = otherFees.map(f => f.name + ' [Other Fee — Terms e.g. 1 or 1,2]');
  const headers = [...coreHeaders, ...feeHeaders];

  const coreExample = [
    'Aisha', 'Nakamya', DB.settings.year+'/001', DB.classes[0]||'P.1',
    'Female', '2014-03-15', 'Moses Nakamya', '+256 771 234 567', 'day', '', '1'
  ];
  const feeExample = otherFees.map((f, i) => i === 0 ? '1,2,3' : '');
  const example = [...coreExample, ...feeExample];

  const noteRow = ['* = Required field', '', '', 'Valid Classes: '+DB.classes.join(', '),
    '','','','','','', 'Term student joined — 1, 2, or 3. Leave blank = Term 1 (charged from the start).',
    ...otherFees.map(() => 'Enter terms: 1 and/or 2 and/or 3, comma-separated. Leave blank = not assigned.')
  ];

  const ws = XLSX.utils.aoa_to_sheet([headers, example, noteRow]);
  const colWidths = [20,20,18,12,20,22,24,22,18,20,16, ...otherFees.map(()=>28)];
  ws['!cols'] = colWidths.map(w=>({wch:w}));

  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Students');

  // Instructions sheet
  const infoData = [
    ['SchoolMS Uganda — Bulk Student Upload Template'],
    ['Generated:', new Date().toLocaleString('en-UG')],
    ['School:', DB.settings.name || '—'],
    ['Academic Year:', DB.settings.year],
    [],
    ['COLUMN GUIDE:'],
    ['Column', 'Required?', 'Notes'],
    ['First Name', 'YES', "Student's first/given name"],
    ['Last Name', 'YES', "Student's surname/family name"],
    ['Admission No', 'YES', 'Must be unique (e.g. 2025/001). Auto-generated if blank.'],
    ['Class', 'YES', 'Must match exactly one of: ' + DB.classes.join(', ')],
    ['Gender', 'No', '"Male" or "Female" (defaults to Male if blank)'],
    ['Date of Birth', 'No', 'Format: YYYY-MM-DD  e.g. 2014-03-15'],
    ['Parent/Guardian', 'No', 'Full name of parent or guardian'],
    ['Contact', 'No', 'Phone number e.g. +256 771 234 557'],
    ['Boarding', 'No', '"day" or "boarding" (defaults to day)'],
    ['Previous School', 'No', 'Previous school name (optional)'],
    ['Join Term', 'No', 'Term the student joined the school — 1, 2, or 3. Leave blank = Term 1. Students joining mid-year (e.g. Term 2) will only be charged fees from that term onward.'],
    ...(otherFees.length ? [
      [],
      ['OTHER FEES COLUMNS (one column per other fee):'],
      ['Column Name Pattern', '', '"FeeName [Other Fee — Terms e.g. 1 or 1,2]"'],
      ['How to fill', '', 'Enter which terms to assign this fee e.g. "1" = Term 1 only, "1,2" = T1 and T2, "1,2,3" = all terms, blank = not assigned'],
      ...otherFees.map(f => [f.name, 'No',
        `T1: UGX ${(+f.t1||0).toLocaleString()}, T2: UGX ${(+f.t2||0).toLocaleString()}, T3: UGX ${(+f.t3||0).toLocaleString()}`])
    ] : [[], ['No other fees are currently defined in the system.']]),
    [],
    ['IMPORTANT RULES:'],
    ['1. Do NOT change or rename the header row (row 1).'],
    ['2. Start entering student data from row 2 (row 3 is notes — you can delete it).'],
    ['3. Admission numbers must be unique — duplicates are skipped.'],
    ['4. Rows where both First Name and Last Name are empty are ignored.'],
    ['5. Class names must match the system exactly (case-insensitive).'],
    [],
    ['VALID CLASSES (copy exactly):'],
    ...DB.classes.map(c => ['  ' + c]),
    [],
    ['CONTACT: WKJSoftwares — wellbornkeys234@gmail.com'],
  ];
  const wsInfo = XLSX.utils.aoa_to_sheet(infoData);
  wsInfo['!cols'] = [{wch:36},{wch:12},{wch:70}];
  XLSX.utils.book_append_sheet(wb, wsInfo, 'Instructions');

  xlsxSave(wb, 'SchoolMS_StudentUploadTemplate.xlsx');
  showAlert('Template downloaded! Fill in student data and upload it using "Bulk Upload".', '✅ Template Ready');
  }); // end xlsxReady
}

// ── 2. Open Bulk Upload Modal ────────────────────────────────
function xlsxBulkUploadStudents() {
  // Reset state
  window._bulkRows = [];
  document.getElementById('bulk-preview-area').style.display = 'none';
  document.getElementById('bulk-import-btn').style.display = 'none';
  document.getElementById('bulk-file-input').value = '';
  document.getElementById('bulk-warnings').innerHTML = '';
  openM('m-bulk-upload');
}

// ── 3. Handle file selection & parse ────────────────────────
function xlsxHandleBulkFile(input) {
  const file = input.files[0]; if (!file) return;
  // Reset state from any previous parse
  document.getElementById('bulk-preview-area').style.display = 'none';
  document.getElementById('bulk-import-btn').style.display = 'none';
  document.getElementById('bulk-warnings').innerHTML = '<div class="alert-box info" style="font-size:11.5px">⏳ Reading file…</div>';
  document.getElementById('bulk-count').textContent = '0';
  window._bulkRows = [];
  xlsxParseReady(function() { _xlsxHandleBulkFileParse(file); });
}
function _xlsxHandleBulkFileParse(file) {
  const reader = new FileReader();
  reader.onload = async function(e) {
    try {
      const data = new Uint8Array(e.target.result);
      const wb = await XLSXReader.readAsync(data);
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSXReader.utils.sheet_to_json(ws, {header:1, defval:''});

      if (!rows || rows.length < 2) {
        showAlert('The file appears empty or has no data rows.', '⚠️ Empty File');
        return;
      }

      // Find header row — look for a row containing "First Name" or "Admission"
      let headerIdx = 0;
      for (let i = 0; i < Math.min(5, rows.length); i++) {
        const row = rows[i].map(c => String(c||'').toLowerCase());
        if (row.some(c => c.includes('first') || c.includes('admission') || c.includes('adm'))) {
          headerIdx = i; break;
        }
      }
      const headers = rows[headerIdx].map(h => String(h||'').toLowerCase().trim());

      // Map column indices flexibly
      function colIdx(keywords) {
        const idx = headers.findIndex(h => keywords.some(k => h.includes(k)));
        return idx >= 0 ? idx : -1;
      }
      const cols = {
        fn:  colIdx(['first','fname','first name']),
        ln:  colIdx(['last','surname','lname','last name']),
        adm: colIdx(['adm','admission','reg no','reg number']),
        cls: colIdx(['class','grade','form']),
        gen: colIdx(['gender','sex']),
        dob: colIdx(['dob','birth','date of birth']),
        par: colIdx(['parent','guardian','father','mother']),
        con: colIdx(['contact','phone','mobile','tel']),
        brd: colIdx(['board','day/board']),
        ps:  colIdx(['previous','prev school','old school']),
        jt:  colIdx(['join term','joined term','join','entry term']),
      };

      // Detect other fee columns — header contains "[Other Fee" or matches a known fee name
      const otherFees = DB.otherFees || [];
      const otherFeeCols = []; // [{feeId, feeName, colIdx}]
      otherFees.forEach(f => {
        const fNameLower = f.name.toLowerCase();
        const matchIdx = headers.findIndex(h => {
          const hl = h.toLowerCase();
          return hl.includes(fNameLower) && (hl.includes('other fee') || hl.includes('term') || hl.includes('['));
        });
        if (matchIdx >= 0) otherFeeCols.push({ feeId: f.id, feeName: f.name, colIdx: matchIdx });
      });

      // Parse data rows
      const parsed = [];
      const warnings = [];
      const tier = getTier();
      const maxStudents = tier ? tier.maxStudents : 50;

      for (let i = headerIdx + 1; i < rows.length; i++) {
        const r = rows[i];
        // Skip empty rows
        if (r.every(c => !String(c||'').trim())) continue;

        const get = idx => idx >= 0 ? String(r[idx]||'').trim() : '';

        const fn = get(cols.fn);
        const ln = get(cols.ln);
        const adm = get(cols.adm) || (DB.settings.year + '/' + String(DB.students.length + parsed.length + 1).padStart(3,'0'));

        if (!fn && !ln) continue; // skip truly empty

        const clsRaw = get(cols.cls);
        const cls = DB.classes.find(c => c.toLowerCase() === clsRaw.toLowerCase()) || clsRaw || DB.classes[0];

        let genRaw = get(cols.gen).toLowerCase();
        const gen = genRaw.startsWith('f') ? 'Female' : genRaw.startsWith('m') ? 'Male' : 'Male';

        let brdRaw = get(cols.brd).toLowerCase();
        const brd = brdRaw.includes('board') ? 'boarding' : 'day';

        let dobRaw = get(cols.dob);
        // Handle Excel date serial numbers
        if (dobRaw && !isNaN(+dobRaw) && +dobRaw > 1000) {
          try {
            // SheetJS v0.20+ removed SSF.parse_date_code — use manual Excel serial conversion
            const serial = +dobRaw;
            const utcDays = serial - 25569; // Excel epoch offset from Unix epoch
            const d = new Date(utcDays * 86400 * 1000);
            dobRaw = d.toISOString().slice(0, 10);
          } catch(e) { dobRaw = ''; }
        } else if (dobRaw instanceof Date) {
          dobRaw = dobRaw.toISOString().slice(0,10);
        }

        // Join Term — which term the student enrolled in (gates fee charging)
        const jtRaw = get(cols.jt);
        let joinTerm = +jtRaw || 1;
        if (![1,2,3].includes(joinTerm)) {
          if (jtRaw) warnings.push(`Row ${i+1}: Invalid Join Term "${jtRaw}" — defaulted to Term 1.`);
          joinTerm = 1;
        }

        // Warnings
        if (!fn || !ln) warnings.push(`Row ${i+1}: Missing name — will still be imported if partial.`);
        if (!DB.classes.includes(cls)) warnings.push(`Row ${i+1}: Class "${clsRaw}" not in system — will use as-is.`);

        // Check duplicate adm in upload batch
        const isDupInBatch = parsed.some(p => p.adm === adm);
        const isDupInDB = DB.students.some(s => s.adm === adm);
        if (isDupInDB) { warnings.push(`Row ${i+1}: Adm "${adm}" already exists — will be skipped.`); continue; }
        if (isDupInBatch) { warnings.push(`Row ${i+1}: Adm "${adm}" duplicated in file — second entry skipped.`); continue; }

        // Parse other fee assignments from columns
        const otherFeeIds = { t1: [], t2: [], t3: [] };
        otherFeeCols.forEach(fc => {
          const raw = get(fc.colIdx);
          if (!raw) return;
          // Accept: "1", "1,2", "1,2,3", "T1", "T1,T2", "all", "yes" (yes = all terms)
          const val = raw.toLowerCase().replace(/\s/g,'').replace(/t/g,'');
          const terms = val === 'yes' || val === 'all' ? [1,2,3]
            : val.split(',').map(Number).filter(n => [1,2,3].includes(n));
          terms.forEach(t => {
            if (!otherFeeIds['t'+t].includes(fc.feeId)) otherFeeIds['t'+t].push(fc.feeId);
          });
        });

        parsed.push({ fn, ln, adm, cls, gen, dob: dobRaw, par: get(cols.par), con: get(cols.con), brd, ps: get(cols.ps), joinTerm, otherFeeIds });
      }

      window._bulkRows = parsed;

      // Render preview
      document.getElementById('bulk-count').textContent = parsed.length;
      const previewHead = document.getElementById('bulk-preview-head');
      const previewBody = document.getElementById('bulk-preview-body');
      const otherFeeColspan = 9 + (otherFeeCols.length > 0 ? 1 : 0);
      const otherFeeHeader = otherFeeCols.length > 0 ? '<th style="color:#7c3aed">Other Fees</th>' : '';
      previewHead.innerHTML = '<th>Adm No.</th><th>First Name</th><th>Last Name</th><th>Class</th><th>Gender</th><th>Boarding</th><th>Parent</th><th>Contact</th><th>Join Term</th>' + otherFeeHeader;
      previewBody.innerHTML = parsed.slice(0,20).map((s,i) => {
        const assignedFees = otherFeeCols.filter(fc => {
          return [1,2,3].some(t => (s.otherFeeIds['t'+t]||[]).includes(fc.feeId));
        });
        const feeCell = otherFeeCols.length > 0
          ? `<td style="font-size:10.5px;color:#7c3aed">${assignedFees.length ? assignedFees.map(fc => {
              const terms = [1,2,3].filter(t=>(s.otherFeeIds['t'+t]||[]).includes(fc.feeId));
              return fc.feeName+' (T'+terms.join(',T')+')';
            }).join('<br>') : '<span style="color:var(--text3)">—</span>'}</td>`
          : '';
        return `<tr style="${i%2===0?'background:var(--surface2)':''}">
          <td>${s.adm}</td><td>${s.fn}</td><td>${s.ln}</td>
          <td><span class="badge badge-info">${s.cls}</span></td>
          <td>${s.gen}</td>
          <td><span class="chip">${s.brd==='boarding'?'🏠':'🚶'} ${s.brd}</span></td>
          <td style="font-size:11.5px">${s.par||'—'}</td>
          <td style="font-size:11.5px">${s.con||'—'}</td>
          <td style="text-align:center">${s.joinTerm>1?`<span class="badge badge-warning">T${s.joinTerm}</span>`:`<span style="color:var(--text3)">T1</span>`}</td>
          ${feeCell}
        </tr>`;
      }).join('') + (parsed.length > 20 ? `<tr><td colspan="${otherFeeColspan}" style="text-align:center;color:var(--text3);padding:8px">…and ${parsed.length - 20} more</td></tr>` : '');

      // Warnings
      const warnEl = document.getElementById('bulk-warnings');
      if (warnings.length) {
        warnEl.innerHTML = `<div class="alert-box warning" style="font-size:11.5px;max-height:120px;overflow-y:auto">
          <strong>⚠️ ${warnings.length} notice(s):</strong><br>${warnings.slice(0,10).map(w=>`• ${w}`).join('<br>')}${warnings.length>10?`<br>…and ${warnings.length-10} more`:''}
        </div>`;
      } else {
        warnEl.innerHTML = `<div class="alert-box success" style="font-size:11.5px">✅ No issues detected. Ready to import.</div>`;
      }

      document.getElementById('bulk-preview-area').style.display = '';
      document.getElementById('bulk-import-btn').style.display = parsed.length > 0 ? '' : 'none';

    } catch(err) {
      showAlert('Could not read the file. Make sure it is a valid Excel (.xlsx/.xls) or CSV file.\n\nError: '+err.message, '❌ File Error');
    }
  };
  reader.readAsArrayBuffer(file);
}

// ── 4. Confirm & Execute Import ──────────────────────────────
function xlsxConfirmBulkImport() {
  const rows = window._bulkRows || [];
  if (!rows.length) { showAlert('No valid rows to import.'); return; }

  if (!licenseActive()) {
    showAlert('No active license. Activate a license in the <strong>License</strong> tab to import students.', '🔐 License Required');
    return;
  }

  const tier = getTier();
  const maxStudents = tier ? tier.maxStudents : 50;
  const available = maxStudents - activeStudentCount();
  const toAdd = rows.slice(0, available);

  if (toAdd.length < rows.length) {
    if (available <= 0) {
      showAlert(`Student limit reached (${maxStudents}). Upgrade your license to add more.`, '🔐 Limit Reached');
      return;
    }
    showAlert(`License allows ${maxStudents} students total. You have ${activeStudentCount()} already. Only the first ${available} students will be imported.`, '⚠️ Partial Import');
  }

  toAdd.forEach(s => {
    s.id = genId('st');
    DB.students.push(s);
  });

  addAct(`Bulk imported ${toAdd.length} student(s) from Excel`);
  saveDB();
  closeM('m-bulk-upload');
  populateClassFilters();
  renderStudents();
  showAlert(`✅ ${toAdd.length} student(s) imported successfully!`, 'Bulk Import Complete');
}

