function expTab(tab, el) {
  document.querySelectorAll('#page-expenses .tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('exp-ledger').style.display = tab==='ledger' ? '' : 'none';
  document.getElementById('exp-summary').style.display = tab==='summary' ? '' : 'none';
  if (tab==='ledger') renderExpenses();
  if (tab==='summary') renderExpenseSummary();
}

function renderExpenses() {
  const term = document.getElementById('exp-filter-term')?.value || 'all';
  const cat  = document.getElementById('exp-filter-cat')?.value  || '';
  const rows = (DB.expenses||[]).filter(e=>{
    const termMatch = term==='all' || +e.term===+term;
    const catMatch  = !cat || e.category===cat;
    return termMatch && catMatch;
  });
  const termRows = (DB.expenses||[]).filter(e=>term==='all'||+e.term===+term);
  const termTotal = termRows.reduce((a,b)=>a+(+b.amount||0),0);
  const grandTotal = (DB.expenses||[]).reduce((a,b)=>a+(+b.amount||0),0);
  if(document.getElementById('exp-total')) document.getElementById('exp-total').textContent = fmt(grandTotal);
  if(document.getElementById('exp-term-total')) document.getElementById('exp-term-total').textContent = fmt(termTotal);
  if(document.getElementById('exp-count')) document.getElementById('exp-count').textContent = rows.length;
  // Net Income: fees collected this term minus expenses this term
  const netEl = document.getElementById('exp-net-income');
  if (netEl) {
    const currentTerm = term === 'all' ? (DB.settings.term || 2) : +term;
    const termFeesCollected = DB.students.reduce((a,s) => a + getTotalPaid(s.id, currentTerm), 0);
    const netIncome = termFeesCollected - termTotal;
    netEl.textContent = fmt(Math.abs(netIncome));
    netEl.style.color = netIncome >= 0 ? 'var(--success)' : 'var(--danger)';
    netEl.parentElement.querySelector('.m-label').textContent = netIncome >= 0 ? 'Net Income (Term)' : 'Net Deficit (Term)';
  }
  document.getElementById('exp-rows').innerHTML = rows.length ? rows.map(e=>`<tr>
    <td>${e.date}</td>
    <td><strong>${e.desc}</strong></td>
    <td><span class="badge badge-info">${e.category||'—'}</span></td>
    <td>Term ${e.term}</td>
    <td style="font-weight:600">UGX ${fmt(e.amount)}</td>
    <td style="font-size:11.5px">${e.approvedBy||'—'}</td>
    <td style="font-size:11.5px;font-family:monospace">${e.receipt||'—'}</td>
    <td style="white-space:nowrap">
      <button class="btn btn-xs" onclick="editExpense('${e.id}')"><i class="ti ti-edit"></i>Edit</button>
      <button class="btn btn-xs btn-danger" onclick="deleteExpense('${e.id}')" title="Delete expense"><i class="ti ti-trash"></i>Delete</button>
    </td></tr>`).join('')
  : `<tr><td colspan="8"><div class="empty"><i class="ti ti-receipt-2"></i><p>No expenses recorded.</p></div></td></tr>`;
}

function renderExpenseSummary() {
  const cats = {};
  (DB.expenses||[]).forEach(e=>{
    const c = e.category||'Other';
    if (!cats[c]) cats[c]={total:0,count:0};
    cats[c].total += +e.amount||0;
    cats[c].count++;
  });
  const grand = Object.values(cats).reduce((a,b)=>a+b.total,0);
  document.getElementById('exp-summary-content').innerHTML = `
    <div class="card">
      <div class="section-hd">Expenses by Category</div>
      <table><thead><tr><th>Category</th><th>No. of Records</th><th>Total (UGX)</th><th>% of Total</th></tr></thead>
      <tbody>${Object.entries(cats).sort((a,b)=>b[1].total-a[1].total).map(([c,d])=>`<tr>
        <td><strong>${c}</strong></td><td>${d.count}</td>
        <td style="font-weight:600">UGX ${fmt(d.total)}</td>
        <td>${grand?Math.round(d.total/grand*100):0}%</td>
      </tr>`).join('')||'<tr><td colspan="4"><div class="empty"><p>No data.</p></div></td></tr>'}
      </tbody>
      <tfoot><tr style="background:var(--surface2);font-weight:700"><td>TOTAL</td><td></td><td>UGX ${fmt(grand)}</td><td>100%</td></tr></tfoot>
      </table>
    </div>`;
}

let _editExpId = null;

function xlsxExportExpenses() {
  const XLSX = XLSXLite;
  const term = document.getElementById('exp-filter-term')?.value || 'all';
  const cat  = document.getElementById('exp-filter-cat')?.value  || '';
  const rows = (DB.expenses||[]).filter(e => {
    const termMatch = term==='all' || +e.term===+term;
    const catMatch  = !cat || e.category===cat;
    return termMatch && catMatch;
  }).sort((a,b) => a.date.localeCompare(b.date));
  if (!rows.length) { toast('No expenses to export','warning'); return; }
  const headers = ['Date','Description','Category','Term','Amount (UGX)','Approved By','Receipt/Ref'];
  const data = rows.map(e => [e.date, e.desc, e.category||'', e.term, e.amount, e.approvedBy||'', e.receipt||'']);
  const totalRow = ['TOTAL','','','', rows.reduce((a,e)=>a+(+e.amount||0),0),'',''];
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet([
    ['SchoolMS Uganda — Expense Report'],
    ['School: '+(DB.settings.name||''), 'Term: '+(term==='all'?'All':term), 'Generated: '+today()],
    [],
    headers, ...data, [], totalRow
  ]);
  ws['!cols'] = [14,30,18,8,18,20,16].map(w=>({wch:w}));
  XLSX.utils.book_append_sheet(wb, ws, 'Expenses');
  const cats = {};
  rows.forEach(e => { const c=e.category||'Other'; if(!cats[c])cats[c]=0; cats[c]+=(+e.amount||0); });
  const sumData = [['Category','Total (UGX)'], ...Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([c,v])=>[c,v])];
  const wsSum = XLSX.utils.aoa_to_sheet(sumData);
  wsSum['!cols'] = [{wch:20},{wch:18}];
  XLSX.utils.book_append_sheet(wb, wsSum, 'By Category');
  xlsxSave(wb, `SchoolMS_Expenses_Term${term}_${today()}.xlsx`);
  addAct('Expenses exported to Excel');
  toast('Expenses exported','success');
}

function openAddExpense() {
  _editExpId = null;
  document.getElementById('m-exp-title').textContent = 'Add Expense';
  ['m-exp-desc','m-exp-approved','m-exp-receipt'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('m-exp-date').value = today();
  document.getElementById('m-exp-amount').value = '';
  document.getElementById('m-exp-term').value = DB.settings.term||2;
  openM('m-expense');
}
function editExpense(id) {
  const e = (DB.expenses||[]).find(x=>x.id===id); if(!e) return;
  _editExpId = id;
  document.getElementById('m-exp-title').textContent = 'Edit Expense';
  document.getElementById('m-exp-desc').value = e.desc||'';
  document.getElementById('m-exp-date').value = e.date||today();
  document.getElementById('m-exp-amount').value = e.amount||'';
  document.getElementById('m-exp-cat').value = e.category||'Other';
  document.getElementById('m-exp-term').value = e.term||2;
  document.getElementById('m-exp-approved').value = e.approvedBy||'';
  document.getElementById('m-exp-receipt').value = e.receipt||'';
  openM('m-expense');
}
function saveExpense() {
  const desc = document.getElementById('m-exp-desc').value.trim();
  const amount = +document.getElementById('m-exp-amount').value;
  if (!desc) { showAlert('Enter a description.'); return; }
  if (!amount||amount<=0) { showAlert('Enter a valid amount.'); return; }
  const d = {
    desc, amount,
    date: document.getElementById('m-exp-date').value,
    category: document.getElementById('m-exp-cat').value,
    term: +document.getElementById('m-exp-term').value,
    approvedBy: document.getElementById('m-exp-approved').value.trim(),
    receipt: document.getElementById('m-exp-receipt').value.trim()
  };
  if (!DB.expenses) DB.expenses = [];
  if (_editExpId) {
    const i = DB.expenses.findIndex(e=>e.id===_editExpId);
    DB.expenses[i] = {...DB.expenses[i], ...d};
  } else {
    d.id = genId('exp'); DB.expenses.push(d);
    addAct('Expense recorded: '+desc+' — UGX '+fmt(amount));
  }
  saveDB(); closeM('m-expense'); renderExpenses();
}
function deleteExpense(id) {
  showConfirm('Delete this expense record?', ()=>{
    DB.expenses = (DB.expenses||[]).filter(e=>e.id!==id);
    saveDB(); renderExpenses();
  });
}

