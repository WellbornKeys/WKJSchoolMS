function printReports() {
  const cls = document.getElementById('rpt-class').value;
  if (!cls) { showAlert('Select a class first.'); return; }
  const zone = document.getElementById('report-print-zone').innerHTML;
  if (!zone||zone.trim()==='') { showAlert('Generate report cards first.'); return; }
  const term = document.getElementById('rpt-term')?.value || DB.settings.term || 2;
  const termName = ['','Term 1','Term 2','Term 3'][+term]||('Term '+term);
  const htmlContent = `<!DOCTYPE html><html><head><title>Report Cards</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;600&display=swap" rel="stylesheet">
  <style>*{box-sizing:border-box}body{font-family:'DM Sans',sans-serif;font-size:11pt;color:#000;margin:0;padding:0}
  .card{page-break-after:always;border:none!important;box-shadow:none!important;padding:12mm;margin:0!important}
  @media print{@page{size:A4;margin:8mm}body{font-size:10pt}}
  </style></head><body>${zone}</body></html>`;
  // Save PDF copy first
  const pdfWin = window.open('','_blank','width=900,height=700');
  if (pdfWin) {
    pdfWin.document.write(htmlContent.replace('</body>','<script>window.onload=function(){window.print();setTimeout(()=>window.close(),2500)}<\/script></body>'));
    pdfWin.document.close();
    toast('PDF copy saved — printing report cards…','success');
  }
  // Print via iframe
  const frame = document.createElement('iframe');
  frame.style.cssText='position:fixed;right:0;bottom:0;width:0;height:0;border:0';
  document.body.appendChild(frame);
  const doc = frame.contentWindow.document;
  doc.open();
  doc.write(htmlContent);
  doc.close();
  setTimeout(()=>{
    frame.contentWindow.focus();
    frame.contentWindow.print();
    setTimeout(()=>frame.remove(), 1200);
  }, 500);
}

// Share all report cards in current class via WhatsApp (one by one)
function shareAllReportsWhatsApp() {
  const cls = document.getElementById('rpt-class').value;
  const term = +(document.getElementById('rpt-term')?.value || DB.settings.term || 2);
  if (!cls) { showAlert('Select a class first.'); return; }
  const sts = DB.students.filter(s=>s.cls===cls && s.con);
  if (!sts.length) { showAlert('No students in this class have a parent contact number saved.','⚠️ No Contacts'); return; }
  // Open WhatsApp for first student, with confirmation for many
  const send = ()=>{
    let opened = 0;
    const toSend = sts.slice(0, 5); // Browser popup limit
    toSend.forEach(s=>{ shareReportWhatsApp(s.id, term); opened++; });
    if (sts.length > 5)
      toast(`WhatsApp opened for first 5 of ${sts.length}. Repeat for the remaining ${sts.length-5}.`,'info',6000);
    else
      toast(`WhatsApp report sent to ${opened} parent(s) in ${cls}.`,'success');
  };
  if (sts.length > 3)
    showConfirm(`Send report cards for ${cls} to ${sts.length} parents via WhatsApp?`, send);
  else send();
}

