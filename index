function xlsxHandleBulkMarks(input) {
  const file = input.files[0]; if(!file) return;
  xlsxParseReady(function() { _xlsxHandleBulkMarksParse(file); });
}
function _xlsxHandleBulkMarksParse(file) {
  const reader = new FileReader();
  reader.onload = async e => {
    try {
      const data = new Uint8Array(e.target.result);
      const wb = await XLSXReader.readAsync(data);
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSXReader.utils.sheet_to_json(ws,{header:1,defval:''});
      // Find header row containing 'Adm' or 'BOT'
      let hi = 0;
      for(let i=0;i<Math.min(6,rows.length);i++) {
        const r = rows[i].map(c=>String(c||'').toLowerCase());
        if(r.some(c=>c.includes('adm')||c.includes('bot')||c.includes('mid'))) { hi=i; break; }
      }
      const headers = rows[hi].map(h=>String(h||'').toLowerCase().trim());
      const find = kws => { const i=headers.findIndex(h=>kws.some(k=>h.includes(k))); return i>=0?i:-1; };
      const cols = { adm:find(['adm','reg']), bot:find(['bot','begin','beginning']), mid:find(['mid','mid-term']), eot:find(['eot','end','final']), name:find(['name','student']) };
      // Validate we found at least adm and one mark column
      if (cols.adm < 0) { toast('Could not find Admission No column in file','danger'); return; }
      const parsed = [];
      for(let i=hi+1;i<rows.length;i++) {
        const r=rows[i]; if(r.every(c=>!String(c||'').trim())) continue;
        const get=idx=>idx>=0?String(r[idx]||'').trim():'';
        const adm=get(cols.adm); if(!adm) continue;
        const s=DB.students.find(x=>x.adm===adm); if(!s) continue;
        parsed.push({s, bot:+get(cols.bot)||0, mid:+get(cols.mid)||0, eot:+get(cols.eot)||0});
      }
      window._bulkMarks = parsed;
      const prev = document.getElementById('bmk-preview');
      prev.style.display='';
      prev.innerHTML=`<div class="alert-box success" style="font-size:12px">✅ ${parsed.length} student mark record(s) parsed. Click <strong>Import Marks</strong> to apply.</div>
      <div style="max-height:200px;overflow-y:auto"><table><thead><tr><th>Student</th><th>BOT</th><th>Mid</th><th>EOT</th><th>Total</th></tr></thead>
      <tbody>${parsed.slice(0,10).map(({s,bot,mid,eot})=>`<tr><td>${s.fn} ${s.ln}</td><td>${bot}</td><td>${mid}</td><td>${eot}</td><td style="font-weight:700">${bot+mid+eot}</td></tr>`).join('')}${parsed.length>10?`<tr><td colspan="5" style="text-align:center;color:var(--text3)">…and ${parsed.length-10} more</td></tr>`:''}</tbody></table></div>`;
      document.getElementById('bmk-import-btn').style.display = parsed.length?'':'none';
    } catch(err) { toast('Could not read file: '+err.message,'danger'); }
  };
  reader.readAsArrayBuffer(file);
}

function xlsxConfirmBulkMarks() {
  const cls = document.getElementById('bmk-class')?.value;
  const sub = document.getElementById('bmk-subject')?.value;
  const term = document.getElementById('bmk-term')?.value || '2';
  if(!cls||!sub) { toast('Select class and subject first','warning'); return; }
  const rows = window._bulkMarks||[];
  if(!rows.length) { toast('No marks to import','warning'); return; }
  const key = cls+'||'+sub+'||'+term;
  if(!DB.marks[key]) DB.marks[key]={};
  rows.forEach(({s,bot,mid,eot})=>{DB.marks[key][s.id]={bot,mid,eot};});
  saveDB(); closeM('m-bulk-marks');
  renderMarks();
  addAct(`Bulk imported marks for ${cls} ${sub} Term ${term}`);
  toast(`${rows.length} student marks imported for ${sub}!`,'success');
}

