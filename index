// ============================================================
//  PERSISTENCE
// ============================================================
// ============================================================
//  INDEXEDDB PERSISTENCE  (replaces 5 MB localStorage limit)
// ============================================================
// Safe console shim — some environments (older WebViews) omit certain methods
var _con = (typeof console !== 'undefined') ? console : {};
var _log = (_con.log   || function(){}).bind(_con);
var _warn = (_con.warn || _log).bind(_con);
const IDB_NAME    = 'schoolms_db';
const IDB_VERSION = 2; // bumped to add 'backups' object store
const IDB_STORE   = 'appdata';
const IDB_KEY     = 'sms_wkj_v10';
const IDB_BACKUP_STORE = 'backups';
const AUTO_BACKUP_MAX  = 5;   // rolling slots
const AUTO_BACKUP_INTERVAL_MS = 24 * 60 * 60 * 1000; // 24 h

function _idbOpen() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(IDB_NAME, IDB_VERSION);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(IDB_STORE)) {
        db.createObjectStore(IDB_STORE);
      }
      if (!db.objectStoreNames.contains(IDB_BACKUP_STORE)) {
        db.createObjectStore(IDB_BACKUP_STORE, { keyPath: 'slot' });
      }
    };
    req.onsuccess = e => resolve(e.target.result);
    req.onerror   = e => reject(e.target.error);
  });
}

function _idbGet(db) {
  return new Promise((resolve, reject) => {
    const tx  = db.transaction(IDB_STORE, 'readonly');
    const req = tx.objectStore(IDB_STORE).get(IDB_KEY);
    req.onsuccess = e => resolve(e.target.result);
    req.onerror   = e => reject(e.target.error);
  });
}

function _idbPut(db, value) {
  return new Promise((resolve, reject) => {
    const tx  = db.transaction(IDB_STORE, 'readwrite');
    const req = tx.objectStore(IDB_STORE).put(value, IDB_KEY);
    req.onsuccess = () => resolve();
    req.onerror   = e => reject(e.target.error);
  });
}

// saveDB — async, fire-and-forget. Falls back to localStorage for small payloads.
function saveDB() {
  const raw = JSON.stringify(DB);
  // Always attempt IndexedDB (no size limit)
  _idbOpen().then(db => _idbPut(db, raw)).catch(err => {
    _warn('IndexedDB save failed, falling back to localStorage', err);
    try {
      localStorage.setItem(IDB_KEY, raw);
      sessionStorage.setItem(IDB_KEY, raw);
    } catch(e) {
      if (typeof showAlert === 'function') {
        showAlert('Storage is full. Please export a JSON backup and then use Reset All Data to free space, or clear old payments/records.', '⚠️ Storage Full');
      } else {
        alert('Storage full — please export a JSON backup and clear old entries to free space.');
      }
    }
  });
  // Also keep a lightweight "last-save" timestamp in localStorage for diagnostics
  try { localStorage.setItem('sms_last_save', Date.now()); } catch(_) {}
}

// Debounced saveDB — used for oninput handlers to avoid writing to IndexedDB on every keystroke
let _saveDBTimer = null;
function saveDBDebounced() {
  if (_saveDBTimer) clearTimeout(_saveDBTimer);
  _saveDBTimer = setTimeout(saveDB, 400);
}
// ============================================================
//  AUTO-BACKUP SYSTEM
//  Keeps up to AUTO_BACKUP_MAX rolling snapshots in IDB.
//  Triggered on login and every 24 h while the app is open.
//  Backups are stored in the 'backups' IDB object store;
//  they are completely separate from the main DB record.
// ============================================================

// ── Low-level IDB helpers for the backups store ─────────────
function _backupGetAll(db) {
  return new Promise((resolve, reject) => {
    const tx  = db.transaction(IDB_BACKUP_STORE, 'readonly');
    const req = tx.objectStore(IDB_BACKUP_STORE).getAll();
    req.onsuccess = e => resolve(e.target.result || []);
    req.onerror   = e => reject(e.target.error);
  });
}
function _backupPut(db, record) {
  return new Promise((resolve, reject) => {
    const tx  = db.transaction(IDB_BACKUP_STORE, 'readwrite');
    const req = tx.objectStore(IDB_BACKUP_STORE).put(record);
    req.onsuccess = () => resolve();
    req.onerror   = e => reject(e.target.error);
  });
}
function _backupDelete(db, slot) {
  return new Promise((resolve, reject) => {
    const tx  = db.transaction(IDB_BACKUP_STORE, 'readwrite');
    const req = tx.objectStore(IDB_BACKUP_STORE).delete(slot);
    req.onsuccess = () => resolve();
    req.onerror   = e => reject(e.target.error);
  });
}

// ── Core: create one backup snapshot ────────────────────────
async function createAutoBackup(label) {
  try {
    const db       = await _idbOpen();
    const existing = await _backupGetAll(db);

    // Sort oldest-first so we can evict slot 0 when full
    existing.sort((a, b) => a.ts - b.ts);

    // Determine next slot number (0-4, wrapping)
    let slot = 0;
    if (existing.length < AUTO_BACKUP_MAX) {
      slot = existing.length;
    } else {
      // Reuse the slot of the oldest backup
      slot = existing[0].slot;
    }

    const snapshot = JSON.stringify(DB);
    const record = {
      slot,
      ts:      Date.now(),
      label:   label || 'Auto',
      school:  DB.settings.name || 'Unknown',
      students: DB.students.length,
      bytes:   new Blob([snapshot]).size,
      data:    snapshot
    };

    await _backupPut(db, record);

    // Persist the timestamp so the 24-h interval knows when we last ran
    try { localStorage.setItem('sms_last_autobackup', Date.now()); } catch(_) {}

    _log('SchoolMS: auto-backup saved to slot', slot, '—', DB.students.length, 'students');
    renderAutoBackupPanel(); // refresh UI if visible
  } catch (err) {
    _warn('SchoolMS: auto-backup failed', err);
  }
}

// ── Restore a backup by slot number ─────────────────────────
async function restoreAutoBackup(slot) {
  try {
    const db       = await _idbOpen();
    const existing = await _backupGetAll(db);
    const record   = existing.find(r => r.slot === slot);
    if (!record) { showAlert('Backup not found.', '⚠️ Error'); return; }

    const parsed = JSON.parse(record.data);
    if (!parsed || typeof parsed !== 'object') { showAlert('Backup data is corrupt.', '⚠️ Error'); return; }

    // Preserve the current machine license — same rule as importData
    const _currentLicense = DB.license;
    const _currentMachineId = DB.settings._machineId;

    DB = {
      ...DB,
      ...parsed,
      license:  _currentLicense,
      settings: { ...parsed.settings, _machineId: _currentMachineId }
    };
    saveDB();
    showAlert(
      'Backup from ' + new Date(record.ts).toLocaleString('en-UG') + ' restored successfully.\n\nThe page will reload to apply changes.',
      '✅ Restored'
    );
    setTimeout(() => location.reload(), 1800);
  } catch (err) {
    showAlert('Restore failed: ' + err.message, '⚠️ Error');
  }
}

// ── Download a backup slot as a JSON file ───────────────────
async function downloadAutoBackup(slot) {
  try {
    const db       = await _idbOpen();
    const existing = await _backupGetAll(db);
    const record   = existing.find(r => r.slot === slot);
    if (!record) { showAlert('Backup not found.', '⚠️ Error'); return; }
    const ts = new Date(record.ts);
    const fname = 'SchoolMS_Backup_' + ts.toISOString().slice(0,10) + '_slot' + slot + '.json';
    const blob = new Blob([record.data], { type: 'application/json' });
    downloadBlob(blob, fname);
  } catch (err) {
    showAlert('Download failed: ' + err.message, '⚠️ Error');
  }
}

// ── Delete a single backup slot ──────────────────────────────
async function deleteAutoBackup(slot) {
  showConfirm('Delete this backup snapshot?', async () => {
    try {
      const db = await _idbOpen();
      await _backupDelete(db, slot);
      renderAutoBackupPanel();
      toast('Backup deleted', 'info');
    } catch (err) {
      showAlert('Delete failed: ' + err.message, '⚠️ Error');
    }
  });
}

// ── Render the backup panel in Settings → Data & Backup ─────
async function renderAutoBackupPanel() {
  const el = document.getElementById('auto-backup-panel');
  if (!el) return;

  el.innerHTML = '<div style="font-size:12px;color:var(--text3)">Loading backups…</div>';

  try {
    const db       = await _idbOpen();
    const existing = await _backupGetAll(db);
    existing.sort((a, b) => b.ts - a.ts); // newest first

    const lastTs   = localStorage.getItem('sms_last_autobackup');
    const nextDue  = lastTs ? new Date(+lastTs + AUTO_BACKUP_INTERVAL_MS) : null;
    const nextStr  = nextDue ? nextDue.toLocaleString('en-UG') : 'on next login';

    if (!existing.length) {
      el.innerHTML = `
        <div style="font-size:12.5px;color:var(--text3);padding:10px 0">
          No backups yet. Click <strong>Back Up Now</strong> to create the first snapshot.
        </div>`;
      return;
    }

    const rows = existing.map(r => {
      const date  = new Date(r.ts).toLocaleString('en-UG');
      const size  = r.bytes < 1024*1024
        ? (r.bytes/1024).toFixed(1) + ' KB'
        : (r.bytes/1024/1024).toFixed(2) + ' MB';
      return `
        <div style="display:flex;align-items:center;gap:8px;padding:9px 0;border-bottom:1px solid var(--border);flex-wrap:wrap">
          <div style="flex:1;min-width:140px">
            <div style="font-size:12.5px;font-weight:600;color:var(--text1)">${r.label} — ${date}</div>
            <div style="font-size:11px;color:var(--text3)">${r.students} students &nbsp;·&nbsp; ${size} &nbsp;·&nbsp; ${r.school}</div>
          </div>
          <div style="display:flex;gap:5px;flex-shrink:0">
            <button class="btn btn-xs btn-success" onclick="showConfirm('Restore this backup? Current data will be replaced.',()=>restoreAutoBackup(${r.slot}))">
              <i class="ti ti-history"></i>Restore
            </button>
            <button class="btn btn-xs" onclick="downloadAutoBackup(${r.slot})" title="Download as JSON">
              <i class="ti ti-download"></i>
            </button>
            <button class="btn btn-xs btn-danger" onclick="deleteAutoBackup(${r.slot})" title="Delete">
              <i class="ti ti-trash"></i>
            </button>
          </div>
        </div>`;
    }).join('');

    el.innerHTML = `
      <div style="font-size:11px;color:var(--text3);margin-bottom:8px">
        ${existing.length} of ${AUTO_BACKUP_MAX} slots used &nbsp;·&nbsp; Next auto-backup: ${nextStr}
      </div>
      ${rows}`;
  } catch (err) {
    el.innerHTML = '<div style="font-size:12px;color:var(--danger)">Failed to load backups: ' + err.message + '</div>';
  }
}

// ── Scheduler: fires on login and every 24 h ─────────────────
function scheduleAutoBackup() {
  const lastTs  = localStorage.getItem('sms_last_autobackup');
  const elapsed = lastTs ? Date.now() - +lastTs : Infinity;

  if (elapsed >= AUTO_BACKUP_INTERVAL_MS) {
    // Due now — fire immediately then schedule next
    createAutoBackup('Auto');
  }
  // Schedule the next check 1 h from now; will trigger if 24 h have elapsed
  setTimeout(function _autoBackupTick() {
    if (currentUser) createAutoBackup('Auto'); // only while logged in
    setTimeout(_autoBackupTick, 60 * 60 * 1000);
  }, 60 * 60 * 1000);
}



// _applyLoaded — shared merge logic used by both loadDB paths
function _applyLoaded(saved) {
  if (!saved) return;
  // Preserve the in-memory (localStorage) machineId — never let an old saved record
  // overwrite it. The localStorage value is always the authoritative machine identity.
  const _preservedMachineId = DB.settings._machineId ||
        (typeof localStorage !== 'undefined' ? localStorage.getItem('sms_mid_v1') : null) ||
        (saved.settings||{})._machineId || null;
  DB = {
    ...DB, ...saved,
    settings: {...DB.settings, ...(saved.settings||{}), _machineId: _preservedMachineId},
    reportSettings: {...DB.reportSettings, ...(saved.reportSettings||{}), classSubjects: {...(DB.reportSettings.classSubjects||{}), ...((saved.reportSettings||{}).classSubjects||{})}},
    syncMeta: {lastSync: null, pendingPush: false, firebase: null, ...(saved.syncMeta||{}), firebase: (saved.syncMeta||{}).firebase || null},
    expenses: saved.expenses || [],
    staffAttendance: saved.staffAttendance || {},
    cca: saved.cca || [],
    ccaEnroll: saved.ccaEnroll || {},
    oneTimeFees: [], // legacy migration stub - kept for import compat
    recurringFees: saved.recurringFees || [],
    classFeeDefaults: saved.classFeeDefaults || {},
    studentTermOverrides: saved.studentTermOverrides || {},
    otherFees: saved.otherFees || [],
    bursaries: saved.bursaries || [],
    feeStructures: saved.feeStructures || []
  };
  if (!DB.usedKeys) DB.usedKeys = [];
  if (!DB.reportSettings.customGrades || !DB.reportSettings.customGrades.length)
    DB.reportSettings.customGrades = getDefaultGrades();

  // ====== MIGRATION: old feeStructures → new recurringFees + classFeeDefaults ======
  if (DB.feeStructures && DB.feeStructures.length && !DB.recurringFees.length) {
    const seen = new Set();
    DB.feeStructures.forEach(fs => {
      (fs.components||[]).forEach(c => {
        const key = c.name.trim().toLowerCase();
        if (!seen.has(key)) {
          seen.add(key);
          DB.recurringFees.push({id: genId('rf'), name: c.name, t1: +c.t1||0, t2: +c.t2||0, t3: +c.t3||0});
        }
      });
      if (fs.oneTimeFees && fs.oneTimeFees.length) {
        fs.oneTimeFees.forEach(f => {
          const key = f.name.trim().toLowerCase();
          const exists = DB.oneTimeFees.some(x => x.name.trim().toLowerCase() === key);
          if (!exists) DB.oneTimeFees.push({id: genId('otf'), name: f.name, amount: +f.amount||0});
        });
      }
    });
    if (!Object.keys(DB.classFeeDefaults).length) {
      DB.classes.forEach(cls => {
        DB.classFeeDefaults[cls] = {
          recurring: DB.recurringFees.map(f=>f.id),
          // onetime removed
        };
      });
    } else {
      DB.classes.forEach(cls => {
        if (!DB.classFeeDefaults[cls]) DB.classFeeDefaults[cls] = {recurring:[], onetime:[], amounts:{}};
        DB.recurringFees.forEach(f => {
          if (!DB.classFeeDefaults[cls].recurring.includes(f.id)) {
            DB.classFeeDefaults[cls].recurring.push(f.id);
          }
        });
      });
    }
    DB.students.forEach(s => { if (s.feeStruct) delete s.feeStruct; });
    DB.feeStructures = [];
    saveDB();
  }
  (DB.feeStructures||[]).forEach(fs => {
    if (fs.oneTimeFees && fs.oneTimeFees.length) {
