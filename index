// Term date ranges (approximate — based on Uganda school calendar)
const TERM_MONTH_RANGES = {
  1: {start:1, end:4},   // Jan-Apr (Term 1)
  2: {start:5, end:8},   // May-Aug (Term 2)
  3: {start:9, end:12},  // Sep-Dec (Term 3)
};

function getTermDates(year, term) {
  const r = TERM_MONTH_RANGES[term] || {start:1,end:4};
  const prefix = `${year}-`;
  return Object.keys(DB.attendance||{}).filter(d=>{
    if (!d.startsWith(prefix)) return false;
    const mo = +d.slice(5,7);
    return mo >= r.start && mo <= r.end;
  }).sort();
}

function getStaffTermDates(year, term) {
  const r = TERM_MONTH_RANGES[term] || {start:1,end:4};
  const prefix = `${year}-`;
  return Object.keys(DB.staffAttendance||{}).filter(d=>{
    if (!d.startsWith(prefix)) return false;
    const mo = +d.slice(5,7);
    return mo >= r.start && mo <= r.end;
  }).sort();
}

