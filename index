// Share marks for a specific student/class via WhatsApp
function shareMarksWhatsApp(sid, term) {
  const s = DB.students.find(x=>x.id===sid); if(!s) return;
  if (!s.con) { showAlert('No parent contact saved for this student.','⚠️ No Contact'); return; }
  const sch = DB.settings;
  const termName = ['','Term 1','Term 2','Term 3'][+term]||('Term '+term);
  const format = DB.reportSettings?.format || 'primary_uneb';
  const subjects = (DB.reportSettings?.classSubjects||{})[s.cls] || [];
  const rows = subjects.map(sub=>{
    const key = `${s.cls}||${sub}||${term}`;
    const m = (DB.marks[key]||{})[s.id]||{};
    const tot = Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
    const gd = typeof getGrade==='function' ? getGrade(tot, format) : {g:'—'};
    return tot>0 ? `  • ${sub}: ${tot}/100 (${gd.g})` : null;
  }).filter(Boolean);
  const avg = rows.length ? Math.round(subjects.map(sub=>{
    const key=`${s.cls}||${sub}||${term}`;const m=(DB.marks[key]||{})[s.id]||{};
    return Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
  }).filter(x=>x>0).reduce((a,b)=>a+b,0)/Math.max(1,rows.length)) : null;
  let msg = `📊 *MARKS REPORT — ${sch.name||'SCHOOL'}*\n`;
  msg += `═══════════════════════\n`;
  msg += `👤 *${s.fn} ${s.ln}* (${s.cls})\n`;
  msg += `📋 Adm: ${s.adm} | *${termName} ${sch.year||''}*\n\n`;
  if (rows.length) {
    msg += `📚 *SUBJECT MARKS*\n${rows.join('\n')}\n`;
    if (avg!==null) msg += `\n✨ *Average: ${avg}/100*\n`;
  } else {
    msg += `📚 Marks not yet entered for ${termName}.\n`;
  }
  msg += `\n_${sch.name||'School'} · SchoolMS Uganda_`;
  const phone = s.con.replace(/[^0-9]/g,'');
  const intPhone = phone.startsWith('0') ? '256'+phone.slice(1) : phone;
  window.open('https://wa.me/'+intPhone+'?text='+encodeURIComponent(msg),'_blank');
}

