function updateSMSCount(){
  const checked = document.querySelectorAll('[id^="sms-chk-"]:checked').length;
  const el = document.getElementById('sms-count');
  if(el) el.textContent = checked;
}

function sendWhatsAppReminders(){
  const t = DB.settings.term||2;
  const msg = (document.getElementById('sms-msg')||{}).value || '';
  const checked = [...document.querySelectorAll('[id^="sms-chk-"]:checked')].map(c=>c.value);
  if(!checked.length){toast('No recipients selected','warning');return;}
  const students = DB.students.filter(s=>checked.includes(s.id));
  // Open WhatsApp for each (first 5 to avoid popup blocker)
  let opened=0;
  students.slice(0,5).forEach(s=>{
    const phone = (s.con||'').replace(/\D/g,'');
    if(phone){
      const personalMsg = msg + `\n\nStudent: ${s.fn} ${s.ln} | Balance: UGX ${fmt(getBalance(s.id,t))}`;
      window.open(`https://wa.me/${phone.startsWith('0')?'256'+phone.slice(1):phone}?text=${encodeURIComponent(personalMsg)}`,'_blank');
      opened++;
    }
  });
  if(students.length>5) toast(`WhatsApp opened for first 5. Repeat for remaining ${students.length-5}.`,'info',5000);
  else if(opened===0) toast('No valid phone numbers found for selected students.','warning');
  else toast(`WhatsApp opened for ${opened} parent(s).`,'success');
}

function copyAllSMSNumbers(){
  const checked = [...document.querySelectorAll('[id^="sms-chk-"]:checked')].map(c=>c.value);
  const numbers = DB.students.filter(s=>checked.includes(s.id)).map(s=>s.con).filter(Boolean).join(', ');
  if(!numbers){toast('No phone numbers to copy','warning');return;}
  navigator.clipboard.writeText(numbers).then(()=>toast(`${checked.length} numbers copied to clipboard`,'success')).catch(()=>toast('Copy failed — check browser permissions','danger'));
}

