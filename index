// ── ATTENDANCE HEATMAP ON STUDENT PROFILES ────────────────────
function getStudentAttHeatmap(sid) {
  const allDates = Object.keys(DB.attendance).sort().slice(-42); // last 42 days
  if(!allDates.length) return '';
  const cells = allDates.map(d=>{
    const v = (DB.attendance[d]||{})[sid]||'';
    const cls = v==='P'?'p':v==='A'?'a':v==='L'?'l':'none';
    return `<div class="att-cell ${cls}" title="${d}: ${v||'no record'}"></div>`;
  }).join('');
  return `<div style="margin-top:8px"><div style="font-size:10.5px;color:var(--text3);margin-bottom:4px">Attendance (last 42 days) &nbsp; <span style="color:var(--success)">■</span> Present &nbsp;<span style="color:var(--danger)">■</span> Absent &nbsp;<span style="color:var(--warning)">■</span> Late</div><div class="att-heatmap">${cells}</div></div>`;
}

