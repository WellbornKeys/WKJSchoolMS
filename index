function saveStudent() {
  const fn=document.getElementById('s-fn').value.trim();
  const ln=document.getElementById('s-ln').value.trim();
  const adm=document.getElementById('s-adm').value.trim();
  if(!fn||!ln){showAlert('Please enter first and last name.');return;}
  if(!adm){showAlert('Please enter admission number.');return;}
  if(!window._editSid&&DB.students.some(s=>s.adm===adm)){showAlert('Admission number already exists.');return;}
  const d={fn,ln,adm,cls:document.getElementById('s-cls').value,gen:document.getElementById('s-gen').value,
    dob:document.getElementById('s-dob').value,par:document.getElementById('s-par').value,
    con:document.getElementById('s-con').value,
    brd:document.getElementById('s-brd').value,ps:document.getElementById('s-ps').value,
    health:(document.getElementById('s-health')||{}).value||'',
    joinTerm:+((document.getElementById('s-joinTerm')||{}).value||1)};
  // collect other fee assignments from checkboxes (per-term)
  const _newOtherIds = { t1: [], t2: [], t3: [] };
  [1,2,3].forEach(t => {
    (DB.otherFees||[]).forEach(f => {
      const cb = document.getElementById('s-otherfee-t'+t+'-'+f.id);
      if (cb && cb.checked) _newOtherIds['t'+t].push(f.id);
    });
  });
  d.otherFeeIds = _newOtherIds;
  if(window._editSid){
    const i=DB.students.findIndex(s=>s.id===window._editSid);
    DB.students[i]={...DB.students[i],...d};
    addAct('Updated student: '+fn+' '+ln);
  } else {
    d.id=genId('st');
    d.enrollYear = DB.settings.year || new Date().getFullYear(); // stamp enrolment year
    DB.students.push(d);
    addAct('Enrolled: '+fn+' '+ln+' ('+d.cls+')');

  }
  saveDB(); closeM('m-student'); renderStudents();
}

