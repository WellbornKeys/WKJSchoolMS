function renderStudentDashboard() {
  const q   = (document.getElementById('sd-search')?.value||'').toLowerCase();
  const cls = document.getElementById('sd-class')?.value||'';
  const term = +(document.getElementById('sd-term')?.value || DB.settings.term || 2);
  const sch = DB.settings;
  const students = DB.students.filter(s=>{
    const m = (s.fn+' '+s.ln+s.adm+(s.par||'')).toLowerCase().includes(q);
    return m && (!cls || s.cls===cls);
  });

