// ── 6. Export Fee Ledger to Excel ────────────────────────────
function xlsxExportFees() {
  const XLSX = XLSXLite;
  const termSel = document.getElementById('fee-filter-term');
  const termVal = termSel ? termSel.value : 'all';
  const terms = termVal === 'all' ? [1,2,3] : [+termVal];
  const termLabel = termVal === 'all' ? 'All Terms' : 'Term ' + termVal;

  const wb = XLSX.utils.book_new();

  terms.forEach(t => {
    const headers = ['Adm No.', 'Student Name', 'Class', 'B/F (UGX)', 'Recurring (UGX)', 'Other Fees (UGX)', 'Expected (UGX)', 'Paid (UGX)', 'Balance (UGX)', 'Status'];
    const rows = DB.students.map(s => {
      const bf   = getCarryForward(s.id, t);
      const rec  = getStudentRecurringFees(s.id, t);
      const opt  = getStudentOtherFees(s.id, t);
      const exp  = getTotalOwed(s.id, t);
      const paid = getTotalPaid(s.id, t);
      const bal  = Math.max(0, exp - paid);

      return [
        s.adm, s.fn + ' ' + s.ln, s.cls,
        bf, rec, opt, exp, paid, bal,
        getFeesStatus(s.id, t)
      ];
    });

    // Totals row
    const totRow = ['', 'TOTALS', '',
      rows.reduce((a,r)=>a+(+r[3]||0),0),
      rows.reduce((a,r)=>a+(+r[4]||0),0),
      rows.reduce((a,r)=>a+(+r[5]||0),0),
      rows.reduce((a,r)=>a+(+r[6]||0),0),
      rows.reduce((a,r)=>a+(+r[7]||0),0),
      rows.reduce((a,r)=>a+(+r[8]||0),0),
      ''
    ];

    const wsData = [headers, ...rows, totRow];
    const ws = XLSX.utils.aoa_to_sheet(wsData);
    ws['!cols'] = [12,22,8,14,16,14,15,12,14,10].map(w=>({wch:w}));
    XLSX.utils.book_append_sheet(wb, ws, 'Term ' + t);
  });

  // Summary sheet
  const summaryHeaders = ['Class', 'Students', 'Expected (UGX)', 'Collected (UGX)', 'Outstanding (UGX)', 'Collection %'];
  const termForSummary = termVal === 'all' ? DB.settings.term : +termVal;
  const summaryRows = DB.classes.map(c => {
    const sts = DB.students.filter(s => s.cls === c);
    const exp = sts.reduce((a, s) => a + getTotalOwed(s.id, termForSummary), 0);
    const col = sts.reduce((a, s) => a + getTotalPaid(s.id, termForSummary), 0);
    const out = Math.max(0, exp - col);
    const pct = exp > 0 ? Math.round(col / exp * 100) + '%' : '0%';
    return [c, sts.length, exp, col, out, pct];
  });
  const wsSummary = XLSX.utils.aoa_to_sheet([summaryHeaders, ...summaryRows]);
  wsSummary['!cols'] = [10,10,18,18,18,14].map(w=>({wch:w}));
  XLSX.utils.book_append_sheet(wb, wsSummary, 'Class Summary');

  xlsxSave(wb, `SchoolMS_FeeLedger_${termLabel.replace(' ','')}_${today()}.xlsx`);
  addAct('Fee ledger exported to Excel — ' + termLabel);
}

