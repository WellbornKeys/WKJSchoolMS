// loadDB — now async. Reads from IndexedDB first; falls back to localStorage for migration.
// Returns a Promise that resolves when DB is ready and UI is initialised.
function loadDB() {
  return _idbOpen().then(db => _idbGet(db).then(raw => {
    let parsed = null;
    if (raw) {
      try { parsed = JSON.parse(raw); } catch(e) { _warn('IDB parse error', e); }
    }
    if (!parsed) {
      // Migrate from localStorage (first run after upgrade)
      const lsRaw = localStorage.getItem(IDB_KEY) || sessionStorage.getItem(IDB_KEY);
      if (lsRaw) {
        try {
          parsed = JSON.parse(lsRaw);
          _log('SchoolMS: migrating data from localStorage → IndexedDB');
          // Persist to IDB and clear localStorage to free space
          _idbPut(db, lsRaw).then(() => {
            try { localStorage.removeItem(IDB_KEY); sessionStorage.removeItem(IDB_KEY); } catch(_) {}
          });
        } catch(e) { _warn('localStorage parse error', e); }
      }
    }
    _applyLoaded(parsed);
  })).catch(err => {
    _warn('IndexedDB unavailable, falling back to localStorage', err);
    try {
      const d = localStorage.getItem(IDB_KEY) || sessionStorage.getItem(IDB_KEY);
      if (d) _applyLoaded(JSON.parse(d));
    } catch(e) { _warn('DB load error', e); }
  });
}

