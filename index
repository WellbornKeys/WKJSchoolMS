// fromCheckbox=true means the browser already flipped cb.checked via onchange; don't flip it again.
function toggleClassDefault(cls, type, feeId, rowElOrFromCheckbox) {
  if (!DB.classFeeDefaults[cls]) DB.classFeeDefaults[cls] = {recurring:[], onetime:[], amounts:{}};
  if (!DB.classFeeDefaults[cls].amounts) DB.classFeeDefaults[cls].amounts = {};
  const arr = DB.classFeeDefaults[cls][type];
  const idx = arr.indexOf(feeId);
  const cbId = type==='recurring' ? 'cfd-rec-'+feeId : 'cfd-ot-'+feeId;
  const cb = document.getElementById(cbId);
  const fromCheckbox = rowElOrFromCheckbox === true;
  if (idx >= 0) {
    arr.splice(idx, 1);
    if (cb && !fromCheckbox) cb.checked = false;
  } else {
    arr.push(feeId);
    if (cb && !fromCheckbox) cb.checked = true;
  }
  saveDB();
  renderClassFeeDefaults();
}

function setClassFeeOverride(cls, key, val) {
  if (!DB.classFeeDefaults[cls]) DB.classFeeDefaults[cls] = {recurring:[], onetime:[], amounts:{}};
  if (!DB.classFeeDefaults[cls].amounts) DB.classFeeDefaults[cls].amounts = {};
  const v = val.trim();
  if (v === '' || isNaN(+v)) {
    delete DB.classFeeDefaults[cls].amounts[key];
  } else {
    DB.classFeeDefaults[cls].amounts[key] = +v;
  }
  saveDB();
}

function clearClassFeeOverride(cls, key) {
  if (DB.classFeeDefaults[cls] && DB.classFeeDefaults[cls].amounts) {
    delete DB.classFeeDefaults[cls].amounts[key];
    saveDB();
    renderClassFeeDefaults();
  }
}

function restoreClassAmountsToGlobal(cls) {
  if (!cls) return;
  showConfirm(`Clear all per-class amount overrides for ${cls}? Fees will use their global amounts.`, () => {
    if (DB.classFeeDefaults[cls]) {
      DB.classFeeDefaults[cls].amounts = {};
    }
    saveDB();
    renderClassFeeDefaults();
    showAlert(`Amount overrides cleared for ${cls}. Global fee amounts are now in effect.`, '✅ Restored');
  });
}

