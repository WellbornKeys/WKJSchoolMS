}

function saveDisciplineRecord() {
  initDisciplineDB();
  const sid = document.getElementById('disc-sid').value;
  const date = document.getElementById('disc-date').value;
  const desc = document.getElementById('disc-desc').value.trim();
  if (!sid) { showAlert('Select a student.'); return; }
  if (!date) { showAlert('Select a date.'); return; }
  if (!desc) { showAlert('Enter incident description.'); return; }
  const rec = {
    id: window._editDiscId || genId('disc'),
    sid, date,
    level: document.getElementById('disc-level').value,
    category: document.getElementById('disc-category').value,
    desc,
    action: document.getElementById('disc-action').value.trim(),
    by: document.getElementById('disc-by').value.trim(),
    ts: Date.now()
  };
  if (window._editDiscId) {
    const idx = DB.discipline.findIndex(d=>d.id===window._editDiscId);
    if (idx>=0) DB.discipline[idx] = rec;
  } else {
    DB.discipline.push(rec);
  }
  saveDB();
  closeM('m-discipline');
  renderDisciplinePage();
  addAct('Discipline record added for ' + ((DB.students.find(s=>s.id===sid)||{}).fn||'student'));
  toast('Discipline record saved', 'success');
}

function editDisciplineRecord(id) {
  initDisciplineDB();
  const d = DB.discipline.find(x=>x.id===id); if(!d) return;
  document.getElementById('m-disc-title').textContent = 'Edit Discipline Record';
  window._editDiscId = id;
  const sel = document.getElementById('disc-sid');
  sel.innerHTML = DB.students.map(s=>`<option value="${s.id}">${s.fn} ${s.ln} (${s.cls})</option>`).join('');
  sel.value = d.sid;
  document.getElementById('disc-date').value = d.date;
  document.getElementById('disc-level').value = d.level;
  document.getElementById('disc-category').value = d.category;
  document.getElementById('disc-desc').value = d.desc;
  document.getElementById('disc-action').value = d.action||'';
  document.getElementById('disc-by').value = d.by||'';
