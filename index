// ── 7. DEBT AGING REPORT ─────────────────────────────────────
function openDebtAgingReport(){
  const t = DB.settings.term||2;
  const today_ms = new Date().getTime();
  const debtors = DB.students.filter(s=>getBalance(s.id,t)>0).map(s=>{
    const bal = getBalance(s.id,t);
    const lastPay = (DB.payments||[]).filter(p=>p.studentId===s.id).sort((a,b)=>new Date(b.date)-new Date(a.date))[0];
    const daysSince = lastPay ? Math.floor((today_ms - new Date(lastPay.date).getTime())/86400000) : 999;
    let aging, ageClass;
    if(daysSince<=30){aging='Current';ageClass='aging-current';}
    else if(daysSince<=60){aging='31-60 days';ageClass='aging-30';}
    else if(daysSince<=90){aging='61-90 days';ageClass='aging-60';}
    else{aging='90+ days';ageClass='aging-90';}
    return {s, bal, daysSince, aging, ageClass};
  }).sort((a,b)=>b.daysSince-a.daysSince);

  const maxBal = Math.max(...debtors.map(d=>d.bal),1);
  const rows = debtors.map(d=>`
    <tr>
      <td>${d.s.fn} ${d.s.ln}</td>
      <td>${d.s.cls}</td>
      <td style="text-align:right;font-weight:600;color:var(--danger)">UGX ${fmt(d.bal)}</td>
      <td><div class="debtor-bar" style="width:${Math.round(d.bal/maxBal*100)}%"></div></td>
      <td><span class="aging-pill ${d.ageClass}">${d.aging}</span></td>
      <td style="font-size:11px;color:var(--text3)">${d.daysSince===999?'Never paid':`${d.daysSince}d ago`}</td>
    </tr>`).join('');

  const totals = {current:0,d30:0,d60:0,d90:0};
  debtors.forEach(d=>{
    if(d.daysSince<=30) totals.current+=d.bal;
    else if(d.daysSince<=60) totals.d30+=d.bal;
    else if(d.daysSince<=90) totals.d60+=d.bal;
    else totals.d90+=d.bal;
  });

  showAlert(`
    <div style="font-size:13.5px;font-weight:700;color:var(--primary);margin-bottom:12px"><i class="ti ti-chart-bar"></i> Fee Debt Aging Report — Term ${t}</div>
    <div class="g4" style="margin-bottom:14px;gap:8px">
      <div class="metric" style="padding:10px"><div class="m-label">Current (&le;30d)</div><div class="m-val" style="font-size:14px;color:var(--success)">UGX ${fmt(totals.current)}</div></div>
      <div class="metric" style="padding:10px"><div class="m-label">31-60 days</div><div class="m-val" style="font-size:14px;color:var(--warning)">UGX ${fmt(totals.d30)}</div></div>
      <div class="metric" style="padding:10px"><div class="m-label">61-90 days</div><div class="m-val" style="font-size:14px;color:var(--accent)">UGX ${fmt(totals.d60)}</div></div>
      <div class="metric" style="padding:10px"><div class="m-label">90+ days</div><div class="m-val" style="font-size:14px;color:var(--danger)">UGX ${fmt(totals.d90)}</div></div>
    </div>
    <div class="tbl-scroll"><table>
      <thead><tr><th>Student</th><th>Class</th><th>Balance</th><th style="width:80px">Scale</th><th>Aging</th><th>Last Pay</th></tr></thead>
      <tbody>${rows||'<tr><td colspan="6" class="empty">No outstanding balances.</td></tr>'}</tbody>
    </table></div>
    <div style="display:flex;gap:8px;margin-top:14px">
      <button class="btn btn-success" onclick="xlsxExportAgingReport()"><i class="ti ti-table-export"></i>Export to Excel</button>
      <button class="btn btn-primary" onclick="openSMSBlast()"><i class="ti ti-brand-whatsapp"></i>Send Reminders</button>
      <button class="btn" onclick="closeM('m-alert')">Close</button>
    </div>
  `, 'Debt Aging Report', 'modal-wide');
}

function xlsxExportAgingReport(){
  const XLSX = XLSXLite;
  const t = DB.settings.term||2;
  const today_ms = new Date().getTime();
  const debtors = DB.students.filter(s=>getBalance(s.id,t)>0).map(s=>{
    const bal = getBalance(s.id,t);
    const lastPay = (DB.payments||[]).filter(p=>p.studentId===s.id).sort((a,b)=>new Date(b.date)-new Date(a.date))[0];
    const daysSince = lastPay ? Math.floor((today_ms - new Date(lastPay.date).getTime())/86400000) : 999;
    return [s.fn+' '+s.ln, s.cls, s.par||'', s.con||'', bal, daysSince===999?'Never paid':daysSince+'d ago'];
  });
  const ws = XLSX.utils.aoa_to_sheet([['Student','Class','Parent','Contact','Balance (UGX)','Last Payment'],...debtors]);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'DebtAging');
  XLSX.writeFile(wb, `FeeAging_Term${t}.xlsx`);
  toast('Aging report exported','success');
}

