function renderPaymentsTab() {
  const q   = (document.getElementById('pay-tab-search')?.value||'').toLowerCase();
  const fc  = document.getElementById('pay-tab-class')?.value || '';
  const tm  = document.getElementById('pay-tab-term')?.value || String(DB.settings.term);
  const term = tm==='all' ? DB.settings.term : +tm;

  let totalBf = 0, totalBal = 0, countWithBal = 0;

  const rows = DB.students.filter(s=>{
    const m = (s.fn+' '+s.ln+s.adm).toLowerCase().includes(q);
    return m && (!fc || s.cls===fc);
  }).map(s=>{
    const bf   = getCarryForward(s.id, term);
    const recFee = getStudentRecurringTotal(s.id, term);
    const optFee = getStudentOtherTotal(s.id, term);
    const owed   = recFee + optFee + bf;
    const paid   = getTotalPaid(s.id, term);
    const bal    = Math.max(0, owed - paid);
    const st     = getFeesStatus(s.id, term);

    totalBf  += bf;
    totalBal += bal;
    if (bal > 0) countWithBal++;

    const stColor = st==='paid'?'var(--success)':st==='partial'?'var(--warning)':'var(--danger)';
    return `<tr>
      <td><strong>${s.fn} ${s.ln}</strong></td>
      <td><span class="badge badge-info">${s.cls}</span></td>
      <td style="text-align:right;color:var(--warning);font-weight:600">${bf > 0 ? fmt(bf) : '<span style="color:var(--text3)">—</span>'}</td>
      <td style="text-align:right;font-weight:700;font-size:13px;color:${stColor}">${fmt(bal)}</td>
      <td style="text-align:center"><span class="badge badge-${st}">${st.toUpperCase()}</span></td>
      <td style="text-align:center">
        ${bal > 0
          ? `<button class="btn btn-sm btn-accent" onclick="openPaymentFor('${s.id}')"><i class="ti ti-cash"></i>Pay</button>`
          : `<span style="font-size:11px;color:var(--success)">✅ Cleared</span>`}
      </td>
    </tr>`;
  });

  document.getElementById('pay-tab-rows').innerHTML = rows.join('') ||
    `<tr><td colspan="6"><div class="empty"><i class="ti ti-users"></i><p>No students found.</p></div></td></tr>`;

  // Summary footer
  document.getElementById('pay-tab-foot').innerHTML = `
    <tr style="background:var(--surface2);font-weight:700;border-top:2px solid var(--border)">
      <td colspan="2" style="padding:10px 12px;font-size:13px">TOTALS (${rows.length} student${rows.length!==1?'s':''})</td>
      <td style="text-align:right;padding:10px 12px;color:var(--warning)">${fmt(totalBf)}</td>
      <td style="text-align:right;padding:10px 12px;color:var(--danger);font-size:14px">${fmt(totalBal)}</td>
      <td colspan="2" style="padding:10px 12px;color:var(--text3);font-size:12px">${countWithBal} student${countWithBal!==1?'s':''} with outstanding balance</td>
    </tr>`;

  // Metric cards
  const ptBf  = document.getElementById('pt-bf');
  const ptBal = document.getElementById('pt-bal');
  const ptCnt = document.getElementById('pt-count');
  if (ptBf)  ptBf.textContent  = fmt(totalBf);
  if (ptBal) ptBal.textContent = fmt(totalBal);
  if (ptCnt) ptCnt.textContent = countWithBal;
}

