function renderFees() {
  _feeCache.clear();
  const q = (document.getElementById('fee-search').value||'').toLowerCase();
  const fc = document.getElementById('fee-filter-class').value;
  const tm = document.getElementById('fee-filter-term').value;
  const statusFilter = (document.getElementById('fee-filter-status')||{}).value || '';
  const term = tm==='all' ? DB.settings.term : +tm;
  let exp=0, col=0;
  const rows = DB.students.filter(s=>{
    const m = (s.fn+' '+s.ln+s.adm).toLowerCase().includes(q);
    if (!m || (fc && s.cls!==fc)) return false;
    if (statusFilter) {
      // When "All Terms" is selected, check status across all terms; otherwise check the selected term
      if (tm==='all') {
        const anyMatch = [1,2,3].some(t => getFeesStatus(s.id, t) === statusFilter);
        if (!anyMatch) return false;
      } else {
        if (getFeesStatus(s.id, term) !== statusFilter) return false;
      }
    }
    return true;
  }).map(s=>{
    const bf = getCarryForward(s.id, term);
    const recFee = getStudentRecurringTotal(s.id, term);
    const optFee = getStudentOtherTotal(s.id, term);
    const termFee = recFee + optFee;
    const owed = termFee+bf;
    const paid = getTotalPaid(s.id, term);
    const bal = Math.max(0, owed-paid);
    exp+=owed; col+=paid;
    const st = getFeesStatus(s.id, term);
    return `<tr>
      <td><strong>${s.adm}</strong></td>
      <td>${s.fn} ${s.ln}</td>
      <td><span class="badge badge-info">${s.cls}</span></td>
      <td style="color:${bf>0?'var(--warning)':'var(--text3)'}">${bf>0?fmt(bf):'0'}</td>
      <td style="font-size:11.5px;color:var(--text2)">${fmt(recFee)}</td>
      <td style="font-size:11.5px;color:#7c3aed">${optFee>0?fmt(optFee):'—'}</td>
      <td><strong>${fmt(owed)}</strong></td>
      <td style="color:var(--success);font-weight:600">${fmt(paid)}</td>
      <td style="color:${bal>0?'var(--danger)':'var(--success)'};font-weight:600">${fmt(bal)}</td>
      <td><span class="badge badge-${st}">${st}</span></td>
      <td style="white-space:nowrap"><button class="btn btn-xs btn-success" onclick="openPaymentFor('${s.id}')"><i class="ti ti-plus"></i>Pay</button> <button class="btn btn-xs" style="background:#25D366;color:#fff;border:none;padding:2px 7px;border-radius:4px;font-size:10px;cursor:pointer" title="Copy WhatsApp fee reminder" onclick="copyWhatsAppReminder('${s.id}')"><i class="ti ti-brand-whatsapp"></i></button></td>
    </tr>`;
  }).join('');
  document.getElementById('fee-rows').innerHTML = rows || `<tr><td colspan="11"><div class="empty"><i class="ti ti-cash"></i><p>No records.</p></div></td></tr>`;
  document.getElementById('f-exp').textContent = fmt(exp);
  document.getElementById('f-col').textContent = fmt(col);
  document.getElementById('f-out').textContent = fmt(Math.max(0, exp-col));
  if (typeof updateFeeKPIs === 'function') updateFeeKPIs();
}

