let _otherFeeModalId = null;

// ── Propagate autoRenew other fees: T1 enrolment → T2, T3 ────────────────
// Called when user opens Term 2 or Term 3 of an autoRenew fee — ensures students
// enrolled in the prior term are already enrolled here (they can be removed per-term).
function propagateAutoRenewOtherFee(fid, toTerm) {
  const fee = (DB.otherFees||[]).find(f=>f.id===fid);
  if (!fee || !fee.autoRenew) return;
  const fromTerm = toTerm > 1 ? toTerm - 1 : null;
  if (!fromTerm) return;
  let changed = false;
  const enrolled = getOtherFeeStudents(fid, fromTerm);
  enrolled.forEach(sid => {
    const already = getOtherFeeStudents(fid, toTerm).includes(sid);
    if (!already) {
      setOtherFeeStudent(fid, sid, toTerm, true);
      changed = true;
    }
  });
  if (changed) { clearFeeCache(); saveDB(); }
}

function openOtherFeeStudents(fid) {
  const fee = (DB.otherFees||[]).find(f => f.id === fid);
