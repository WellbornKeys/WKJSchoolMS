function deleteOtherFee(i) {
  showConfirm('Remove this other fee? Students currently assigned will no longer be charged.', ()=>{
    const fid = DB.otherFees[i].id;
    DB.otherFees.splice(i, 1);
    // Remove from student opt-in lists (both legacy flat and term-scoped)
    DB.students.forEach(s => {
      if (!s.otherFeeIds) return;
      if (Array.isArray(s.otherFeeIds)) {
        s.otherFeeIds = s.otherFeeIds.filter(id => id !== fid);
      } else {
        ['t1','t2','t3'].forEach(k => {
          if (s.otherFeeIds[k]) s.otherFeeIds[k] = s.otherFeeIds[k].filter(id => id !== fid);
        });
      }
    });
    // Remove from bursary exemptions
    (DB.bursaries||[]).forEach(b => {
      if (b.exemptFeeIds && b.exemptFeeIds.other) b.exemptFeeIds.other = b.exemptFeeIds.other.filter(id=>id!==fid);
    });
    saveDB(); renderOtherFees();
  });
}

