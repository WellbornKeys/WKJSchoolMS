// ── Bursary discount on recurring fees for a student in a given term ─────────
function getBursaryRecurringDiscount(sid, term) {
  const bursaries = getStudentBursaries(sid, term);
  if (!bursaries.length) return 0;
  if (!isEnrolledByTerm(sid, term)) return 0;
  const st = DB.students.find(s=>s.id===sid); if(!st) return 0;
  const isDayScholar = (st.brd !== 'boarding');
  const defaults = getClassDefaults(st.cls);
  const amounts = defaults.amounts || {};
  let discount = 0;
  // Determine full amount first (boarding fees excluded for day scholars)
  const recFees = (DB.recurringFees||[]).filter(f=>defaults.recurring.includes(f.id) && !(isDayScholar && isBoardingFee(f.name)));
  const total = recFees.reduce((s,f)=>{
    return s + getEffectiveRecAmount(f, st.cls, term);
  },0);
  // Apply best (highest) bursary — full bursary = 100% waiver; partial = only exempted fees waived
  // Full bursary: entire recurring total is discounted
  const fullBursary = bursaries.find(b=>b.type==='full');
  if (fullBursary) return total;
  // Partial bursary: only fees listed in exemptFeeIds.rec are waived
  let waived = 0;
  bursaries.filter(b=>b.type==='partial').forEach(b=>{
    const exemptRec = (b.exemptFeeIds||{}).rec || [];
    recFees.filter(f=>exemptRec.includes(f.id)).forEach(f=>{
      waived += getEffectiveRecAmount(f, st.cls, term);
    });
  });
  return Math.min(waived, total);
}

