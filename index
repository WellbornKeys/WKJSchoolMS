// ---- PUSH ----
async function syncPushNow() {
  if (!jbReady()) { showAlert('Configure JSONBin sync first (Settings → Online & Sync).','⚠️ Not Configured'); return; }
  if (!navigator.onLine) {
    if (!DB.syncMeta) DB.syncMeta = {};
    DB.syncMeta.pendingPush = true; saveDB();
    syncLog('⚠️ Offline — push queued.', 'warn');
    showAlert('You are offline. Push will happen automatically when you reconnect.','📴 Queued'); return;
  }
  syncLog('⬆ Pushing data to JSONBin…', 'info');
  const pkg = {
    _meta:          { deviceId: getDeviceId(), pushedAt: new Date().toISOString(), version: 1 },
    students:       DB.students,
    payments:       DB.payments,
    attendance:     DB.attendance,
    marks:          DB.marks,
    staff:          DB.staff,
    expenses:       DB.expenses || [],
    feeStructures:  DB.feeStructures,
    oneTimeFees:    DB.oneTimeFees  || [],
    recurringFees:  DB.recurringFees || [],
    classFeeDefaults: DB.classFeeDefaults || {},
    settings:       DB.settings,
    reportSettings: DB.reportSettings || {}
  };
  try {
    await jbRequest('/b/' + jbCfg().binId, 'PUT', pkg);
    if (!DB.syncMeta) DB.syncMeta = {};
    DB.syncMeta.lastSync = new Date().toLocaleString('en-UG');
    DB.syncMeta.pendingPush = false;
    saveDB(); renderSyncPage();
    const msg = `✅ Pushed: ${pkg.students.length} students · ${pkg.payments.length} payments · ${(pkg.staff||[]).length} staff`;
    syncLog(msg, 'ok');
    addAct(`Cloud push — ${pkg.students.length} students, ${pkg.payments.length} payments`);
    toast('Data pushed to cloud ✅', 'success');
  } catch(e) {
    syncLog('❌ Push failed: ' + e.message, 'err');
    showAlert('Push failed: ' + e.message, '❌ Error');
  }
}

// ---- PULL & MERGE ----
async function syncPullNow() {
  if (!jbReady()) { showAlert('Configure JSONBin sync first (Settings → Online & Sync).','⚠️ Not Configured'); return; }
  if (!navigator.onLine) { showAlert('You are offline. Connect to pull data.','⚠️ Offline'); return; }
  syncLog('⬇ Pulling from JSONBin…', 'info');
  try {
    const data = await jbRequest('/b/' + jbCfg().binId);
    // data is the raw record (X-Bin-Meta: false)
    const pkg = data.record !== undefined ? data.record : data;
    if (!pkg || !pkg._meta) { syncLog('⚠️ Bin is empty or not yet pushed from another device.', 'warn'); return; }
    syncLog(`↳ From device ${pkg._meta.deviceId} pushed at ${(pkg._meta.pushedAt||'').replace('T',' ').slice(0,19)}`, 'info');
    let added = { students:0, payments:0, staff:0, attendance:0, marks:0, expenses:0 };
    let skipped = 0;
    // Students
    (pkg.students||[]).forEach(s => {
      const existing = DB.students.find(x=>x.id===s.id);
      if (!existing) { DB.students.push(s); added.students++; }
      else {
        // Update if remote is newer (has more data)
        if ((s.updatedAt||'') > (existing.updatedAt||'')) { Object.assign(existing, s); added.students++; }
        else skipped++;
      }
    });
    // Payments
    (pkg.payments||[]).forEach(p => {
      if (!DB.payments.find(x=>x.id===p.id)) { DB.payments.push(p); added.payments++; } else skipped++;
    });
    // Staff
    (pkg.staff||[]).forEach(sf => {
      const existing = DB.staff.find(x=>x.id===sf.id);
      if (!existing) { DB.staff.push(sf); added.staff++; } else skipped++;
    });
    // Expenses
    (pkg.expenses||[]).forEach(ex => {
      if (!DB.expenses) DB.expenses = [];
      if (!DB.expenses.find(x=>x.id===ex.id)) { DB.expenses.push(ex); added.expenses++; } else skipped++;
    });
    // Attendance
    Object.entries(pkg.attendance||{}).forEach(([date,recs]) => {
      if (!DB.attendance[date]) DB.attendance[date] = {};
      Object.entries(recs||{}).forEach(([sid,v]) => {
        if (!DB.attendance[date][sid]) { DB.attendance[date][sid]=v; added.attendance++; }
      });
    });
    // Marks
    Object.entries(pkg.marks||{}).forEach(([key,stus]) => {
      if (!DB.marks[key]) DB.marks[key] = {};
      Object.entries(stus||{}).forEach(([sid,m]) => {
        if (!DB.marks[key][sid]) { DB.marks[key][sid]=m; added.marks++; }
      });
    });
    // Fee structures (merge by name)
    (pkg.oneTimeFees||[]).forEach(f => {
      if (!DB.oneTimeFees) DB.oneTimeFees = [];
      if (!DB.oneTimeFees.some(x=>(x.name||'').toLowerCase()===(f.name||'').toLowerCase())) DB.oneTimeFees.push(f);
    });
    (pkg.recurringFees||[]).forEach(f => {
      if (!DB.recurringFees) DB.recurringFees = [];
      if (!DB.recurringFees.some(x=>(x.name||'').toLowerCase()===(f.name||'').toLowerCase())) DB.recurringFees.push(f);
    });
    Object.entries(pkg.classFeeDefaults||{}).forEach(([cls,defs]) => {
      if (!DB.classFeeDefaults[cls]) DB.classFeeDefaults[cls] = defs;
    });
    if (!DB.syncMeta) DB.syncMeta = {};
    DB.syncMeta.lastSync = new Date().toLocaleString('en-UG');
    saveDB(); renderSyncPage();
    syncLog(`✅ Merged — +${added.students} students · +${added.payments} payments · +${added.staff} staff · +${added.expenses} expenses`, 'ok');
    syncLog(`✅ +${added.attendance} attendance · +${added.marks} marks · ${skipped} duplicates skipped`, 'ok');
    addAct(`Cloud pull — +${added.students} students, +${added.payments} payments`);
    showAlert(`Sync complete!\n\nAdded: ${added.students} students · ${added.payments} payments · ${added.staff} staff\nDuplicates skipped: ${skipped}`, '✅ Pull Complete');
  } catch(e) {
    syncLog('❌ Pull failed: ' + e.message, 'err');
    showAlert('Pull failed: ' + e.message + '\n\nMake sure another device has pushed data first.', '❌ Error');
  }
}

