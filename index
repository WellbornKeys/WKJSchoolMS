function renderStudents() {
  const q = (document.getElementById('st-search').value||'').toLowerCase();
  const fc = document.getElementById('st-filter-class').value;
  const jtf = (document.getElementById('st-filter-jointerm')||{}).value || '';
  const sf = (document.getElementById('st-filter-status')||{}).value || 'active';
  const rows = DB.students.filter(s=>{
    const m = (s.fn+' '+s.ln+s.adm+s.cls).toLowerCase().includes(q);
    if (!m || (fc && s.cls!==fc)) return false;
    if (jtf && +(s.joinTerm||1) !== +jtf) return false;
    const isDismissed = s.status === 'dismissed';
    if (sf === 'active' && isDismissed) return false;
    if (sf === 'dismissed' && !isDismissed) return false;
    return true;
  });
  const t = DB.settings.term;
  document.getElementById('st-rows').innerHTML = rows.length ? rows.map(s=>{
    const initials = (s.fn.charAt(0)+s.ln.charAt(0)).toUpperCase();
    const isDismissed = s.status === 'dismissed';
    const photoHtml = s.photo
      ? `<img src="${s.photo}" class="student-photo" onclick="openPhotoModal('${s.id}')" style="cursor:pointer;width:34px;height:34px;border-radius:50%;object-fit:cover" title="View/change photo">`
      : `<div class="student-initials" style="background:${getAvatarColor(s.fn)};cursor:pointer;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff" onclick="openPhotoModal('${s.id}')" title="Add photo">${initials}</div>`;
    const nameCell = isDismissed
      ? `${s.fn} ${s.ln}<div style="font-size:10px;color:var(--danger);font-weight:600">Dismissed${s.dismissedDate?' · '+s.dismissedDate:''}</div>`
      : `${s.fn} ${s.ln}`;
    const actionsCell = isDismissed
      ? `<button class="btn btn-sm btn-primary" onclick="viewStudentProfile('${s.id}')"><i class="ti ti-id-badge-2"></i>Profile</button>
         <button class="btn btn-sm btn-success" onclick="reinstateStudent('${s.id}')" title="Restore to active students"><i class="ti ti-user-check"></i>Reinstate</button>
         <button class="btn btn-sm btn-danger" onclick="confirmDeleteStudent('${s.id}')" title="Permanently delete student"><i class="ti ti-trash"></i>Delete</button>`
      : `<button class="btn btn-sm btn-primary" onclick="viewStudentProfile('${s.id}')"><i class="ti ti-id-badge-2"></i>Profile</button>
         <button class="btn btn-sm" onclick="editStudent('${s.id}')"><i class="ti ti-edit"></i>Edit</button>
         <button class="btn btn-sm btn-danger" onclick="dismissStudent('${s.id}')" title="Dismiss student"><i class="ti ti-user-off"></i>Dismiss</button>`;
    return `<tr>
    <td class="photo-cell" style="width:44px;text-align:center">${photoHtml}</td>
    <td><strong>${s.adm}</strong></td>
    <td>${nameCell}</td>
    <td><span class="badge badge-info">${s.cls}</span></td>
    <td>${s.gen}</td>
    <td>${s.par||'—'}</td>
    <td>${s.con||'—'}</td>
    <td><span class="chip">${s.brd==='boarding'?'🏠 Boarder':'🚶 Day'}</span></td>
    <td style="white-space:nowrap">${actionsCell}</td></tr>`;
  }).join('') : `<tr><td colspan="9"><div class="empty"><i class="ti ti-users"></i><p>No ${sf==='dismissed'?'dismissed':''} students found.</p></div></td></tr>`;
}

function dismissStudent(id) {
  const s = DB.students.find(x=>x.id===id); if(!s) return;
  window._dismissSid = id;
  const dEl = document.getElementById('ds-date');
  const rEl = document.getElementById('ds-reason');
  if (dEl) dEl.value = new Date().toISOString().slice(0,10);
  if (rEl) rEl.value = '';
  document.getElementById('m-dismiss-title').textContent = 'Dismiss ' + s.fn + ' ' + s.ln;
  openM('m-dismiss-student');
}

function saveDismissStudent() {
  const id = window._dismissSid; if (!id) return;
  const s = DB.students.find(x=>x.id===id); if (!s) return;
  s.status = 'dismissed';
  s.dismissedDate = (document.getElementById('ds-date')||{}).value || new Date().toISOString().slice(0,10);
  s.dismissReason = (document.getElementById('ds-reason')||{}).value || '';
  saveDB();
  closeM('m-dismiss-student');
  renderStudents();
  addAct('Dismissed student: '+s.fn+' '+s.ln);
  showUndoToast((s.fn+' '+s.ln)+' dismissed', ()=>{
    s.status = 'active';
    delete s.dismissedDate;
    delete s.dismissReason;
    saveDB(); renderStudents();
  });
}

function reinstateStudent(id) {
  const s = DB.students.find(x=>x.id===id); if(!s) return;
  showConfirm('Reinstate '+(s.fn+' '+s.ln)+' as an active student?', ()=>{
    s.status = 'active';
    delete s.dismissedDate;
    delete s.dismissReason;
    saveDB(); renderStudents();
    addAct('Reinstated student: '+s.fn+' '+s.ln);
  });
}

