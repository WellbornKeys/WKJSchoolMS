function initDisciplineDB() {
  if (!DB.discipline) DB.discipline = [];
}

function openAddDiscipline(sid) {
  initDisciplineDB();
  document.getElementById('m-disc-title').textContent = 'Record Discipline Incident';
  window._editDiscId = null;
  // Populate student dropdown
  const sel = document.getElementById('disc-sid');
  sel.innerHTML = DB.students.map(s=>`<option value="${s.id}">${s.fn} ${s.ln} (${s.cls})</option>`).join('');
