function renderSattYearlyReport() {
  const year = +document.getElementById('satt-yearly-year').value;
  const prefix = `${year}-`;
  const allDates = Object.keys(DB.staffAttendance||{}).filter(d=>d.startsWith(prefix)).sort();
  const el = document.getElementById('satt-yearly-content');
  if (!allDates.length || !DB.staff.length) { el.innerHTML='<div class="empty"><p>No attendance data for '+year+'.</p></div>'; return; }
  const monthNames=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const monthData = Array.from({length:12},(_,i)=>i+1).map(m=>{
    const ms=String(m).padStart(2,'0'); return {m,label:monthNames[m-1],dates:allDates.filter(d=>d.startsWith(`${year}-${ms}`)).sort()};
  }).filter(md=>md.dates.length>0);
  const html = `<div style="font-size:12px;color:var(--text2);margin-bottom:8px"><strong>Staff Yearly Summary ${year}</strong> &nbsp;|&nbsp; ${allDates.length} working day(s) recorded</div>
  <div style="overflow-x:auto"><table>
    <thead><tr><th>Name</th><th>Role</th>${monthData.map(md=>`<th>${md.label}<br><small style="font-size:9px">${md.dates.length}d</small></th>`).join('')}<th style="color:var(--success)">Total P</th><th style="color:var(--danger)">Total A</th><th>Overall %</th></tr></thead>
    <tbody>${DB.staff.map(s=>{
      let totalP=0,totalA=0;
      const mCells=monthData.map(md=>{
        let P=0,A=0,LT=0,LV=0;
        md.dates.forEach(d=>{const v=(DB.staffAttendance[d]||{})[s.id]||'P';if(v==='P')P++;else if(v==='A')A++;else if(v==='LT')LT++;else if(v==='LV')LV++;});
        totalP+=P+LT; totalA+=A+LV;
        const t=P+A+LT+LV; const pct=t>0?Math.round((P+LT)/t*100):null;
        const color=pct===null?'var(--text3)':pct>=90?'var(--success)':pct>=75?'var(--warning)':'var(--danger)';
        return `<td style="text-align:center;font-size:11px;color:${color};font-weight:600">${pct!==null?pct+'%':'—'}</td>`;
      }).join('');
      const totalAll=totalP+totalA; const oPct=totalAll>0?Math.round(totalP/totalAll*100):0;
      const oColor=oPct>=90?'var(--success)':oPct>=75?'var(--warning)':'var(--danger)';
      return `<tr><td><strong>${s.fn} ${s.ln}</strong></td><td style="font-size:11px">${s.role}</td>${mCells}
        <td style="color:var(--success);font-weight:700">${totalP}</td>
        <td style="color:var(--danger);font-weight:700">${totalA}</td>
        <td style="color:${oColor};font-weight:700;font-size:13px">${oPct}%</td></tr>`;
    }).join('')}</tbody>
  </table></div>
  <div style="margin-top:8px;font-size:11px;color:var(--text3)">P+Late counted as present. Leave counted as absent. ≥90% ✅ ≥75% ⚠️</div>`;
  el.innerHTML = html;
}

function renderSattReport() {
  const month = +document.getElementById('satt-report-month').value;
  const year = +document.getElementById('satt-report-year').value;
  const monthStr = String(month).padStart(2,'0');
  const prefix = `${year}-${monthStr}`;
  const dates = Object.keys(DB.staffAttendance||{}).filter(d=>d.startsWith(prefix)).sort();
  if (!dates.length || !DB.staff.length) {
    document.getElementById('satt-report-content').innerHTML='<div class="empty"><p>No attendance data for this month.</p></div>'; return;
  }
  const html = `<div style="overflow-x:auto"><table>
    <thead><tr><th>Staff Member</th><th>Role</th>${dates.map(d=>`<th style="font-size:10px">${d.slice(8)}</th>`).join('')}<th>P</th><th>A</th><th>Late</th><th>Leave</th></tr></thead>
    <tbody>${DB.staff.map(s=>{
      let P=0,A=0,LT=0,LV=0;
      const cells = dates.map(d=>{
        const v = (DB.staffAttendance[d]||{})[s.id]||'P';
        if(v==='P')P++; else if(v==='A')A++; else if(v==='LT')LT++; else if(v==='LV')LV++;
        const color = v==='P'?'var(--success)':v==='A'?'var(--danger)':v==='LT'?'var(--warning)':'var(--info)';
        const sym = v==='P'?'P':v==='A'?'A':v==='LT'?'L':'LV';
        return `<td style="text-align:center;font-size:11px;color:${color};font-weight:700">${sym}</td>`;
      }).join('');
      return `<tr><td><strong>${s.fn} ${s.ln}</strong></td><td style="font-size:11px">${s.role}</td>${cells}
        <td style="color:var(--success);font-weight:700">${P}</td>
        <td style="color:var(--danger);font-weight:700">${A}</td>
