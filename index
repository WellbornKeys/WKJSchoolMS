// ── FINANCIAL INSIGHTS on Fees page ──────────────────────────
function renderFinancialInsights() {
  const el = document.getElementById('financial-insights');
  if (!el) return;
  const t = DB.settings.term || 2;
  const feeExp = DB.students.reduce((a,s)=>a+getTotalOwed(s.id,t),0);
  const feePaid = DB.students.reduce((a,s)=>a+getTotalPaid(s.id,t),0);
  const colRate = feeExp>0?Math.round(feePaid/feeExp*100):0;
  const debtors = DB.students.filter(s=>getBalance(s.id,t)>0);
  const insights = [];
  if (colRate >= 90) insights.push({icon:'🌟', text:`Excellent! ${colRate}% fee collection rate this term.`, type:'success'});
  else if (colRate >= 70) insights.push({icon:'⚠️', text:`${colRate}% collection rate. UGX ${fmtK(Math.max(0,feeExp-feePaid))} still outstanding.`, type:'warning'});
  else insights.push({icon:'🚨', text:`Low collection rate (${colRate}%). ${debtors.length} students owe fees. Consider sending reminders.`, type:'danger'});
  if (debtors.length > 0) {
    const top = debtors.sort((a,b)=>getBalance(b.id,t)-getBalance(a.id,t))[0];
    insights.push({icon:'👤', text:`Highest debtor: ${top.fn} ${top.ln} (UGX ${fmt(getBalance(top.id,t))})`, type:'info'});
  }
  const recentPays = (DB.payments||[]).filter(p=>+p.term===t).sort((a,b)=>b.date.localeCompare(a.date)).slice(0,3);
  if (recentPays.length) insights.push({icon:'💳', text:`Last payment: UGX ${fmt(recentPays[0].amount)} on ${recentPays[0].date}`, type:'info'});
  el.innerHTML = insights.map(ins=>`<div class="alert-box ${ins.type}" style="margin-bottom:6px;font-size:12px">${ins.icon} ${ins.text}</div>`).join('');
}

