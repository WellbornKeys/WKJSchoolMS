// ============================================================
//  WHATSAPP REPORT SHARING
// ============================================================
function shareReportWhatsApp(sid, term) {
  const s = DB.students.find(x=>x.id===sid); if(!s) return;
  const sch = DB.settings;
  if (!s.con) { showAlert('No contact number saved for this student. Add parent contact first.', '⚠️ No Contact'); return; }

  const termName = ['','Term 1','Term 2','Term 3'][term]||('Term '+term);
  const format = DB.reportSettings?.format || 'primary_uneb';
  const subjects = (DB.reportSettings?.classSubjects||{})[s.cls] || [];
  const markRows = subjects.map(sub=>{
    const key = `${s.cls}||${sub}||${term}`;
    const m = (DB.marks[key]||{})[s.id]||{};
    const tot = Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
    const gd = getGrade(tot, format);
    return tot > 0 ? `  • ${sub}: ${tot}/100 (${gd.g})` : null;
  }).filter(Boolean);

  const avgMark = markRows.length ? Math.round(subjects.map(sub=>{
    const key=`${s.cls}||${sub}||${term}`;const m=(DB.marks[key]||{})[s.id]||{};
    return Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
  }).filter(x=>x>0).reduce((a,b)=>a+b,0)/Math.max(1,markRows.length)) : null;

  const t = term;
  const year = sch.year || new Date().getFullYear();
  const allDates = Object.keys(DB.attendance||{}).filter(d=>d.startsWith(year+'-'));
  let attP=0, attA=0, attL=0;
  allDates.forEach(d=>{const v=(DB.attendance[d]||{})[s.id]||'';if(v==='P')attP++;else if(v==='A')attA++;else if(v==='L')attL++;});
  const attTotal=attP+attA+attL;
  const attPct=attTotal>0?Math.round((attP+attL)/attTotal*100):null;
  const bal = getBalance(s.id, t);
  const feeStatus = getFeesStatus(s.id, t);

  let msg = `📚 *${sch.name||'SCHOOL REPORT'}*\n`;
  msg += `═══════════════════════\n`;
  msg += `👤 *Student:* ${s.fn} ${s.ln}\n`;
  msg += `🏫 *Class:* ${s.cls} | *${termName} ${year}*\n`;
  msg += `📋 *Adm No:* ${s.adm}\n\n`;

  if (markRows.length) {
    msg += `📊 *ACADEMIC RESULTS*\n`;
    msg += markRows.join('\n') + '\n';
    if (avgMark !== null) msg += `\n✨ *Average: ${avgMark}/100*\n`;
  } else {
    msg += `📊 *Marks:* Not yet entered for ${termName}\n`;
  }

  msg += `\n📅 *ATTENDANCE*\n`;
  msg += `  Present: ${attP} | Absent: ${attA} | Late: ${attL}\n`;
  if (attPct !== null) msg += `  Rate: *${attPct}%*\n`;

  msg += `\n💰 *FEES — ${termName}*\n`;
  msg += `  Status: *${feeStatus.toUpperCase()}*\n`;
  if (bal > 0) msg += `  Outstanding: *UGX ${bal.toLocaleString()}*\n`;
  else msg += `  ✅ Fully paid\n`;

  msg += `\n─────────────────────\n`;
  msg += `_Sent via SchoolMS Uganda_\n`;
  msg += `_${sch.phone||''} | ${sch.addr||''}_`;

  const phone = s.con.replace(/[^0-9]/g,'');
  const waUrl = `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
  window.open(waUrl, '_blank');
}

// ============================================================
