        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px">
          <div style="text-align:center;background:var(--success-light);border-radius:var(--radius);padding:5px">
            <div style="font-size:16px;font-weight:700;color:var(--success)">${attP}</div>
            <div style="font-size:9px;color:var(--success)">Present</div>
          </div>
