function addRecurringFee() {
  if (!DB.recurringFees) DB.recurringFees = [];
  const newFee = {id: genId('rf'), name:'', t1:0, t2:0, t3:0};
  DB.recurringFees.push(newFee);
  // Auto-enable this new fee in all existing class defaults (default ON behaviour)
  DB.classes.forEach(cls => {
    if (!DB.classFeeDefaults[cls]) DB.classFeeDefaults[cls] = {recurring:[], onetime:[], amounts:{}};
    if (!DB.classFeeDefaults[cls].recurring.includes(newFee.id)) {
      DB.classFeeDefaults[cls].recurring.push(newFee.id);
    }
  });
  saveDB(); renderRecurringFees(); renderClassFeeDefaults();
}

function deleteRecurringFee(i) {
  const fee = DB.recurringFees[i];
  showConfirm('Remove this recurring fee? It will also be removed from all class defaults.', ()=>{
    const fid = fee.id;
    DB.recurringFees.splice(i, 1);
    // Remove from all class defaults
    Object.values(DB.classFeeDefaults).forEach(d => {
      d.recurring = (d.recurring||[]).filter(id=>id!==fid);
    });
    // Remove student exemptions for this fee
    DB.students.forEach(s => {
      if (s.exemptions && s.exemptions['rec_'+fid]) delete s.exemptions['rec_'+fid];
    });
    saveDB(); renderFeeStructures();
    renderStudentFeeExemptionsIfOpen();
  });
}

