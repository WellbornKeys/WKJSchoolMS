            ${markRows.slice(0,5).map(r=>{
              const w = Math.round(r.tot);
              const col = r.tot>=75?'var(--success)':r.tot>=50?'var(--warning)':'var(--danger)';
              return `<div style="display:flex;align-items:center;gap:5px;font-size:10.5px">
                <span style="min-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text2)">${r.sub}</span>
