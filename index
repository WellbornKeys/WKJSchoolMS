// ── Enrollment-term gate ──────────────────────────────────────────────────────
// A student who joined mid-year (e.g. Term 2 or Term 3) should not be charged
// fees for terms before they enrolled. This only restricts terms within the
// academic year they actually joined (s.enrollYear) — once the school moves to
// a new academic year (rollover), the student is a continuing student and is
// billed normally from Term 1 of that year.
function isEnrolledByTerm(sid, term) {
  const st = DB.students.find(s=>s.id===sid); if(!st) return true;
  const joinTerm = +st.joinTerm || 1;
  if (joinTerm <= 1) return true;
  const joinYear = st.enrollYear;
  const curYear = DB.settings.year;
  if (joinYear === undefined || joinYear === null) return true; // no record of join year — don't restrict
  if (curYear !== joinYear) return true; // different (later) academic year — fully enrolled
  return +term >= joinTerm;
}

// Returns true if a fee name is a boarding fee (day scholars are never charged these)
