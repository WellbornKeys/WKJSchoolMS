function updateFeeKPIs() {
  _feeCache.clear();
  const t = DB.settings.term || 2;
  const exp = DB.students.reduce((a,s)=>a+getTotalOwed(s.id,t),0);
  const col = DB.students.reduce((a,s)=>a+getTotalPaid(s.id,t),0);
  const out = Math.max(0, exp-col);
  const pct = exp>0 ? Math.round(col/exp*100) : 0;
  const fExp = document.getElementById('d-fee-expected'); if(fExp) fExp.textContent = fmt(exp);
  const fCol = document.getElementById('d-fee-collected'); if(fCol) fCol.textContent = fmt(col);
  const fOut = document.getElementById('d-fee-outstanding'); if(fOut) fOut.textContent = fmt(out);
  const fPct = document.getElementById('d-fee-pct'); if(fPct) fPct.textContent = pct+'% collected';
  const fPctBig = document.getElementById('d-fee-pct-big'); if(fPctBig) fPctBig.textContent = pct+'%';
  const fProg = document.getElementById('d-fee-prog-bar'); if(fProg) fProg.style.width = pct+'%';
  const termLbl = document.getElementById('kpi-term-label'); if(termLbl) termLbl.textContent = t;
  // Sparkline
  const sparkEl = document.getElementById('d-fee-sparkline');
  if (sparkEl) {
    const byDay = {};
    DB.payments.filter(p=>+p.term===t).forEach(p=>{ byDay[p.date]=(byDay[p.date]||0)+p.amount; });
    const days = Object.entries(byDay).sort((a,b)=>a[0].localeCompare(b[0])).slice(-7);
    const maxV = Math.max(...days.map(d=>d[1])) || 1;
    sparkEl.innerHTML = days.map(([d,v],i)=>`<div style="width:6px;border-radius:2px 2px 0 0;background:rgba(255,255,255,${0.3+0.7*(i===days.length-1?1:v/maxV)});height:${Math.max(4,Math.round(v/maxV*20))}px" title="${d}: UGX ${fmt(v)}"></div>`).join('');
  }
}

