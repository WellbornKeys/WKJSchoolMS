let _subjectMgrClass = null;
let _subjectMgrList = [];

function openSubjectManager() {
  const cls = document.getElementById('rs-class-sel').value;
  if (!cls) { showAlert('Select a class first.'); return; }
  _subjectMgrClass = cls;
  _subjectMgrList = [...getClassSubjects(cls)];
  document.getElementById('m-subj-class-name').textContent = cls;
  document.getElementById('m-subj-new').value = '';
  renderSubjectMgrList();
  openM('m-subjects');
}

function renderSubjectMgrList() {
  const tbody = document.getElementById('m-subj-list');
  if (!_subjectMgrList.length) {
    tbody.innerHTML = '<tr><td colspan="3"><div class="empty"><i class="ti ti-books"></i><p>No subjects. Add one above.</p></div></td></tr>';
    return;
  }
  tbody.innerHTML = _subjectMgrList.map((s,i)=>`<tr class="subj-manage-row">
    <td style="color:var(--text3);font-weight:600;width:32px">${i+1}</td>
    <td><strong>${s}</strong></td>
