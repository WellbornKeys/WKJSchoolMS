}

function deleteDisciplineRecord(id) {
  showConfirm('Delete this discipline record?', ()=>{
    DB.discipline = DB.discipline.filter(d=>d.id!==id);
    saveDB(); renderDisciplinePage();
  });
}

function renderDisciplinePage() {
  initDisciplineDB();
  // Populate class filter
  const cfSel = document.getElementById('disc-filter-cls');
  if (cfSel && cfSel.options.length <= 1) {
    DB.classes.forEach(c=>{ const o=document.createElement('option'); o.value=c; o.textContent=c; cfSel.appendChild(o); });
  }
  const q = (document.getElementById('disc-search')?.value||'').toLowerCase();
  const filterCls = document.getElementById('disc-filter-cls')?.value||'';
  const filterLvl = document.getElementById('disc-filter-lvl')?.value||'';
  const lvlColors = {minor:'var(--warning)',moderate:'#e8820c',serious:'var(--danger)'};
  const lvlLabels = {minor:'⚠️ Minor',moderate:'🟠 Moderate',serious:'🔴 Serious'};

  const rows = DB.discipline.filter(d=>{
    const s = DB.students.find(x=>x.id===d.sid)||{fn:'',ln:'',cls:''};
    const match = (s.fn+' '+s.ln+s.cls+d.category+d.desc).toLowerCase().includes(q);
    return match && (!filterCls||s.cls===filterCls) && (!filterLvl||d.level===filterLvl);
  }).sort((a,b)=>b.ts-a.ts);

  // Summary row
  const sumEl = document.getElementById('disc-summary-row');
  if (sumEl) {
    const total = DB.discipline.length;
    const minor = DB.discipline.filter(d=>d.level==='minor').length;
    const moderate = DB.discipline.filter(d=>d.level==='moderate').length;
    const serious = DB.discipline.filter(d=>d.level==='serious').length;
    sumEl.innerHTML = [
      {label:'Total Incidents',val:total,color:'var(--primary)',icon:'ti-gavel'},
      {label:'Minor',val:minor,color:'var(--warning)',icon:'ti-alert-triangle'},
      {label:'Moderate',val:moderate,color:'#e8820c',icon:'ti-alert-circle'},
      {label:'Serious',val:serious,color:'var(--danger)',icon:'ti-forbid-2'},
    ].map(c=>`<div class="card" style="padding:12px;text-align:center;border-top:3px solid ${c.color}">
      <div style="font-size:22px;font-weight:700;color:${c.color}">${c.val}</div>
      <div style="font-size:10.5px;color:var(--text3);text-transform:uppercase;letter-spacing:.4px;margin-top:3px"><i class="ti ${c.icon}"></i> ${c.label}</div>
    </div>`).join('');
  }

  const tbody = document.getElementById('disc-rows');
  if (!tbody) return;
  tbody.innerHTML = rows.length ? rows.map(d=>{
    const s = DB.students.find(x=>x.id===d.sid)||{fn:'—',ln:'',cls:'—'};
    return `<tr>
      <td>${d.date}</td>
      <td><strong>${s.fn} ${s.ln}</strong></td>
      <td><span class="badge badge-info">${s.cls}</span></td>
      <td><span style="font-weight:600;color:${lvlColors[d.level]||'var(--text)'}">${lvlLabels[d.level]||d.level}</span></td>
      <td>${d.category}</td>
      <td style="max-width:220px;word-break:break-word">${d.desc}</td>
      <td style="font-size:11.5px;color:var(--text2)">${d.action||'—'}</td>
      <td style="font-size:11.5px;color:var(--text3)">${d.by||'—'}</td>
      <td>
        <button class="btn btn-xs btn-primary" onclick="editDisciplineRecord('${d.id}')" title="Edit this record"><i class="ti ti-pencil"></i> Edit</button>
        <button class="btn btn-xs" onclick="shareDiscWhatsApp('${d.id}')" title="Share via WhatsApp"><i class="ti ti-brand-whatsapp"></i> Share</button>
        <button class="btn btn-xs btn-danger" onclick="deleteDisciplineRecord('${d.id}')" title="Delete this record"><i class="ti ti-trash"></i> Del</button>
      </td>
    </tr>`;
  }).join('') : '<tr><td colspan="9"><div class="empty"><i class="ti ti-gavel"></i><p>No discipline records found.</p></div></td></tr>';
}

function exportDisciplineXLS() {
  initDisciplineDB();
  if (!DB.discipline.length) { toast('No records to export', 'warning'); return; }
  const rows = DB.discipline.map(d=>{
    const s = DB.students.find(x=>x.id===d.sid)||{fn:'—',ln:'',cls:'—'};
    return {
      Date: d.date,
      Student: s.fn+' '+s.ln,
      Class: s.cls,
      Severity: d.level,
      Category: d.category,
      Description: d.desc,
      'Action Taken': d.action||'',
      'Recorded By': d.by||''
    };
  });
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.json_to_sheet(rows);
  XLSX.utils.book_append_sheet(wb, ws, 'Discipline Records');
  XLSX.writeFile(wb, 'Discipline_Records.xlsx');
  toast('Discipline records exported', 'success');
}

function shareDiscWhatsApp(discId) {
  initDisciplineDB();
  const d = DB.discipline.find(x=>x.id===discId); if(!d) return;
  const s = DB.students.find(x=>x.id===d.sid); if(!s) return;
  if (!s.con) { showAlert('No parent contact saved for this student.','⚠️ No Contact'); return; }
  const sch = DB.settings;
  const lvlLabels = {minor:'Minor ⚠️',moderate:'Moderate 🟠',serious:'Serious 🔴'};
  let msg = `📋 *DISCIPLINE NOTICE — ${sch.name||'SCHOOL'}*\n`;
  msg += `═════════════════════════\n`;
  msg += `👤 *Student:* ${s.fn} ${s.ln} (${s.cls})\n`;
  msg += `📅 *Date:* ${d.date}\n`;
  msg += `⚠️ *Severity:* ${lvlLabels[d.level]||d.level}\n`;
  msg += `📁 *Category:* ${d.category}\n\n`;
  msg += `📝 *Incident:*\n${d.desc}\n\n`;
  if (d.action) msg += `✅ *Action Taken:* ${d.action}\n\n`;
  msg += `Please contact the school for further discussion.\n`;
  msg += `📞 ${sch.phone||''}\n`;
  msg += `_— ${sch.name||'School Management'}_`;
  const phone = s.con.replace(/[^0-9]/g,'');
  const intPhone = phone.startsWith('0') ? '256'+phone.slice(1) : phone;
  window.open('https://wa.me/'+intPhone+'?text='+encodeURIComponent(msg),'_blank');
