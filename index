// Get recurring fees applicable to a student.
// If a per-student term override is active for this term, it replaces class defaults entirely.
// Day scholars are never charged any fee whose name contains "board".
function getStudentRecurringFees(sid, term) {
  const ck = 'rec_'+sid+'_'+term; if (_feeCache.has(ck)) return _feeCache.get(ck);
  if (!isEnrolledByTerm(sid, term)) return _feeCache.set(ck, 0);
  const st = DB.students.find(s=>s.id===sid); if(!st) return 0;
  const isDayScholar = (st.brd !== 'boarding');

  // Per-student term override
  const termOverride = ((DB.studentTermOverrides||{})[sid]||{})[term];
  if (termOverride && termOverride.enabled) {
    const overAmounts = termOverride.amounts || {};
    return _feeCache.set(ck, (DB.recurringFees||[]).filter(f=>(termOverride.recurring||[]).includes(f.id) && !(isDayScholar && isBoardingFee(f.name))).reduce((sum,f)=>{
      const key = 'rec_'+f.id;
      const amt = overAmounts[key] !== undefined ? overAmounts[key] : (+f['t'+term]||0);
      return sum + amt;
    }, 0));
  }

  // Class defaults
  const defaults = getClassDefaults(st.cls);
  const amounts = defaults.amounts || {};
  const exemptions = st.exemptions || {};
  return _feeCache.set(ck, (DB.recurringFees||[]).filter(f=>defaults.recurring.includes(f.id) && !(isDayScholar && isBoardingFee(f.name)) && !exemptions['rec_'+f.id]).reduce((sum,f)=>{
    return sum + getEffectiveRecAmount(f, st.cls, term);
