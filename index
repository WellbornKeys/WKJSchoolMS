    const all = s.otherFeeIds;
    s.otherFeeIds = {
      t1: all.slice(), t2: all.slice(), t3: all.slice()
    };
  }
  if (!s.otherFeeIds || typeof s.otherFeeIds !== 'object') {
    s.otherFeeIds = { t1: [], t2: [], t3: [] };
  }
  const key = 't' + term;
  if (!s.otherFeeIds[key]) s.otherFeeIds[key] = [];
  if (enrolled) {
    if (!s.otherFeeIds[key].includes(fid)) s.otherFeeIds[key].push(fid);
  } else {
    s.otherFeeIds[key] = s.otherFeeIds[key].filter(id => id !== fid);
  }
}

