function onBursaryTypeChange() {
  const type = document.getElementById('bursary-type')?.value;
  const panel = document.getElementById('bursary-partial-panel');
  if (panel) panel.style.display = type==='partial' ? '' : 'none';
}

function renderBursaryStudentPicker() {
  const q = (document.getElementById('bursary-student-search')?.value||'').toLowerCase();
  const fc = document.getElementById('bursary-student-class-filter')?.value;
  const sel = window._bursarySelectedStudents || new Set();
  const students = DB.students.filter(s=>{
    const m = (s.fn+' '+s.ln+s.adm).toLowerCase().includes(q);
    return m && (!fc||s.cls===fc);
  });
  const el = document.getElementById('bursary-student-picker');
  if (!el) return;
  el.innerHTML = students.map(s=>`
    <label style="display:flex;align-items:center;gap:8px;padding:5px 6px;border-radius:4px;cursor:pointer;font-size:12.5px;font-weight:400;${sel.has(s.id)?'background:#ede9fe;':''}">
      <input type="checkbox" ${sel.has(s.id)?'checked':''} onchange="toggleBursaryStudent('${s.id}',this.checked)">
      <span><strong>${s.fn} ${s.ln}</strong> &nbsp;<span class="badge badge-info" style="font-size:10px">${s.cls}</span> &nbsp;<span style="color:var(--text3)">${s.adm}</span></span>
    </label>`).join('') || '<div style="font-size:12px;color:var(--text3);padding:6px">No students match filter.</div>';
  document.getElementById('bursary-selected-count').textContent = sel.size;
}

function toggleBursaryStudent(sid, checked) {
  if (!window._bursarySelectedStudents) window._bursarySelectedStudents = new Set();
  if (checked) window._bursarySelectedStudents.add(sid);
  else window._bursarySelectedStudents.delete(sid);
  document.getElementById('bursary-selected-count').textContent = window._bursarySelectedStudents.size;
  // Re-render to update highlight
  renderBursaryStudentPicker();
}

function saveBursary() {
  const name = document.getElementById('bursary-name').value.trim();
  if (!name) { showAlert('Please enter a bursary name.'); return; }
  const type = document.getElementById('bursary-type').value;
  const termScope = [1,2,3].filter(t=>document.getElementById('bursary-t'+t)?.checked);
  if (!termScope.length) { showAlert('Select at least one term for this bursary.'); return; }
  const note = document.getElementById('bursary-note').value.trim();
  const students = [...(window._bursarySelectedStudents||new Set())];

  // Collect exemptions (only for partial)
  let exemptFeeIds = {rec:[], other:[]};
  if (type==='partial') {
    exemptFeeIds.rec   = (DB.recurringFees||[]).filter(f=>document.getElementById('bex-rec-'+f.id)?.checked).map(f=>f.id);
    exemptFeeIds.other = (DB.otherFees||[]).filter(f=>document.getElementById('bex-other-'+f.id)?.checked).map(f=>f.id);
  }

  const bId = document.getElementById('bursary-edit-id').value;
  if (!DB.bursaries) DB.bursaries = [];

  if (bId) {
    const idx = DB.bursaries.findIndex(b=>b.id===bId);
    if (idx>=0) DB.bursaries[idx] = {...DB.bursaries[idx], name, type, termScope, note, students, exemptFeeIds};
  } else {
    DB.bursaries.push({id:genId('bur'), name, type, termScope, note, students, exemptFeeIds});
  }

  addAct(`Bursary "${name}" saved — ${students.length} student(s)`);
  saveDB();
  closeM('m-bursary-editor');
  renderBursaryTab();
  renderBursaryRecipients();
  populateBursaryFilters();
  renderFees();
  showAlert(`Bursary "${name}" saved with ${students.length} student(s).`, '✅ Saved');
}

function deleteBursary() {
  const bId = document.getElementById('bursary-edit-id').value;
  if (!bId) return;
  const b = (DB.bursaries||[]).find(x=>x.id===bId);
  if (!b) return;
  showConfirm(`Delete bursary "${b.name}"? This will remove all fee concessions for its students.`, ()=>{
    DB.bursaries = (DB.bursaries||[]).filter(x=>x.id!==bId);
    saveDB();
    closeM('m-bursary-editor');
    renderBursaryTab();
    renderBursaryRecipients();
    populateBursaryFilters();
    renderFees();
    showAlert(`Bursary "${b.name}" deleted.`, '🗑️ Deleted');
  });
}

function xlsxExportBursaryList() {
  const XLSX = XLSXLite;
  const bId = document.getElementById('bursary-view-filter')?.value;
  const term = +(document.getElementById('bursary-term-view')?.value || DB.settings.term || 2);
  let students = DB.students.slice();
  let label = 'All_Bursaries';
  if (bId) {
    const b = (DB.bursaries||[]).find(x=>x.id===bId);
    if (b) { students = students.filter(s=>(b.students||[]).includes(s.id)); label = b.name.replace(/\s+/g,'_'); }
  } else {
    const ids = new Set(); (DB.bursaries||[]).forEach(b=>{ if((b.termScope||[]).includes(term)) (b.students||[]).forEach(id=>ids.add(id)); });
    students = students.filter(s=>ids.has(s.id));
  }
  const rows = [['Adm No','Name','Class','Bursary(ies)','Discount (UGX)','Other Fees (UGX)','Net Term Fee (UGX)']];
  students.forEach(s=>{
    const bNames = (DB.bursaries||[]).filter(b=>(b.students||[]).includes(s.id)&&(b.termScope||[]).includes(term)).map(b=>b.name).join('; ');
    const disc = getBursaryRecurringDiscount(s.id,term);
    const opt  = getStudentOtherTotal(s.id,term);
    const net  = getTermFeeTotal(s.id,term);
    rows.push([s.adm, s.fn+' '+s.ln, s.cls, bNames, disc, opt, net]);
  });
  if (typeof XLSX !== 'undefined') {
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(rows), 'Bursaries');
    XLSX.writeFile(wb, `Bursary_List_${label}_T${term}.xlsx`);
  } else {
    showAlert('Excel export not available.','⚠️');
  }
}


