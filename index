function updatePayInfo() {
  const sid = document.getElementById('py-st').value;
  const term = +document.getElementById('py-term').value;
  const s = DB.students.find(x=>x.id===sid); if(!s) return;
  const bf = getCarryForward(sid, term);
  const recFee = getStudentRecurringTotal(sid, term);
  const optFee = getStudentOtherTotal(sid, term);
  const termFee = recFee + optFee;
  const owed = termFee+bf;
  const paid = getTotalPaid(sid, term);
  const bal = Math.max(0, owed-paid);

  // Breakdown
  const classDefs = getClassDefaults(s.cls);
  const exemptions = s.exemptions||{};
  const _classAmts = classDefs.amounts || {};
  const recBreak = (DB.recurringFees||[]).filter(f=>classDefs.recurring.includes(f.id)&&!exemptions['rec_'+f.id]).map(f=>{
    return `${f.name}: UGX ${fmt(getEffectiveRecAmount(f, s.cls, term))}`;
  }).join(' | ');

  document.getElementById('py-info').innerHTML =
    `<strong>${s.fn} ${s.ln}</strong> | <strong>${s.cls}</strong><br>
    ${!isEnrolledByTerm(sid, term) ? `<span style="font-size:11.5px;color:var(--warning);font-weight:600">⚠ Student enrolled from Term ${s.joinTerm||1} — no fees are charged for Term ${term}.</span><br>` : ''}
    ${recBreak && isEnrolledByTerm(sid, term) ? `<span style="font-size:11.5px;color:var(--text3)">${recBreak}</span><br>` : ''}
    Recurring: <strong>UGX ${fmt(recFee)}</strong>${optFee>0?' + Other: <strong style="color:#7c3aed">UGX '+fmt(optFee)+'</strong>':''}${bf>0?' | B/F: <strong style="color:var(--warning)">UGX '+fmt(bf)+'</strong>':''}<br>
    Total Owed: <strong>UGX ${fmt(owed)}</strong> | Paid: <strong style="color:var(--success)">UGX ${fmt(paid)}</strong> | Remaining: <strong style="color:${bal>0?'var(--danger)':'var(--success)'}">UGX ${fmt(bal)}</strong>`;

  // Dynamically populate component dropdown from student's class fees
  const sel = document.getElementById('py-component');
  const noteEl = document.getElementById('py-onetime-note');
  const prevVal = sel.value;
  // Clear all dynamic options
  [...sel.options].forEach(o=>{ if(o.dataset.dynamic) o.remove(); });
  // Add recurring fees separator + options (reuse classDefs from above)
  const applicableRec = isEnrolledByTerm(sid, term) ? (DB.recurringFees||[]).filter(f=>classDefs.recurring.includes(f.id)) : [];
  if (applicableRec.length) {
    const sep = document.createElement('option'); sep.disabled=true; sep.textContent='── Recurring Fees ──'; sep.dataset.dynamic='1'; sel.insertBefore(sep, sel.options[0]);
    applicableRec.forEach((f,i)=>{
      const amt = getEffectiveRecAmount(f, s.cls, term);
      const opt = document.createElement('option'); opt.value='rec_'+f.id;
      opt.textContent = f.name+' (UGX '+fmt(amt)+'/term)';
      opt.dataset.dynamic='1';
      sel.insertBefore(opt, sel.options[i+1]);
    });
  }
  // Other fees (assigned to this student for the selected term)
  const otherRaw = s.otherFeeIds;
  let otherInTerm;
  if (Array.isArray(otherRaw)) { otherInTerm = otherRaw; }
  else if (otherRaw && typeof otherRaw === 'object') { otherInTerm = otherRaw['t'+term] || []; }
  else { otherInTerm = []; }
  const applicableOther = isEnrolledByTerm(sid, term) ? (DB.otherFees||[]).filter(f=>otherInTerm.includes(f.id)) : [];
  if (applicableOther.length) {
    const sep2 = document.createElement('option'); sep2.disabled=true; sep2.value=''; sep2.textContent='── Other Fees ──'; sep2.dataset.dynamic='1'; sel.appendChild(sep2);
    applicableOther.forEach(f=>{
      const amt = getEffectiveOtherFeeAmount(f, s.cls, term);
      const opt = document.createElement('option'); opt.value='othf_'+f.id;
      opt.textContent = f.name+' (UGX '+fmt(amt)+' · Other)';
