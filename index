<script>
// ── INLINE XLSX WRITER (no CDN needed for template downloads) ──
// ============================================================
// INLINE XLSX WRITER - No external dependencies
// Implements: XLSX.utils.book_new, aoa_to_sheet, sheet_add_aoa,
//             book_append_sheet, write, writeFile
// Used for TEMPLATE DOWNLOADS. Upload parsing still uses CDN.
// ============================================================
(function(g){
'use strict';

// ── CRC32 table ──
var crcTable = (function(){
  var t=new Uint32Array(256);
  for(var i=0;i<256;i++){var c=i;for(var j=0;j<8;j++)c=((c&1)?0xEDB88320^(c>>>1):(c>>>1));t[i]=c;}
  return t;
})();
function crc32(buf){
  var c=0xFFFFFFFF;
  for(var i=0;i<buf.length;i++)c=(crcTable[(c^buf[i])&0xFF]^(c>>>8));
  return (c^0xFFFFFFFF)>>>0;
}

// ── UTF-8 encode ──
function utf8(s){
  var b=[],c;
  for(var i=0;i<s.length;i++){
    c=s.charCodeAt(i);
    if(c<0x80)b.push(c);
    else if(c<0x800){b.push(0xC0|(c>>6),0x80|(c&0x3F));}
    else{b.push(0xE0|(c>>12),0x80|((c>>6)&0x3F),0x80|(c&0x3F));}
  }
  return new Uint8Array(b);
}

// ── Little-endian helpers ──
function u16(n){return[n&0xFF,(n>>8)&0xFF];}
function u32(n){return[n&0xFF,(n>>8)&0xFF,(n>>16)&0xFF,(n>>24)&0xFF];}

// ── Concat Uint8Arrays ──
function cat(){
  var total=0,i,offset=0;
  for(i=0;i<arguments.length;i++)total+=arguments[i].length;
  var out=new Uint8Array(total);
  for(i=0;i<arguments.length;i++){out.set(arguments[i],offset);offset+=arguments[i].length;}
  return out;
}
function fromArr(a){return new Uint8Array(a);}

// ── Simple DEFLATE (store only, no compression — valid per spec) ──
function deflateStore(data){
  // DEFLATE stored blocks: BFINAL=1, BTYPE=00 (stored)
  var out=[];
  var i=0;
  while(i<data.length){
    var blockLen=Math.min(65535,data.length-i);
    var last=(i+blockLen>=data.length)?1:0;
    out.push(last|0x00); // BFINAL | BTYPE=00
    out.push(blockLen&0xFF,(blockLen>>8)&0xFF);
    out.push((~blockLen)&0xFF,((~blockLen)>>8)&0xFF);
    for(var j=0;j<blockLen;j++)out.push(data[i+j]);
    i+=blockLen;
  }
  return new Uint8Array(out);
}

function zlibWrap(data){
  // zlib header + deflate store + adler32
  var deflated=deflateStore(data);
  var adler=adler32(data);
  return cat(fromArr([0x78,0x9C]),deflated,fromArr([(adler>>24)&0xFF,(adler>>16)&0xFF,(adler>>8)&0xFF,adler&0xFF]));
}

function adler32(data){
  var s1=1,s2=0;
  for(var i=0;i<data.length;i++){s1=(s1+data[i])%65521;s2=(s2+s1)%65521;}
  return (s2<<16)|s1;
}

// ── Build ZIP file ──
function buildZip(files){
  // files: [{name, data(Uint8Array)}]
  var localHeaders=[];
  var offset=0;
  var centralDirs=[];

  for(var i=0;i<files.length;i++){
    var f=files[i];
    var nameBytes=utf8(f.name);
    var data=f.data;
    var crc=crc32(data);
    var compData=deflateStore(data); // stored
    // Use stored (method=0) — simpler and always valid
    var localHeader=cat(
      fromArr([0x50,0x4B,0x03,0x04]), // sig
      fromArr([0x14,0x00]),            // version needed
      fromArr([0x00,0x00]),            // flags
      fromArr([0x00,0x00]),            // method: stored=0
      fromArr([0x00,0x00,0x00,0x00]),  // mod time/date
      fromArr(u32(crc)),               // crc32
      fromArr(u32(data.length)),       // compressed size (same as uncompressed for stored)
      fromArr(u32(data.length)),       // uncompressed size
      fromArr(u16(nameBytes.length)),  // name length
      fromArr([0x00,0x00]),            // extra length
      nameBytes,
      data  // stored = raw data
    );
    localHeaders.push(localHeader);
    centralDirs.push({name:nameBytes,crc:crc,size:data.length,offset:offset});
    offset+=localHeader.length;
  }

  var centralStart=offset;
  var centralParts=[];
  for(var i=0;i<centralDirs.length;i++){
    var cd=centralDirs[i];
    var c=cat(
      fromArr([0x50,0x4B,0x01,0x02]), // sig
      fromArr([0x14,0x00]),            // version made by
      fromArr([0x14,0x00]),            // version needed
      fromArr([0x00,0x00]),            // flags
      fromArr([0x00,0x00]),            // method stored
      fromArr([0x00,0x00,0x00,0x00]),  // mod time/date
      fromArr(u32(cd.crc)),
      fromArr(u32(cd.size)),
      fromArr(u32(cd.size)),
      fromArr(u16(cd.name.length)),
      fromArr([0x00,0x00]),            // extra
      fromArr([0x00,0x00]),            // comment
      fromArr([0x00,0x00]),            // disk start
      fromArr([0x00,0x00]),            // int attribs
      fromArr([0x00,0x00,0x00,0x00]),  // ext attribs
      fromArr(u32(cd.offset)),
      cd.name
    );
    centralParts.push(c);
  }
  var centralData=cat.apply(null,centralParts);
  var eocd=cat(
    fromArr([0x50,0x4B,0x05,0x06]),
    fromArr([0x00,0x00,0x00,0x00]),
    fromArr(u16(files.length)),
    fromArr(u16(files.length)),
    fromArr(u32(centralData.length)),
    fromArr(u32(centralStart)),
    fromArr([0x00,0x00])
  );
  return cat.apply(null,localHeaders.concat([centralData,eocd]));
}

// ── XML helpers ──
function esc(s){
  return String(s==null?'':s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&apos;');
}

// ── col index to letter (0=A, 25=Z, 26=AA …) ──
function colLetter(n){
  var s='';
  n++;
  while(n>0){n--;s=String.fromCharCode(65+(n%26))+s;n=Math.floor(n/26);}
  return s;
}
function cellAddr(r,c){return colLetter(c)+(r+1);}

// ── aoa_to_sheet ──
function aoa_to_sheet(aoa){
  if(!aoa||!aoa.length)return {_data:[],_cols:[]};
  return {_data:aoa.map(function(row){return row?row.map(function(v){return v==null?'':v;}):[];}),_cols:[]};
}

// ── sheet_add_aoa ──
function sheet_add_aoa(ws,aoa,opts){
  var origin=(opts&&opts.origin)||'A1';
  var m=origin.match(/^([A-Z]+)(\d+)$/);
  if(!m)return;
  var startC=0,tmp=m[1];
  for(var i=0;i<tmp.length;i++)startC=startC*26+(tmp.charCodeAt(i)-64);
  startC--;
  var startR=parseInt(m[2])-1;
  for(var r=0;r<aoa.length;r++){
    var row=aoa[r]||[];
    while(ws._data.length<=startR+r)ws._data.push([]);
    for(var c=0;c<row.length;c++){
      var target=ws._data[startR+r];
      while(target.length<=startC+c)target.push('');
      target[startC+c]=row[c]==null?'':row[c];
    }
  }
}

// ── Build sheet XML ──
function sheetXML(ws,sharedStrings,ssMap){
  var rows=ws._data;
  var rowsXML='';
  for(var r=0;r<rows.length;r++){
    var row=rows[r];
    if(!row||!row.length)continue;
    var cells='';
    for(var c=0;c<row.length;c++){
      var v=row[c];
      if(v===''||v==null)continue;
      var addr=cellAddr(r,c);
      if(typeof v==='number'){
        cells+='<c r="'+addr+'" t="n"><v>'+v+'</v></c>';
      } else {
        var sv=String(v);
        var idx;
        if(ssMap[sv]===undefined){idx=sharedStrings.length;sharedStrings.push(sv);ssMap[sv]=idx;}
        else{idx=ssMap[sv];}
        cells+='<c r="'+addr+'" t="s"><v>'+idx+'</v></c>';
      }
    }
    if(cells)rowsXML+='<row r="'+(r+1)+'">'+cells+'</row>';
  }
  var colsXML='';
  if(ws._cols&&ws._cols.length){
    colsXML='<cols>';
    for(var i=0;i<ws._cols.length;i++){
      if(ws._cols[i]&&ws._cols[i].wch)colsXML+='<col min="'+(i+1)+'" max="'+(i+1)+'" width="'+ws._cols[i].wch+'" customWidth="1"/>';
    }
    colsXML+='</cols>';
  }
  return '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">'
    +colsXML
    +'<sheetData>'+rowsXML+'</sheetData>'
    +'</worksheet>';
}

// ── write workbook to Uint8Array ──
function write(wb){
  var sharedStrings=[];
  var ssMap={};
  var sheetXMLs=wb._sheets.map(function(s){return sheetXML(s.ws,sharedStrings,ssMap);});

  var ssXML='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<sst xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" count="'+sharedStrings.length+'" uniqueCount="'+sharedStrings.length+'">'
    +sharedStrings.map(function(s){return '<si><t xml:space="preserve">'+esc(s)+'</t></si>';}).join('')
    +'</sst>';

  var wbXML='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships">'
    +'<sheets>'
    +wb._sheets.map(function(s,i){return '<sheet name="'+esc(s.name)+'" sheetId="'+(i+1)+'" r:id="rId'+(i+2)+'"/>';}).join('')
    +'</sheets></workbook>';

  var wbRels='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">'
    +'<Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/sharedStrings" Target="sharedStrings.xml"/>'
    +wb._sheets.map(function(s,i){return '<Relationship Id="rId'+(i+2)+'" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet'+(i+1)+'.xml"/>';}).join('')
    +'</Relationships>';

  var pkgRels='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">'
    +'<Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/>'
    +'</Relationships>';

  var contentTypes='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types">'
    +'<Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/>'
    +'<Default Extension="xml" ContentType="application/xml"/>'
    +'<Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/>'
    +'<Override PartName="/xl/sharedStrings.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sharedStrings+xml"/>'
    +wb._sheets.map(function(s,i){return '<Override PartName="/xl/worksheets/sheet'+(i+1)+'.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>';}).join('')
    +'</Types>';

  var stylesXML='<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
    +'<styleSheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">'
    +'<fonts><font><sz val="11"/><name val="Calibri"/></font></fonts>'
    +'<fills><fill><patternFill patternType="none"/></fill><fill><patternFill patternType="gray125"/></fill></fills>'
    +'<borders><border><left/><right/><top/><bottom/><diagonal/></border></borders>'
    +'<cellStyleXfs count="1"><xf numFmtId="0" fontId="0" fillId="0" borderId="0"/></cellStyleXfs>'
    +'<cellXfs><xf numFmtId="0" fontId="0" fillId="0" borderId="0" xfId="0"/></cellXfs>'
    +'</styleSheet>';

  var files=[
    {name:'[Content_Types].xml',data:utf8(contentTypes)},
    {name:'_rels/.rels',data:utf8(pkgRels)},
    {name:'xl/workbook.xml',data:utf8(wbXML)},
    {name:'xl/_rels/workbook.xml.rels',data:utf8(wbRels)},
    {name:'xl/sharedStrings.xml',data:utf8(ssXML)},
    {name:'xl/styles.xml',data:utf8(stylesXML)},
  ];
  wb._sheets.forEach(function(s,i){
    files.push({name:'xl/worksheets/sheet'+(i+1)+'.xml',data:utf8(sheetXMLs[i])});
  });

  return buildZip(files);
}

// ── Public API (matches SheetJS subset) ──
var XLSXLite = {
  utils: {
    book_new: function(){return {_sheets:[]};},
    aoa_to_sheet: aoa_to_sheet,
    sheet_add_aoa: sheet_add_aoa,
    book_append_sheet: function(wb,ws,name){ws._cols=ws._cols||[];wb._sheets.push({ws:ws,name:name||'Sheet'+(wb._sheets.length+1)});},
  },
  write: function(wb){return write(wb);},
  writeFile: function(wb,name){
    var data=write(wb);
    var blob=new Blob([data],{type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'});
    var a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download=name;
    a.style.display='none';
    document.body.appendChild(a);
    a.click();
    setTimeout(function(){URL.revokeObjectURL(a.href);a.remove();},1200);
  }
};

// Expose as global
g.XLSXLite = XLSXLite;

})(typeof window!=='undefined'?window:this);

</script>
<script>
// ── INLINE XLSX READER — no CDN, no internet needed ──────────
// Replaces SheetJS CDN for parsing uploaded .xlsx files.
// Uses browser-native DecompressionStream (Chrome 80+, FF 113+, Safari 16.4+).
(function(g){
'use strict';

async function inflateRaw(data) {
  const ds = new DecompressionStream('deflate-raw');
  const w = ds.writable.getWriter();
  const r = ds.readable.getReader();
  w.write(data instanceof Uint8Array ? data : new Uint8Array(data));
  w.close();
  const chunks = [];
  for (;;) { const {done,value} = await r.read(); if(done) break; chunks.push(value); }
  let len = 0; for (const c of chunks) len += c.length;
  const out = new Uint8Array(len); let off = 0;
  for (const c of chunks) { out.set(c, off); off += c.length; }
  return out;
}

async function parseZip(ab) {
  const buf = ab instanceof ArrayBuffer ? ab : ab.buffer;
  const v = new DataView(buf), u8 = new Uint8Array(buf), td = new TextDecoder();
  let eocd = -1;
  for (let i = buf.byteLength - 22; i >= 0; i--)
    if (v.getUint32(i,true) === 0x06054b50) { eocd = i; break; }
  if (eocd < 0) throw new Error('Not a valid XLSX file (ZIP not found)');
  const cdN = v.getUint16(eocd+8,true), cdOff = v.getUint32(eocd+16,true);
  const files = {};
  let p = cdOff;
  for (let i = 0; i < cdN; i++) {
    if (v.getUint32(p,true) !== 0x02014b50) break;
    const meth = v.getUint16(p+10,true), cSz = v.getUint32(p+20,true);
    const nLen = v.getUint16(p+28,true), xLen = v.getUint16(p+30,true), cLen = v.getUint16(p+32,true);
    const lhOff = v.getUint32(p+42,true);
    const name = td.decode(u8.subarray(p+46, p+46+nLen));
    p += 46 + nLen + xLen + cLen;
    const lhNLen = v.getUint16(lhOff+26,true), lhXLen = v.getUint16(lhOff+28,true);
    const dStart = lhOff + 30 + lhNLen + lhXLen;
    const comp = u8.subarray(dStart, dStart + cSz);
    files[name] = meth === 8 ? await inflateRaw(comp) : comp.slice();
  }
  return files;
}

function xmlQ(xml, sel) {
  return Array.from(new DOMParser().parseFromString(xml,'text/xml').querySelectorAll(sel));
}
function td2(u8) { return new TextDecoder().decode(u8); }

function parseSharedStrings(xml) {
  return xmlQ(xml,'si').map(si => { let s=''; si.querySelectorAll('t').forEach(t=>s+=t.textContent); return s; });
}

function parseWorkbook(xml) {
  return xmlQ(xml,'sheet').map(s => ({
    name: s.getAttribute('name'),
    sheetId: s.getAttribute('sheetId'),
    rId: s.getAttribute('r:id') ||
         s.getAttributeNS('http://schemas.openxmlformats.org/officeDocument/2006/relationships','id')
  }));
}

function parseRels(xml) {
  const m = {};
  xmlQ(xml,'Relationship').forEach(r => { m[r.getAttribute('Id')] = r.getAttribute('Target'); });
  return m;
}

function colNum(col) { let n=0; for(let i=0;i<col.length;i++) n=n*26+(col.charCodeAt(i)-64); return n; }

function parseSheet(xml, ss) {
  const cells = {};
  xmlQ(xml,'c').forEach(c => {
    const ref = c.getAttribute('r'); if(!ref) return;
    const t = c.getAttribute('t')||'n', vEl = c.querySelector('v');
    if (!vEl && t!=='inlineStr') return;
    const raw = vEl ? vEl.textContent : '';
    let val;
    if      (t==='s')         val = ss[parseInt(raw)] ?? '';
    else if (t==='b')         val = raw==='1';
    else if (t==='inlineStr') val = (c.querySelector('is t')||{}).textContent || '';
    else if (t==='str')       val = raw;
    else { const n=parseFloat(raw); val = isNaN(n) ? raw : n; }
    cells[ref] = val;
  });
  return cells;
}

function cellsToAOA(cells, defval) {
  const def = defval !== undefined ? defval : '';
  const keys = Object.keys(cells);
  if (!keys.length) return [];
  let maxR=0, maxC=0;
  const pts = [];
  for (const ref of keys) {
    const m = ref.match(/^([A-Z]+)(\d+)$/); if(!m) continue;
    const r=parseInt(m[2]), c=colNum(m[1]);
    if(r>maxR) maxR=r; if(c>maxC) maxC=c;
    pts.push({r,c,v:cells[ref]});
  }
  const aoa = Array.from({length:maxR},()=>new Array(maxC).fill(def));
  for (const {r,c,v} of pts) aoa[r-1][c-1]=v;
  return aoa;
}

async function readAsync(data) {
  const ab = data instanceof Uint8Array ? data.buffer : data;
  const files = await parseZip(ab);
  const sheetDefs = parseWorkbook(td2(files['xl/workbook.xml']));
  const rels = files['xl/_rels/workbook.xml.rels'] ? parseRels(td2(files['xl/_rels/workbook.xml.rels'])) : {};
  const ss = files['xl/sharedStrings.xml'] ? parseSharedStrings(td2(files['xl/sharedStrings.xml'])) : [];
  const wb = { SheetNames:[], Sheets:{} };
  for (const sd of sheetDefs) {
    const tgt = (rels[sd.rId]||'worksheets/sheet'+sd.sheetId+'.xml').replace(/^\.\//,'');
    const wsData = files['xl/'+tgt]; if(!wsData) continue;
    wb.Sheets[sd.name] = { _cells: parseSheet(td2(wsData), ss) };
    wb.SheetNames.push(sd.name);
  }
  return wb;
}

function sheetToJson(ws, opts) {
  opts = opts||{};
  const aoa = cellsToAOA(ws._cells||{}, opts.defval);
  if (opts.header===1) return aoa;
  if (!aoa.length) return [];
  const hdrs = aoa[0].map(h=>String(h==null?'':h));
  return aoa.slice(1).map(row => {
    const obj={};
    hdrs.forEach((h,i)=>{ obj[h]=row[i]!==undefined?row[i]:(opts.defval!==undefined?opts.defval:''); });
    return obj;
  });
}

g.XLSXReader = { readAsync, utils: { sheet_to_json: sheetToJson } };
g._xlsxParseReady = true;
g._xlsxParseLoadFailed = false;

})(window);
// ── CDN no longer needed — XLSXReader is fully inline above ──
</script>
