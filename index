function addSubjectToClass() {
  const val = document.getElementById('m-subj-new').value.trim();
  if (!val) return;
  if (_subjectMgrList.map(s=>s.toLowerCase()).includes(val.toLowerCase())) {
    showAlert('That subject is already in the list.'); return;
  }
  _subjectMgrList.push(val);
  document.getElementById('m-subj-new').value = '';
  renderSubjectMgrList();
}

function removeSubject(i) {
  _subjectMgrList.splice(i, 1);
  renderSubjectMgrList();
}

function moveSubject(i, dir) {
  const j = i+dir;
  if (j<0||j>=_subjectMgrList.length) return;
  [_subjectMgrList[i],_subjectMgrList[j]]=[_subjectMgrList[j],_subjectMgrList[i]];
  renderSubjectMgrList();
}

function saveSubjectsAndClose() {
  if (!_subjectMgrClass) return;
  if (!DB.reportSettings.classSubjects) DB.reportSettings.classSubjects = {};
  DB.reportSettings.classSubjects[_subjectMgrClass] = [..._subjectMgrList];
  saveDB();
  closeM('m-subjects');
  renderClassSubjects(); // refresh the checkboxes panel too
  updateMarkSubjectSelect();
  showAlert('Subjects saved for '+_subjectMgrClass+'.','✅ Saved');
}

// ============================================================
//  AUTO COMMENT GENERATOR
// ============================================================
function generateAutoComment(avgMark, grade, posRank, totalStudents, presRate) {
  const firstName = ''; // will be interpolated when called
  let teacherComment = '';
  let headComment = '';

  // Teacher comment based on average mark
  if (avgMark >= 80) {
    const phrases = [
      'Outstanding performance this term! Keep up the excellent work.',
      'Exceptional academic achievement. A model student in every way.',
      'Brilliant results — your hard work has clearly paid off. Well done!',
    ];
    teacherComment = phrases[Math.floor(Math.random()*phrases.length)];
  } else if (avgMark >= 70) {
    teacherComment = 'Very good performance this term. With a little more effort, excellence is within reach.';
  } else if (avgMark >= 60) {
    teacherComment = 'Good performance this term. Focus on revision and seek help where needed to improve further.';
  } else if (avgMark >= 50) {
    teacherComment = 'Fair performance. More consistent study habits and active class participation are encouraged.';
  } else if (avgMark >= 40) {
    teacherComment = 'Below expected performance. Needs to put in more effort and attend extra tuition where possible.';
  } else {
    teacherComment = 'Very poor performance. Urgent attention is needed. Please see the class teacher for guidance.';
  }
  // Headteacher comment considers position
  if (posRank && totalStudents) {
    const pctRank = posRank/totalStudents;
    if (pctRank <= 0.1) headComment = 'Ranked in the top 10% of the class. A commendable performance. Promote to the next class.';
    else if (pctRank <= 0.3) headComment = 'Good academic standing. Continue working hard for even better results.';
    else if (pctRank <= 0.6) headComment = 'Average performance. More effort is needed to improve class position.';
    else headComment = 'Needs significant improvement. Parents are encouraged to provide support at home.';
  } else {
    if (avgMark >= 60) headComment = 'Satisfactory performance. Encouraged to maintain this standard.';
    else headComment = 'Performance must improve. Parents are requested to support learning at home.';
  }
  // Attendance note
  if (presRate !== null && presRate < 75) {
    teacherComment += ' Attendance has been poor — regular school attendance is essential for academic success.';
  }
  return { teacherComment, headComment };
}

