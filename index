function renderOtherFeeStudentModal(fid, term) {
  const fee = (DB.otherFees||[]).find(f => f.id === fid);
  if (!fee) return;

  // Highlight active term tab
  [1,2,3].forEach(t => {
    const btn = document.getElementById('otherfee-term-btn-'+t);
    if (btn) {
      btn.style.background = t === term ? 'var(--primary)' : 'var(--surface2)';
      btn.style.color = t === term ? '#fff' : 'var(--text2)';
    }
  });

  const termAmt = fee['t'+term] || 0;
  document.getElementById('otherfee-term-amount').textContent =
    `Term ${term} amount: UGX ${termAmt.toLocaleString()}`;

  const enrolled = getOtherFeeStudents(fid, term);

  // Build class filter options
  const classFilter = document.getElementById('otherfee-class-filter');
  const prevCls = classFilter ? classFilter.value : '';
  if (classFilter) {
    classFilter.innerHTML = '<option value="">All Classes</option>' +
      DB.classes.map(c => `<option value="${c}" ${c===prevCls?'selected':''}>${c}</option>`).join('');
  }
  const filterCls = classFilter ? classFilter.value : '';

  let students = DB.students.slice().sort((a,b)=>(a.cls+a.fn).localeCompare(b.cls+b.fn));
  if (filterCls) students = students.filter(s => s.cls === filterCls);

  const searchEl = document.getElementById('otherfee-search');
  const q = searchEl ? searchEl.value.trim().toLowerCase() : '';
  if (q) students = students.filter(s =>
    (s.fn+' '+s.ln).toLowerCase().includes(q) || (s.adm||'').toLowerCase().includes(q)
  );

  const enrolledCount = students.filter(s => enrolled.includes(s.id)).length;
  const totalEnrolled = getOtherFeeStudents(fid, term).length;

  const body = document.getElementById('otherfee-student-list');
  if (!body) return;

  if (!students.length) {
    body.innerHTML = `<tr><td colspan="4" style="text-align:center;color:var(--text3);font-style:italic;padding:18px">No students match filters.</td></tr>`;
  } else {
    body.innerHTML = students.map(s => {
      const chk = enrolled.includes(s.id);
      return `<tr>
        <td style="width:36px;padding:8px 12px">
          <input type="checkbox" id="optfee-chk-${s.id}" data-sid="${s.id}"
            ${chk ? 'checked' : ''}
            style="width:15px;height:15px;accent-color:#7c3aed;cursor:pointer"
            onchange="toggleOtherFeeStudent('${fid}', '${s.id}', ${term}, this.checked)">
        </td>
        <td style="padding:8px 12px">
          <div style="font-weight:500">${s.fn} ${s.ln}</div>
          <div style="font-size:11px;color:var(--text3)">${s.adm||''}</div>
        </td>
        <td style="padding:8px 12px;color:var(--text3);font-size:12px">${s.cls}</td>
        <td style="padding:8px 12px">
          ${chk ? `<span class="badge badge-paid"><i class="ti ti-check" style="font-size:10px"></i> Enrolled</span>` : `<span style="font-size:11px;color:var(--text3)">—</span>`}
        </td>
      </tr>`;
    }).join('');
  }

  // Update summary
  const summaryEl = document.getElementById('otherfee-summary');
  if (summaryEl) summaryEl.textContent = `${totalEnrolled} student(s) enrolled for Term ${term}${filterCls ? ' · filtered: '+enrolledCount+'/'+students.length : ''}`;

  // Store current term in modal for bulk actions
  document.getElementById('m-otherfee-students').dataset.term = term;
  document.getElementById('m-otherfee-students').dataset.fid = fid;
}

function toggleOtherFeeStudent(fid, sid, term, enrolled) {
  clearFeeCache();
  setOtherFeeStudent(fid, sid, term, enrolled);
  saveDBDebounced();
  // Refresh counts in summary only (no full re-render to preserve scroll)
  const totalEnrolled = getOtherFeeStudents(fid, term).length;
  const summaryEl = document.getElementById('otherfee-summary');
  const classFilter = document.getElementById('otherfee-class-filter');
  const filterCls = classFilter ? classFilter.value : '';
  let students = DB.students.slice();
  if (filterCls) students = students.filter(s => s.cls === filterCls);
  const q = (document.getElementById('otherfee-search')||{}).value||'';
  if (q.trim()) students = students.filter(s => (s.fn+' '+s.ln).toLowerCase().includes(q.trim().toLowerCase()) || (s.adm||'').toLowerCase().includes(q.trim().toLowerCase()));
  const enrolledInFilter = getOtherFeeStudents(fid, term).filter(id => students.some(s=>s.id===id)).length;
  if (summaryEl) summaryEl.textContent = `${totalEnrolled} student(s) enrolled for Term ${term}${filterCls ? ' · filtered: '+enrolledInFilter+'/'+students.length : ''}`;
  // Update badge in row
  const row = document.getElementById('optfee-chk-'+sid)?.closest('tr');
  if (row) {
    const td = row.querySelectorAll('td')[3];
    if (td) td.innerHTML = enrolled
      ? `<span class="badge badge-paid"><i class="ti ti-check" style="font-size:10px"></i> Enrolled</span>`
      : `<span style="font-size:11px;color:var(--text3)">—</span>`;
  }
}

function otherFeeEnrollAll() {
  const modal = document.getElementById('m-otherfee-students');
  const fid = modal.dataset.fid;
  const term = +modal.dataset.term;
  clearFeeCache();
  // Enroll all currently visible students
  const checkboxes = document.querySelectorAll('#otherfee-student-list input[type="checkbox"]');
  checkboxes.forEach(cb => {
    const sid = cb.dataset.sid;
    setOtherFeeStudent(fid, sid, term, true);
    cb.checked = true;
  });
  saveDB();
  renderOtherFeeStudentModal(fid, term);
  toast('All visible students enrolled for Term ' + term, 'success');
}

function otherFeeUnenrollAll() {
  const modal = document.getElementById('m-otherfee-students');
  const fid = modal.dataset.fid;
  const term = +modal.dataset.term;
  clearFeeCache();
  const checkboxes = document.querySelectorAll('#otherfee-student-list input[type="checkbox"]');
  checkboxes.forEach(cb => {
    const sid = cb.dataset.sid;
    setOtherFeeStudent(fid, sid, term, false);
    cb.checked = false;
  });
  saveDB();
  renderOtherFeeStudentModal(fid, term);
  toast('All visible students removed for Term ' + term, 'info');
}

