// ============================================================
//  LICENSE SYSTEM — Machine-Bound, Tamper-Proof
//  Each key is valid for exactly ONE installation.
//  Activation is cryptographically bound to a stable device
//  fingerprint. Moving or copying the localStorage record to
//  another machine invalidates the license automatically.
// ============================================================
const LICENSE_TIERS = {
  trial:        {label:'Trial',       emoji:'🟡',maxStudents:50,  maxDevices:1, sync:false},
  standard:     {label:'Standard',    emoji:'🟢',maxStudents:9999,maxDevices:1, sync:false},
  professional: {label:'Professional',emoji:'🔵',maxStudents:9999,maxDevices:3, sync:true},
  enterprise:   {label:'Enterprise',  emoji:'🟣',maxStudents:9999,maxDevices:99,sync:true}
};
const LICENSE_SECRET = 'WKJ_SCHOOLMS_2025_UGANDA_SECRET_KEY_V3';
const MACHINE_SECRET = 'WKJ_MACHINE_BIND_2025_V4';

// ── Crypto helpers ──────────────────────────────────────────
async function hmacSHA256(secret, message) {
  const enc = new TextEncoder();
  const key = await crypto.subtle.importKey('raw', enc.encode(secret), {name:'HMAC',hash:'SHA-256'}, false, ['sign']);
  const sig = await crypto.subtle.sign('HMAC', key, enc.encode(message));
  return Array.from(new Uint8Array(sig)).map(b=>b.toString(16).padStart(2,'0')).join('');
}
async function sha256(message) {
  const enc = new TextEncoder();
  const buf = await crypto.subtle.digest('SHA-256', enc.encode(message));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

// ── Machine fingerprint ─────────────────────────────────────
// Builds a stable, hard-to-spoof identifier from browser
// environment signals. Not perfect, but raises the bar
// substantially over a simple localStorage flag.
async function getMachineId() {
  // Use a persisted random ID as the primary anchor.
  // Stored in BOTH localStorage AND DB.settings (IndexedDB) so it
  // survives localStorage clears (cache wipe, cookie clear, etc.)
  // without triggering a false machine_mismatch and unwanted logout.
  const MIDKEY = 'sms_mid_v1';

  // 1. Try localStorage first (fastest path)
  let mid = localStorage.getItem(MIDKEY);

  // 2. Fall back to IDB-backed copy in DB.settings
  if (!mid && DB && DB.settings && DB.settings._machineId) {
    mid = DB.settings._machineId;
    try { localStorage.setItem(MIDKEY, mid); } catch(_) {}
  }

  if (!mid) {
    // First time — generate and lock in the machine ID.
    const rand = crypto.getRandomValues(new Uint8Array(16));
    const randHex = Array.from(rand).map(b=>b.toString(16).padStart(2,'0')).join('');
    const signals = [
      navigator.language || '',
      navigator.platform || '',
      (screen.width || 0) + 'x' + (screen.height || 0),
      Intl.DateTimeFormat().resolvedOptions().timeZone || '',
      navigator.hardwareConcurrency || 0,
      (navigator.deviceMemory || 0)
    ].join('|');
    mid = await hmacSHA256(MACHINE_SECRET, randHex + '::' + signals);
    mid = mid.slice(0, 32);
    try { localStorage.setItem(MIDKEY, mid); } catch(_) {}
    if (DB && DB.settings) { DB.settings._machineId = mid; saveDB(); }
  } else if (DB && DB.settings && DB.settings._machineId !== mid) {
    // Keep IDB copy in sync
    DB.settings._machineId = mid;
    saveDB();
  }

  return mid;
}

// ── Compute an integrity seal over a license record ─────────
// The seal is an HMAC of all the critical license fields bound
// together with the machine ID. If ANY field is edited, or if
// the record is moved to a machine with a different ID, the
// seal won't verify.
async function computeLicenseSeal(licObj, machineId) {
  const payload = [
    licObj.key,
    licObj.type,
    licObj.school,
    licObj.activated,
    licObj.expires,
    machineId
  ].join('||');
  const fullHmac = await hmacSHA256(MACHINE_SECRET + LICENSE_SECRET, payload);
  return fullHmac.slice(0, 24); // 24-char seal
}

// ── Verify the stored license record is still intact ────────
async function verifyLicenseIntegrity() {
  const lic = DB.license;
  if (!lic || !lic.key) return { ok: false, reason: 'no_license' };

  const currentMid = await getMachineId();

  // Auto-heal: if _seal or _mid are missing (e.g. older activation or data import),
  // recompute and store them for this machine rather than blocking access.
  if (!lic._seal || !lic._mid) {
    lic._mid = currentMid;
    lic._seal = await computeLicenseSeal(lic, currentMid);
    const kfp = lic.key.slice(-12);
    _registerKeyUse(kfp, currentMid);
    saveDB();
    return { ok: true };
  }

  // 1. Machine ID must match this browser.
  // A mismatch most commonly means localStorage was cleared (cache wipe,
  // cookie clear) while IndexedDB data survived — NOT a genuine piracy
  // attempt on a different machine. Auto-heal: re-bind the license to the
  // current machine ID (same as the missing-seal auto-heal above).
  if (lic._mid !== currentMid) {
    lic._mid = currentMid;
    lic._seal = await computeLicenseSeal(lic, currentMid);
    const kfp = lic.key.slice(-12);
    _registerKeyUse(kfp, currentMid);
    saveDB();
    return { ok: true };
  }

  // 2. Seal must verify (catches field-level tampering of key/expiry/school).
  const expectedSeal = await computeLicenseSeal(lic, currentMid);
  if (lic._seal !== expectedSeal) {
    // Before flagging as tampered, re-verify the raw key's own cryptographic
    // signature. If the key is still cryptographically valid, the seal drift
    // is a false positive (race condition, migration, or prior save race).
    // Re-seal and continue — this is the same as the _mid auto-heal above.
    const recheck = await parseLicenseKey(lic.key);
    if (recheck.valid && recheck.expires === lic.expires && recheck.tier === lic.type) {
      // Key is genuine — the seal just drifted. Recompute and save.
      lic._seal = expectedSeal;
      lic._mid  = currentMid;
      saveDB();
      return { ok: true };
    }
    // Key's own signature doesn't validate — genuinely tampered.
    return { ok: false, reason: 'tampered' };
  }

  // 3. Key fingerprint must still be in usedKeys — format-aware check
  // (usedKeys stores objects {fp,mid,ts} in current format, plain strings in legacy)
  const keyFp = lic.key.slice(-12);
  const keyRegistered = (DB.usedKeys||[]).some(e => (typeof e === 'object' ? e.fp : e) === keyFp);
  if (!keyRegistered) {
    // Auto-heal: re-register the key for this machine
    _registerKeyUse(keyFp, currentMid);
    saveDB();
  }

  return { ok: true };
}

// ── Parse and validate the raw license key ──────────────────
async function parseLicenseKey(rawKey) {
  const key = rawKey.trim().toUpperCase();
  const parts = key.split('-');
  if (parts.length !== 5 || parts[0] !== 'WKJ')
    return {valid:false, reason:'Invalid key format. Expected: WKJ-T-YYYYMMDD-SCHOOLHASH-SIGNATURE'};
  const [,tierCode,expiry,schoolHash,sig] = parts;
  const tierMap = {T:'trial',S:'standard',P:'professional',E:'enterprise'};
  const tier = tierMap[tierCode];
  if (!tier) return {valid:false, reason:'Unknown tier code.'};
  if (!/^\d{8}$/.test(expiry)) return {valid:false, reason:'Invalid expiry date.'};
  const expiryDate = `${expiry.slice(0,4)}-${expiry.slice(4,6)}-${expiry.slice(6,8)}`;
  const payload = tierCode + expiry + schoolHash;
  const fullHmac = await hmacSHA256(LICENSE_SECRET, payload);
  const expectedSig = fullHmac.slice(0,8).toUpperCase();
  if (sig !== expectedSig)
    return {valid:false, reason:'Signature mismatch — key is invalid or has been tampered with.'};
  return {valid:true, tier, expires:expiryDate, schoolHash};
}

async function verifySchoolMatch(schoolName, schoolHash) {
  const enc = new TextEncoder();
  const raw = await crypto.subtle.digest('SHA-256', enc.encode(schoolName.trim().toLowerCase()));
  const hash = Array.from(new Uint8Array(raw)).map(b=>b.toString(16).padStart(2,'0')).join('');
  return hash.slice(0,8).toUpperCase() === schoolHash.toUpperCase();
}

// ── Core activation function ─────────────────────────────────
async function _doActivateLicense(keyEl, schoolEl, statusEl, setDB) {
  const key = keyEl.value.trim().toUpperCase();
  const school = schoolEl.value.trim();
  if (!key || !school) {
    statusEl.innerHTML='<span style="color:red">⚠️ Please fill in both fields.</span>';
    return;
  }
  statusEl.innerHTML = '<span style="color:var(--text3)">⏳ Verifying license…</span>';

  // ── Step 1: parse and cryptographically validate the key ──
  const result = await parseLicenseKey(key);
  if (!result.valid) {
    statusEl.innerHTML = `<span style="color:red">❌ ${result.reason}</span>`;
    return;
  }

  // ── Step 2: school name must hash-match the key ───────────
  const match = await verifySchoolMatch(school, result.schoolHash);
  if (!match) {
    statusEl.innerHTML = `<span style="color:red">❌ School name does not match this license key. Use the exact school name used during purchase.</span>`;
    return;
  }

  // ── Step 3: check if this key is already bound to a DIFFERENT machine ──
  // We store a longer fingerprint (12 chars) to reduce collision risk.
  const keyFp = key.slice(-12);

  // If this key fingerprint is already registered, only allow reactivation
  // if the machine ID matches what was stored with it.
  const usedEntry = (DB.usedKeys||[]).find(e => typeof e === 'object' ? e.fp === keyFp : e === keyFp);
  const currentMid = await getMachineId();

  if (usedEntry) {
    // Key was previously activated somewhere
    const storedMid = typeof usedEntry === 'object' ? usedEntry.mid : null;
    const isThisMachine = !storedMid || storedMid === currentMid;
    const isCurrentKey = DB.license?.key?.toUpperCase() === key;

    if (!isThisMachine && !isCurrentKey) {
      // Key is registered to a DIFFERENT machine — block it
      statusEl.innerHTML = `<span style="color:red">🔒 This license key is already activated on another installation.<br>
        Each key is valid for one installation only.<br>
        Contact <strong>WKJSoftwares</strong> at <em>wellbornkeys234@gmail.com</em> to transfer or purchase a new license.</span>`;
      return;
    }
  }

  // ── Step 4: check expiry ──────────────────────────────────
  if (result.expires < today()) {
    statusEl.innerHTML = `<span style="color:orange">⚠️ This license expired on ${result.expires}. Please renew at WKJSoftwares — wellbornkeys234@gmail.com</span>`;
    // Still record as expired (but bound to this machine)
    const licRec = {key, type:result.tier, school, activated:today(), expires:result.expires, _mid: currentMid};
    licRec._seal = await computeLicenseSeal(licRec, currentMid);
    DB.license = licRec;
    _registerKeyUse(keyFp, currentMid);
    saveDB();
    return;
  }

  // ── Step 5: activate and machine-bind ────────────────────
  const tier = LICENSE_TIERS[result.tier];
  const licRec = {
    key,
    type: result.tier,
    school,
    activated: today(),
    expires: result.expires,
    _mid: currentMid   // machine ID embedded in record
  };
  // Compute integrity seal AFTER all fields are set
  licRec._seal = await computeLicenseSeal(licRec, currentMid);

  DB.license = licRec;
  _registerKeyUse(keyFp, currentMid);
  saveDB();

  statusEl.innerHTML = `<span style="color:green">✅ ${tier.emoji} <strong>${tier.label}</strong> activated for <strong>${school}</strong><br>
    Expires: ${result.expires} &nbsp;·&nbsp; Devices: ${tier.maxDevices===99?'Unlimited':tier.maxDevices} &nbsp;·&nbsp; Sync: ${tier.sync?'✅':'❌'}<br>
    <span style="font-size:11px;color:var(--text3)">Machine ID: ${currentMid.slice(0,8)}…</span></span>`;

  updateLicenseBadge();
  const warn = document.getElementById('li-lic-warn');
  if (warn) warn.style.display = 'none';
  setTimeout(()=>{
    const loginTab = document.getElementById('ltab-login');
    if (loginTab) switchLoginTab('login', loginTab);
  }, 1800);
}

// Store key use as an object with machine binding (backwards-compatible with old string entries)
function _registerKeyUse(keyFp, machineId) {
  if (!DB.usedKeys) DB.usedKeys = [];
  // Remove any old-format (string) entry for this fp
  DB.usedKeys = DB.usedKeys.filter(e => (typeof e === 'object' ? e.fp : e) !== keyFp);
  // Add new bound entry
  DB.usedKeys.push({ fp: keyFp, mid: machineId, ts: today() });
  // Cap to last 20 entries
  if (DB.usedKeys.length > 20) DB.usedKeys = DB.usedKeys.slice(-20);
}

