<script>
// ============================================================
//  ENHANCEMENTS
// ============================================================

// ── AI ASSISTANT ─────────────────────────────────────────────
let _aiHistory = []; // conversation history for multi-turn context

function toggleAIPanel() {
  const p = document.getElementById('ai-panel');
  p.classList.toggle('open');
  // Show key warning banner if no key is configured
  const warn = document.getElementById('ai-key-warn-panel');
  if (warn) warn.style.display = localStorage.getItem('sms_ai_key') ? 'none' : '';
}

function aiAsk(q) {
  document.getElementById('ai-input').value = q;
  aiSend();
}

async function aiSend() {
  const inp = document.getElementById('ai-input');
  const q = inp.value.trim();
  if (!q) return;
  inp.value = '';

  const msgs = document.getElementById('ai-msgs');

  // Add user bubble
  msgs.innerHTML += `<div class="ai-msg user">${q}</div>`;
  // Add loading bubble
  const loadId = 'ai-load-' + Date.now();
  msgs.innerHTML += `<div class="ai-msg bot loading" id="${loadId}">⏳ Analysing your school data…</div>`;
  msgs.scrollTop = msgs.scrollHeight;

  // Build data context
  const t = DB.settings.term || 2;
  const totalStudents = DB.students.length;
  const totalStaff = DB.staff.length;
  const feeExp = DB.students.reduce((a,s)=>a+getTotalOwed(s.id,t),0);
  const feePaid = DB.students.reduce((a,s)=>a+getTotalPaid(s.id,t),0);
  const feeOut = Math.max(0, feeExp - feePaid);
  const colRate = feeExp > 0 ? Math.round(feePaid/feeExp*100) : 0;
  const todayAtt = DB.attendance[today()] || {};
  const presentToday = Object.values(todayAtt).filter(v=>v==='P').length;
  const absentToday = Object.values(todayAtt).filter(v=>v==='A').length;
  const debtors = DB.students.filter(s=>getBalance(s.id,t)>0).sort((a,b)=>getBalance(b.id,t)-getBalance(a.id,t)).slice(0,5);
  const expTotal = (DB.expenses||[]).reduce((a,e)=>a+e.amount,0);

  // Class breakdown
  const classBreakdown = DB.classes.map(c=>({cls:c, count:DB.students.filter(s=>s.cls===c).length})).filter(x=>x.count>0);

  // Academic snapshot
  let topStudents = [];
  try {
    const allKeys = Object.keys(DB.marks);
    const studentScores = {};
    allKeys.filter(k=>k.endsWith('||'+t)).forEach(key=>{
      const marks = DB.marks[key];
      Object.entries(marks).forEach(([sid,m])=>{
        const tot = (+m.bot||0)+(+m.mid||0)+(+m.eot||0);
        if(!studentScores[sid]) studentScores[sid]={total:0,count:0};
        studentScores[sid].total += tot; studentScores[sid].count++;
      });
    });
    topStudents = Object.entries(studentScores).map(([sid,sc])=>{
      const s=DB.students.find(x=>x.id===sid);
      return s ? {name:s.fn+' '+s.ln, cls:s.cls, avg:Math.round(sc.total/sc.count)} : null;
    }).filter(Boolean).sort((a,b)=>b.avg-a.avg).slice(0,5);
  } catch(e){}

  const schoolName = DB.settings.name || 'the school';
  const schoolYear = DB.settings.year || 2025;

  const systemPrompt = `You are SchoolMS AI, an intelligent school management assistant for ${schoolName} (Uganda). You have access to real-time school data and must answer the admin's questions concisely, using bullet points where helpful. Keep responses short (under 150 words). Reference specific numbers from the data. Be friendly and professional.

CURRENT DATA SNAPSHOT (Term ${t}, ${schoolYear}):
- Students: ${totalStudents} enrolled across ${DB.classes.filter(c=>DB.students.some(s=>s.cls===c)).length} active classes
- Class breakdown: ${classBreakdown.map(x=>`${x.cls}(${x.count})`).join(', ')}
- Staff: ${totalStaff} members
- Fee collection: UGX ${fmt(feePaid)} collected of UGX ${fmt(feeExp)} expected (${colRate}% rate)
- Outstanding fees: UGX ${fmt(feeOut)} from ${debtors.length > 0 ? DB.students.filter(s=>getBalance(s.id,t)>0).length : 0} students
- Top debtors: ${debtors.map(s=>`${s.fn} ${s.ln} (UGX ${fmt(getBalance(s.id,t))})`).join('; ')||'None'}
- Today's attendance: ${presentToday} present, ${absentToday} absent
- Total expenses recorded: UGX ${fmt(expTotal)}
- Top students by avg marks: ${topStudents.map(s=>`${s.name} ${s.avg}%`).join(', ')||'No marks data yet'}`;

  // Append user turn to history
  _aiHistory.push({ role: 'user', content: q });
  // Keep history to last 10 turns to avoid token bloat
  if (_aiHistory.length > 20) _aiHistory = _aiHistory.slice(_aiHistory.length - 20);

  // Check for API key (required for direct browser access to Anthropic API)
  const _aiApiKey = localStorage.getItem('sms_ai_key') || '';
  if (!_aiApiKey) {
    _aiHistory.pop();
    const loadEl = document.getElementById(loadId);
    if (loadEl) { loadEl.className='ai-msg bot'; loadEl.innerHTML='\u{1F511} <strong>API key not set.</strong><br>Go to <strong>Settings → Data &amp; Backup</strong> and enter your Anthropic API key to enable the AI assistant.'; }
    msgs.scrollTop = msgs.scrollHeight;
    return;
  }

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': _aiApiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 400,
        system: systemPrompt,
        messages: _aiHistory
      })
    });
    const data = await resp.json();
    if (data.error) {
      _aiHistory.pop();
      const loadEl = document.getElementById(loadId);
      const isAuth = data.error.type === 'authentication_error';
      if (loadEl) { loadEl.className='ai-msg bot'; loadEl.innerHTML='\u26a0\ufe0f <strong>' + (isAuth ? 'Invalid API key.' : 'AI error: ' + (data.error.message||'Unknown')) + '</strong>' + (isAuth ? '<br>Update your key in <strong>Settings → Data &amp; Backup</strong>.' : ''); }
    } else {
      const answer = data.content?.[0]?.text || 'Sorry, I could not process that request.';
      _aiHistory.push({ role: 'assistant', content: answer });
      const loadEl = document.getElementById(loadId);
      if (loadEl) { loadEl.className='ai-msg bot'; loadEl.innerHTML=answer.replace(/\n/g,'<br>'); }
    }
  } catch(err) {
    _aiHistory.pop();
    const loadEl = document.getElementById(loadId);
    if (loadEl) { loadEl.className='ai-msg bot'; loadEl.innerHTML='\u26a0\ufe0f Could not reach the AI. Check your internet connection.'; }
  }
  msgs.scrollTop = msgs.scrollHeight;
}

// ── ANALYTICS MODAL ──────────────────────────────────────────
function openAnalyticsModal() {
  openM('m-analytics');
  analyticsTab('overview', document.querySelector('#analytics-tabs .tab'));
}

function analyticsTab(tab, el) {
  document.querySelectorAll('#analytics-tabs .tab').forEach(t=>t.classList.remove('active'));
  if (el) el.classList.add('active');
  const c = document.getElementById('analytics-content');
  const t = DB.settings.term || 2;

  if (tab === 'overview') {
    const totalSt = DB.students.length;
    const totalStaff = DB.staff.length;
    const feeExp = DB.students.reduce((a,s)=>a+getTotalOwed(s.id,t),0);
    const feePaid = DB.students.reduce((a,s)=>a+getTotalPaid(s.id,t),0);
    const colRate = feeExp>0 ? Math.round(feePaid/feeExp*100) : 0;
    const attDates = Object.keys(DB.attendance).sort().slice(-30);
    let totalP=0,totalA=0;
    attDates.forEach(d=>{ Object.values(DB.attendance[d]||{}).forEach(v=>{if(v==='P')totalP++;else if(v==='A')totalA++;}); });
    const attRate = totalP+totalA>0 ? Math.round(totalP/(totalP+totalA)*100) : 0;
    const expTotal = (DB.expenses||[]).reduce((a,e)=>a+e.amount,0);
    const males = DB.students.filter(s=>s.gen==='Male').length;
    const females = DB.students.filter(s=>s.gen==='Female').length;
    const boarders = DB.students.filter(s=>s.brd==='boarding').length;

    c.innerHTML = `
      <div class="analytics-grid">
        <div class="analytics-kpi"><div class="ak-val">${totalSt}</div><div class="ak-label">Total Students</div></div>
        <div class="analytics-kpi"><div class="ak-val">${totalStaff}</div><div class="ak-label">Staff Members</div></div>
        <div class="analytics-kpi" style="border-left:3px solid var(--success)"><div class="ak-val" style="color:var(--success)">${colRate}%</div><div class="ak-label">Fee Collection Rate</div></div>
        <div class="analytics-kpi" style="border-left:3px solid var(--info)"><div class="ak-val" style="color:var(--info)">${attRate}%</div><div class="ak-label">Attendance Rate (30d)</div></div>
      </div>
      <div class="g3">
        <div class="card" style="padding:12px">
          <div class="section-hd">Gender Split</div>
          <div style="font-size:13px;margin-top:6px">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Male</span><strong>${males}</strong></div>
            <div class="prog"><div class="prog-fill" style="width:${totalSt>0?Math.round(males/totalSt*100):0}%;background:var(--info)"></div></div>
            <div style="display:flex;justify-content:space-between;margin:8px 0 4px"><span>Female</span><strong>${females}</strong></div>
            <div class="prog"><div class="prog-fill" style="width:${totalSt>0?Math.round(females/totalSt*100):0}%;background:var(--accent)"></div></div>
          </div>
        </div>
        <div class="card" style="padding:12px">
          <div class="section-hd">Boarding Status</div>
          <div style="font-size:13px;margin-top:6px">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Day scholars</span><strong>${totalSt-boarders}</strong></div>
            <div class="prog"><div class="prog-fill" style="width:${totalSt>0?Math.round((totalSt-boarders)/totalSt*100):0}%"></div></div>
            <div style="display:flex;justify-content:space-between;margin:8px 0 4px"><span>Boarders</span><strong>${boarders}</strong></div>
            <div class="prog"><div class="prog-fill" style="width:${totalSt>0?Math.round(boarders/totalSt*100):0}%;background:var(--accent)"></div></div>
          </div>
        </div>
        <div class="card" style="padding:12px">
          <div class="section-hd">Financial Health</div>
          <div style="font-size:13px;margin-top:6px">
            <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Revenue (Term ${t})</span><strong style="color:var(--success)">UGX ${fmtK(feePaid)}</strong></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:4px"><span>Outstanding</span><strong style="color:var(--danger)">UGX ${fmtK(Math.max(0,feeExp-feePaid))}</strong></div>
            <div style="display:flex;justify-content:space-between"><span>Expenses</span><strong style="color:var(--warning)">UGX ${fmtK(expTotal)}</strong></div>
          </div>
        </div>
      </div>
      <div class="card" style="padding:12px;margin-top:14px">
        <div class="section-hd">Class Enrollment</div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:6px">
          ${DB.classes.map(cls=>{const n=DB.students.filter(s=>s.cls===cls).length;return n?`<div style="text-align:center;min-width:60px"><div style="font-size:18px;font-weight:700;color:var(--primary)">${n}</div><div style="font-size:10.5px;color:var(--text3)">${cls}</div></div>`:''}).join('')}
        </div>
      </div>`;
  }

  else if (tab === 'fees') {
    const feeExp = DB.students.reduce((a,s)=>a+getTotalOwed(s.id,t),0);
    const feePaid = DB.students.reduce((a,s)=>a+getTotalPaid(s.id,t),0);
    const feeOut = Math.max(0, feeExp-feePaid);
    const colRate = feeExp>0 ? Math.round(feePaid/feeExp*100) : 0;
    const debtors = DB.students.filter(s=>getBalance(s.id,t)>0).sort((a,b)=>getBalance(b.id,t)-getBalance(a.id,t));
    const fully = DB.students.filter(s=>getBalance(s.id,t)<=0).length;
    const partial = DB.students.filter(s=>{const b=getBalance(s.id,t);const p=getTotalPaid(s.id,t);return b>0&&p>0;}).length;
    const none = DB.students.filter(s=>getTotalPaid(s.id,t)===0&&getTotalOwed(s.id,t)>0).length;
    const payByMethod = {};
    (DB.payments||[]).filter(p=>+p.term===t).forEach(p=>{payByMethod[p.method]=(payByMethod[p.method]||0)+p.amount;});

    c.innerHTML = `
      <div class="analytics-grid">
        <div class="analytics-kpi" style="border-left:3px solid var(--success)"><div class="ak-val" style="color:var(--success)">UGX ${fmtK(feePaid)}</div><div class="ak-label">Collected Term ${t}</div></div>
        <div class="analytics-kpi" style="border-left:3px solid var(--danger)"><div class="ak-val" style="color:var(--danger)">UGX ${fmtK(feeOut)}</div><div class="ak-label">Outstanding</div></div>
        <div class="analytics-kpi"><div class="ak-val">${fully}</div><div class="ak-label">Fully Paid Students</div></div>
        <div class="analytics-kpi"><div class="ak-val">${debtors.length}</div><div class="ak-label">Students with Balance</div></div>
      </div>
      <div class="g2">
        <div class="card" style="padding:12px">
          <div class="section-hd">Payment Status Breakdown</div>
          <div style="margin-top:8px">
            <div style="display:flex;justify-content:space-between;padding:5px 0"><span style="color:var(--success)">✅ Fully paid</span><strong>${fully}</strong></div>
            <div style="display:flex;justify-content:space-between;padding:5px 0"><span style="color:var(--warning)">⚠️ Partially paid</span><strong>${partial}</strong></div>
            <div style="display:flex;justify-content:space-between;padding:5px 0"><span style="color:var(--danger)">❌ Not paid</span><strong>${none}</strong></div>
          </div>
          <div class="prog" style="margin-top:10px;height:10px">
            <div class="prog-fill" style="width:${colRate}%;background:linear-gradient(90deg,var(--success),var(--accent))"></div>
          </div>
          <div style="font-size:11px;color:var(--text3);margin-top:4px">${colRate}% collection rate</div>
        </div>
        <div class="card" style="padding:12px">
          <div class="section-hd">Payments by Method</div>
          ${Object.entries(payByMethod).sort((a,b)=>b[1]-a[1]).map(([m,v])=>`
            <div style="display:flex;justify-content:space-between;padding:4px 0;font-size:12px"><span>${m}</span><strong>UGX ${fmtK(v)}</strong></div>
          `).join('')||'<div class="empty" style="padding:10px"><p>No payments this term.</p></div>'}
        </div>
      </div>
      <div class="card" style="padding:12px;margin-top:14px">
        <div class="section-hd">Top 5 Debtors</div>
        ${debtors.slice(0,5).map((s,i)=>`
          <div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px">
