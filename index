function checkStorageUsage() {
  if (!navigator.storage || !navigator.storage.estimate) return;
  navigator.storage.estimate().then(({usage, quota}) => {
    const wrap = document.getElementById('storage-usage-bar-wrap');
    const fill = document.getElementById('storage-usage-fill');
    const label = document.getElementById('storage-usage-label');
    const warn = document.getElementById('storage-usage-warn');
    if (!wrap || !fill || !label) return;
    wrap.style.display = '';
    const pct = quota > 0 ? Math.round((usage / quota) * 100) : 0;
    const usedMB = (usage / 1048576).toFixed(1);
    const totalMB = (quota / 1048576).toFixed(0);
    fill.style.width = Math.min(pct, 100) + '%';
    fill.style.background = pct >= 80 ? 'var(--danger)' : pct >= 60 ? 'var(--warning)' : 'var(--primary)';
    label.textContent = `${usedMB} MB of ~${totalMB} MB used (${pct}%)`;
    if (warn) warn.style.display = pct >= 75 ? '' : 'none';
    // Also show a toast warning if critically high
    if (pct >= 90 && typeof showAlert === 'function') {
      showAlert('⚠️ Storage is almost full (' + pct + '%). Please export a JSON backup now and consider clearing old data.', '⚠️ Storage Warning');
    }
  }).catch(()=>{});
}

