    .sinfo-item{font-size:11px} .sinfo-label{font-size:10px;color:#888;margin-bottom:2px}
    .section-title{font-weight:700;font-size:12px;margin:12px 0 5px;border-bottom:1px solid #ddd;padding-bottom:3px}
    .avg-box{display:inline-block;padding:6px 14px;background:#1e4d35;color:#fff;border-radius:4px;font-weight:700;font-size:13px;margin-top:6px}
    .footer{margin-top:16px;text-align:center;font-size:9.5px;color:#888;border-top:1px dashed #ccc;padding-top:8px}
    @media print{body{padding:10mm}@page{size:A4;margin:12mm}}
  </style></head><body>
  <h1>${sch.name||'SCHOOL REPORT CARD'}</h1>
  <div class="sub">${termName} ${year} · Official Academic Report</div>
  <div class="sinfo">
    <div class="sinfo-item"><div class="sinfo-label">STUDENT NAME</div><strong>${s.fn} ${s.ln}</strong></div>
    <div class="sinfo-item"><div class="sinfo-label">ADM NO.</div>${s.adm}</div>
    <div class="sinfo-item"><div class="sinfo-label">CLASS</div>${s.cls}</div>
    <div class="sinfo-item"><div class="sinfo-label">GENDER</div>${s.gen}</div>
    <div class="sinfo-item"><div class="sinfo-label">PARENT/GUARDIAN</div>${s.par||'—'}</div>
    <div class="sinfo-item"><div class="sinfo-label">CONTACT</div>${s.con||'—'}</div>
  </div>
  ${rows.length?`<div class="section-title">📊 Academic Performance</div>
  <table><thead><tr><th>#</th><th>Subject</th><th>BOT</th><th>MID</th><th>EOT</th><th>Total</th><th>Grade</th><th>Remarks</th></tr></thead>
  <tbody>${rows.map((r,i)=>`<tr><td>${i+1}</td><td>${r.sub}</td><td>${r.bot||'—'}</td><td>${r.mid||'—'}</td><td>${r.eot||'—'}</td><td><strong>${r.tot}</strong></td><td><strong>${r.grade}</strong></td><td>${r.rem}</td></tr>`).join('')}</tbody>
  </table>
  ${avg!==null?`<div><span class="avg-box">Average: ${avg}%</span></div>`:''}` : '<div style="color:#888;margin-top:8px">No marks entered for this term.</div>'}
  <div class="section-title">📅 Attendance</div>
  <table><thead><tr><th>Present</th><th>Absent</th><th>Late</th><th>Total Days</th><th>Rate</th></tr></thead>
  <tbody><tr><td>${attP}</td><td>${attA}</td><td>${attL}</td><td>${attTotal}</td><td>${attPct!==null?attPct+'%':'—'}</td></tr></tbody></table>
  <div class="section-title">💰 Fee Status</div>
  <table><thead><tr><th>Term Fee</th><th>B/F Balance</th><th>Total Paid</th><th>Outstanding</th><th>Status</th></tr></thead>
  <tbody><tr><td>UGX ${fmt(termFee)}</td><td>${bf>0?'UGX '+fmt(bf):'—'}</td><td>UGX ${fmt(paid)}</td><td style="color:${bal>0?'red':'green'}">UGX ${fmt(bal)}</td><td>${bal===0?'✅ Paid':'⚠️ Outstanding'}</td></tr></tbody></table>
  ${s.health?`<div class="section-title">🏥 Health Notes</div><div style="padding:7px;border:1px solid #ffc107;border-radius:4px;background:#fffbea;color:#856404;font-size:11px">${s.health}</div>`:''}
