function buildStudentProfileCard(s, term, termName, sch) {
  const termFee = getTermFeeTotal(s.id, term);
  const bf = getCarryForward(s.id, term);
  const paid = getTotalPaid(s.id, term);
  const balance = Math.max(0, termFee + bf - paid);
  const feeStatus = getFeesStatus(s.id, term);
  const feeStatusColor = {paid:'var(--success)',partial:'var(--warning)',unpaid:'var(--danger)'}[feeStatus]||'var(--text3)';

  // Attendance this year
  const year = sch.year || new Date().getFullYear();
  const allDates = Object.keys(DB.attendance||{}).filter(d=>d.startsWith(year+'-'));
  let attP=0, attA=0, attL=0;
  allDates.forEach(d=>{
    const v=(DB.attendance[d]||{})[s.id]||'';
    if(v==='P')attP++; else if(v==='A')attA++; else if(v==='L')attL++;
  });
  const attTotal = attP+attA+attL;
  const attPct = attTotal>0 ? Math.round((attP+attL)/attTotal*100) : null;
  const attColor = attPct===null?'var(--text3)':attPct>=90?'var(--success)':attPct>=75?'var(--warning)':'var(--danger)';

  // Marks this term
  const format = DB.reportSettings.format || 'primary_uneb';
  const subjects = (DB.reportSettings.classSubjects||{})[s.cls] || [];
  const markRows = subjects.map(sub=>{
    const key = `${s.cls}||${sub}||${term}`;
    const m = (DB.marks[key]||{})[s.id]||{};
    const tot = Math.min(100,(+m.bot||0)+(+m.mid||0)+(+m.eot||0));
    const gd = getGrade(tot, format);
    return {sub, tot, gd};
  }).filter(r=>r.tot>0);

  const avgMark = markRows.length ? Math.round(markRows.reduce((a,b)=>a+b.tot,0)/markRows.length) : null;
  const overallGd = avgMark!==null ? getGrade(avgMark, format) : null;

  // Monthly attendance breakdown for current year
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const monthBars = Array.from({length:12},(_,i)=>{
    const ms = String(i+1).padStart(2,'0');
    const mDates = allDates.filter(d=>d.startsWith(`${year}-${ms}`));
    if (!mDates.length) return `<div style="flex:1;text-align:center"><div style="height:28px;background:var(--border);border-radius:3px 3px 0 0"></div><div style="font-size:8px;color:var(--text3);margin-top:2px">${monthNames[i]}</div></div>`;
    let mp=0,ma=0,ml=0;
    mDates.forEach(d=>{const v=(DB.attendance[d]||{})[s.id]||'';if(v==='P')mp++;else if(v==='A')ma++;else if(v==='L')ml++;});
    const mt=mp+ma+ml; const pct=mt>0?Math.round((mp+ml)/mt*100):0;
    const col=pct>=90?'var(--success)':pct>=75?'var(--warning)':'var(--danger)';
    return `<div style="flex:1;text-align:center" title="${monthNames[i]}: ${pct}% (${mp+ml}/${mt})">
      <div style="height:${Math.max(4,Math.round(pct*0.28))}px;background:${col};border-radius:3px 3px 0 0;margin:0 1px;transition:height 0.3s"></div>
      <div style="font-size:7.5px;color:var(--text3);margin-top:2px">${monthNames[i]}</div>
    </div>`;
  }).join('');

  const dob = s.dob ? new Date(s.dob) : null;
  const age = dob ? (new Date().getFullYear() - dob.getFullYear()) : null;

  return `<div class="card" style="margin-bottom:18px;border-top:4px solid var(--primary);position:relative" data-student-id="${s.id}">
    <!-- HEADER ROW -->
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;gap:12px;flex-wrap:wrap">
      <div style="display:flex;align-items:center;gap:14px">
        <div style="width:52px;height:52px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700;color:#fff;flex-shrink:0;font-family:var(--font-display);overflow:hidden;cursor:pointer;border:2px solid var(--border)" onclick="openPhotoModal('${s.id}')" title="Manage photo">${s.photo?`<img src="${s.photo}" style="width:100%;height:100%;object-fit:cover">`:(s.fn[0]+s.ln[0])}</div>
        <div>
          <div style="font-size:17px;font-weight:700;color:var(--text);font-family:var(--font-display)">${s.fn} ${s.ln}</div>
          <div style="font-size:11.5px;color:var(--text3);margin-top:2px">Adm: <strong>${s.adm}</strong> &nbsp;·&nbsp; Class: <strong>${s.cls}</strong> &nbsp;·&nbsp; ${s.gen} &nbsp;·&nbsp; ${s.brd==='boarding'?'🏠 Boarder':'🚶 Day Scholar'}</div>
          ${age?`<div style="font-size:11px;color:var(--text3)">Age: ${age} yrs &nbsp;·&nbsp; DOB: ${s.dob||'—'}</div>`:''}
        </div>
      </div>
      <div style="display:flex;gap:6px;flex-wrap:wrap">
        <span class="badge badge-info">${s.cls}</span>
        <span class="badge badge-${feeStatus}">${feeStatus.toUpperCase()}</span>
        ${attPct!==null?`<span class="badge" style="background:${attColor}22;color:${attColor}">${attPct}% ATT</span>`:''}
      </div>
    </div>

    <!-- 4 INFO COLS -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px;background:var(--surface2);padding:12px;border-radius:var(--radius)">
      <div>
        <div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px">Parent/Guardian</div>
        <div style="font-size:12.5px;font-weight:500">${s.par||'—'}</div>
        <div style="font-size:11.5px;color:var(--text3)">${s.con||'—'}</div>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px">Fee Info</div>
        <div style="font-size:12.5px;font-weight:500">${s.cls} — ${s.brd==='boarding'?'Boarder':'Day Scholar'}</div>
        <div style="font-size:11.5px;color:var(--text3)">${termName}</div>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px">Previous School</div>
