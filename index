function getLicense() { return DB.license || null; }
function getTier() { const lic = getLicense(); if (!lic) return null; return LICENSE_TIERS[lic.type] || null; }

// Synchronous fast check — used in hot paths (login gate, canAddStudent, etc.)
// Full async integrity check runs at startup and periodically.
function licenseActive() {
  const lic = getLicense();
  if (!lic || !lic.key) return false;
  if (lic._integrityFailed) return false; // set by async integrity verifier (in-memory only)
  if (!lic.expires) return false;
  // Derive active/expired purely from the date — never trust the persisted status flag,
  // which can get stuck as 'expired' and block valid licenses across refreshes.
  return lic.expires >= today();
}
function activeStudentCount() {
  return DB.students.filter(s=>s.status!=='dismissed').length;
}
function canAddStudent() {
  if (!licenseActive()) return false;
  const tier = getTier();
  return tier && activeStudentCount() < tier.maxStudents;
}
function syncAllowed() {
  if (!licenseActive()) return false;
  const tier = getTier();
  return tier && tier.sync === true;
}

// Full async integrity verification — called at startup and every 10 min
// One retry on 'tampered' before treating it as fatal — a single bad read
// can occur due to a saveDB() write being in-flight during the check.
async function runLicenseIntegrityCheck() {
  const lic = DB.license;
  if (!lic || !lic.key) return; // nothing to check
  if (lic.expires && lic.expires < today()) return; // genuinely expired by date
  const result = await verifyLicenseIntegrity();
  if (!result.ok) {
    // Give it one more chance after a short pause before declaring failure.
    // This eliminates false positives from concurrent saveDB() writes.
    await new Promise(r => setTimeout(r, 5000));
    // Re-read from DB in case a concurrent save updated the seal
    const retry = await verifyLicenseIntegrity();
    if (retry.ok) return; // transient — all good now
    const reasonMessages = {
      tampered: 'License record has been modified. Please re-activate with your original key.',
      no_seal: 'License record is missing security data. Please re-activate.',
      key_unregistered: 'License record could not be verified. Please re-activate.'
    };
    // Mark as failed (synchronous checks will now return false)
    if (DB.license) DB.license._integrityFailed = true;
    // Don't save — prevents persisting the bad state
    updateLicenseBadge();
    if (currentUser) {
      showAlert(
        (reasonMessages[retry.reason] || 'License verification failed. Please re-activate.') +
        '\n\nYou will be logged out. Contact WKJSoftwares at wellbornkeys234@gmail.com.',
        '🔐 License Invalid'
      );
      setTimeout(doLogout, 8000); // give user time to read the message
    }
  }
}

function updateLicenseBadge() {
  const lic = getLicense(); const tier = getTier();
  const el = document.getElementById('lic-current-badge');
  if (el) {
    if (!lic || !lic.key) {
      el.innerHTML = `<div class="alert-box danger" style="margin-bottom:0">⚠️ No license activated — sign-in is blocked until a valid key is entered.</div>`;
    } else if (lic._integrityFailed) {
      el.innerHTML = `<div class="alert-box danger" style="margin-bottom:0">🔒 License integrity check failed — re-activate or contact WKJSoftwares.</div>`;
    } else {
      const active = licenseActive();
      const mid = lic._mid ? (' &nbsp;·&nbsp; Machine: <code style="font-size:10px">' + lic._mid.slice(0,8) + '…</code>') : '';
      const tierLabel = tier ? (tier.emoji + ' <strong>' + tier.label + '</strong>') : ('⚪ <strong>' + (lic.type || 'Unknown') + '</strong>');
      el.innerHTML = `<div class="alert-box ${active?'success':'danger'}" style="margin-bottom:0">Current: ${tierLabel} — ${active?'✅ Active':'❌ Expired'} (expires ${lic.expires||'—'})${mid}</div>`;
    }
  }
  // Keep the topbar plan badge in sync with the current license state
  const topBadge = document.getElementById('topbar-plan-badge');
  if (topBadge) {
    const typeKey = (lic && lic.type) ? lic.type : 'trial';
    const typeToClass = {trial:'trial', standard:'standard', professional:'pro', enterprise:'enterprise'};
    const labels      = {trial:'Trial', standard:'Standard', professional:'Professional', enterprise:'Enterprise'};
    topBadge.className = `plan-badge ${typeToClass[typeKey] || 'trial'}`;
    topBadge.textContent = labels[typeKey] || typeKey;
  }
  const sw = document.getElementById('sync-lic-warn');
  if (sw) sw.style.display = syncAllowed() ? 'none' : '';
  renderLicenseSettingsPanel();
}

