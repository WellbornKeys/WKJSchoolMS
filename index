// ── 12. Parse Bulk Payment File ──────────────────────────────
function xlsxHandleBulkPaymentFile(input) {
  const file = input.files[0]; if (!file) return;
  // Reset state from any previous parse
  document.getElementById('bulk-pay-preview-area').style.display = 'none';
  document.getElementById('bulk-pay-import-btn').style.display = 'none';
  document.getElementById('bulk-pay-warnings').innerHTML = '<div class="alert-box info" style="font-size:11.5px">⏳ Reading file…</div>';
  document.getElementById('bulk-pay-total').textContent = '';
  document.getElementById('bulk-pay-count').textContent = '0';
  window._bulkPayRows = [];
  xlsxParseReady(function() { _xlsxHandleBulkPaymentFileParse(file); });
}
function _xlsxHandleBulkPaymentFileParse(file) {
  const reader = new FileReader();
  reader.onload = async function(e) {
    try {
      const data = new Uint8Array(e.target.result);
      const wb   = await XLSXReader.readAsync(data);
      const ws   = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSXReader.utils.sheet_to_json(ws, {header:1, defval:''});

      if (!rows || rows.length < 2) {
        showAlert('The file appears empty or has no data rows.', '⚠️ Empty File');
        return;
      }

      // Find header row
      let headerIdx = 0;
      for (let i = 0; i < Math.min(5, rows.length); i++) {
        const r = rows[i].map(c => String(c||'').toLowerCase());
        if (r.some(c => c.includes('adm') || c.includes('amount') || c.includes('date'))) {
          headerIdx = i; break;
        }
      }
      const headers = rows[headerIdx].map(h => String(h||'').toLowerCase().trim());

      function colIdx(keywords) {
        const idx = headers.findIndex(h => keywords.some(k => h.includes(k)));
        return idx >= 0 ? idx : -1;
      }
      const cols = {
        date:   colIdx(['date']),
        adm:    colIdx(['adm','admission','reg no','student id']),
        amount: colIdx(['amount','ugx','fee','paid']),
        term:   colIdx(['term']),
        method: colIdx(['payment method','pay method','method']),
        comp:   colIdx(['fee component','component','fee type']),
        rcpt:   colIdx(['receipt','rcpt','ref']),
        notes:  colIdx(['notes','note','remark']),
      };

      const parsed = [], warnings = [];
      let autoRcptCounter = 1;

      for (let i = headerIdx + 1; i < rows.length; i++) {
        const r = rows[i];
        if (r.every(c => !String(c||'').trim())) continue;

        const get = idx => idx >= 0 ? String(r[idx]||'').trim() : '';

        // Date
        let dateRaw = get(cols.date);
        if (dateRaw instanceof Date || (r[cols.date] instanceof Date)) {
          const d = r[cols.date] instanceof Date ? r[cols.date] : new Date(dateRaw);
          dateRaw = d.toISOString().slice(0,10);
        } else if (dateRaw && !isNaN(+dateRaw) && +dateRaw > 1000) {
          try {
            // SheetJS v0.20+ removed SSF.parse_date_code — use manual Excel serial conversion
            const serial = +dateRaw;
            const utcDays = serial - 25569;
            const d = new Date(utcDays * 86400 * 1000);
            dateRaw = d.toISOString().slice(0, 10);
          } catch(err) { dateRaw = today(); }
        } else if (!dateRaw || !/^\d{4}-\d{2}-\d{2}$/.test(dateRaw)) {
          warnings.push(`Row ${i+1}: Invalid or missing date "${dateRaw}" — using today.`);
          dateRaw = today();
        }

        // Adm No
        const adm = get(cols.adm);
        if (!adm) { warnings.push(`Row ${i+1}: No admission number — row skipped.`); continue; }
        const student = DB.students.find(s => s.adm.toLowerCase() === adm.toLowerCase());
        if (!student) { warnings.push(`Row ${i+1}: Adm "${adm}" not found in system — row skipped.`); continue; }

        // Amount
        const amtRaw = get(cols.amount).replace(/[^0-9.]/g,'');
        const amount = Math.round(parseFloat(amtRaw) || 0);
        if (!amount || amount <= 0) { warnings.push(`Row ${i+1}: Invalid amount "${get(cols.amount)}" — row skipped.`); continue; }

        // Term
        const termRaw = parseInt(get(cols.term)) || DB.settings.term || 2;
        const term = [1,2,3].includes(termRaw) ? termRaw : DB.settings.term;

        // Method
        const validMethods = ['Cash','Mobile Money (MTN)','Mobile Money (Airtel)','Bank Transfer (Stanbic)','Bank Transfer (Centenary)','Cheque'];
        const methodRaw = get(cols.method);
        const method = validMethods.find(m => m.toLowerCase().includes(methodRaw.toLowerCase())) || methodRaw || 'Cash';

        // Component — resolve name to fee key
        const rawComp = get(cols.comp);
        let comp = rawComp || (DB.recurringFees&&DB.recurringFees[0] ? DB.recurringFees[0].name : 'tuition');
        if (rawComp) {
          // Check if it already looks like a fee key (othf_ prefix or exact recurring name)
          const asOther = (DB.otherFees||[]).find(f =>
            f.name.toLowerCase() === rawComp.toLowerCase() || 'othf_'+f.id === rawComp
          );
          if (asOther) {
            comp = 'othf_' + asOther.id;
          } else {
            // Keep as-is (recurring fee name or legacy string)
            const asRec = (DB.recurringFees||[]).find(f => f.name.toLowerCase() === rawComp.toLowerCase());
            comp = asRec ? asRec.name : rawComp;
          }
        }

        // Receipt
        let rcpt = get(cols.rcpt);
        if (!rcpt) rcpt = 'RCP-' + String(Date.now() + autoRcptCounter++).slice(-6);

        const notes = get(cols.notes);

        parsed.push({ date:dateRaw, studentId:student.id, admDisplay:student.adm, studentName:student.fn+' '+student.ln, cls:student.cls, amount, term, method, component:comp, receipt:rcpt, notes });
      }

      window._bulkPayRows = parsed;

      // Render preview
      document.getElementById('bulk-pay-count').textContent = parsed.length;
      const totalAmt = parsed.reduce((a,p) => a+p.amount, 0);
      document.getElementById('bulk-pay-preview-body').innerHTML = parsed.slice(0,25).map((p,i) => `
        <tr style="${i%2===0?'background:var(--surface2)':''}">
          <td>${p.date}</td>
          <td style="font-family:monospace;font-size:11px">${p.admDisplay}</td>
          <td>${p.studentName}</td>
          <td><span class="badge badge-info">${p.cls}</span></td>
          <td>Term ${p.term}</td>
          <td style="font-weight:600;color:var(--success)">UGX ${fmt(p.amount)}</td>
          <td style="font-size:11px">${p.method}</td>
          <td style="font-size:11px">${p.component}</td>
          <td style="font-family:monospace;font-size:10.5px">${p.receipt}</td>
          <td style="font-size:11px;color:var(--text3)">${p.notes||'—'}</td>
        </tr>`).join('') + (parsed.length > 25 ? `<tr><td colspan="10" style="text-align:center;color:var(--text3);padding:8px">…and ${parsed.length-25} more</td></tr>` : '');

      document.getElementById('bulk-pay-total').innerHTML = `Total to import: <strong>UGX ${fmt(totalAmt)}</strong> across ${parsed.length} payment${parsed.length!==1?'s':''}`;

      const warnEl = document.getElementById('bulk-pay-warnings');
      if (warnings.length) {
        warnEl.innerHTML = `<div class="alert-box warning" style="font-size:11.5px;max-height:120px;overflow-y:auto">
          <strong>⚠️ ${warnings.length} notice(s):</strong><br>${warnings.slice(0,12).map(w=>`• ${w}`).join('<br>')}${warnings.length>12?`<br>…and ${warnings.length-12} more`:''}
        </div>`;
      } else {
        warnEl.innerHTML = `<div class="alert-box success" style="font-size:11.5px">✅ No issues detected. All rows matched to students.</div>`;
      }

      document.getElementById('bulk-pay-preview-area').style.display = '';
      document.getElementById('bulk-pay-import-btn').style.display = parsed.length > 0 ? '' : 'none';

    } catch(err) {
      showAlert('Could not read the file. Make sure it is a valid Excel (.xlsx/.xls) or CSV file.\n\nError: ' + err.message, '❌ File Error');
    }
  };
  reader.readAsArrayBuffer(file);
}

// ── 13. Confirm & Execute Bulk Payment Import ────────────────
function xlsxConfirmBulkPaymentImport() {
  const rows = window._bulkPayRows || [];
  if (!rows.length) { showAlert('No valid rows to import.'); return; }

  let imported = 0;
  rows.forEach(p => {
    const pay = {
      id:        genId('pay'),
      studentId: p.studentId,
      amount:    p.amount,
      date:      p.date,
      term:      p.term,
      method:    p.method,
      component: p.component,
      receipt:   p.receipt,
      notes:     p.notes || ''
    };
    DB.payments.push(pay);
    imported++;
  });

  const total = rows.reduce((a,p) => a+p.amount, 0);
  addAct(`Bulk imported ${imported} payment(s) — UGX ${fmt(total)} from Excel`);
  saveDB();
  closeM('m-bulk-pay-upload');
  renderFees();
  if (document.getElementById('phist-rows')) renderPayHistory();
  showAlert(`✅ ${imported} payment(s) imported successfully!\nTotal: UGX ${fmt(total)}`, 'Bulk Import Complete');
}

</script>

