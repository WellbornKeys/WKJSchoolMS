<script>
(function() {
'use strict';

// ── 1. IMPROVED SHORTCUT HELP ────────────────────────────────
window.showShortcutHelp = function() {
  if (typeof openM === 'function') openM('m-shortcuts');
};

// ── 2. EXTRA KEYBOARD SHORTCUTS ─────────────────────────────
document.addEventListener('keydown', function(e) {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
  // Ctrl+B → toggle sidebar
  if ((e.ctrlKey||e.metaKey) && e.key === 'b') {
    e.preventDefault();
    if (typeof toggleSidebar === 'function') toggleSidebar();
  }
  // Ctrl+Shift+A → toggle AI panel
  if ((e.ctrlKey||e.metaKey) && e.shiftKey && e.key === 'A') {
    e.preventDefault();
    const fab = document.querySelector('.ai-fab');
    if (fab) fab.click();
  }
  // Alt+D → dashboard, Alt+S → students, Alt+F → fees, Alt+M → marks, Alt+A → attendance
  if (e.altKey && !e.ctrlKey && !e.metaKey) {
    const navMap = {d:'dashboard',s:'students',f:'fees',m:'marks',a:'attendance'};
    const page = navMap[e.key.toLowerCase()];
    if (page) {
      e.preventDefault();
      const navEl = document.getElementById('nav-'+page);
      if (navEl && typeof nav === 'function') nav(page, navEl);
    }
  }
});

// ── 3. SESSION CLOCK ─────────────────────────────────────────
function injectSessionClock() {
  const topbarRight = document.querySelector('.topbar-right');
  if (!topbarRight || document.getElementById('session-clock')) return;
  const clockEl = document.createElement('div');
  clockEl.id = 'session-clock';
  clockEl.innerHTML = '<i class="ti ti-clock" style="font-size:12px"></i><span id="clock-time">--:--</span>';
  topbarRight.insertBefore(clockEl, topbarRight.firstChild);

  function tick() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    const timeEl = document.getElementById('clock-time');
    if (timeEl) timeEl.textContent = h+':'+m;
  }
  tick();
  setInterval(tick, 15000);
}

// ── 4. AUTO-SAVE INDICATOR ───────────────────────────────────
function injectAutoSaveIndicator() {
  const footer = document.querySelector('.sidebar-footer');
  if (!footer || document.getElementById('autosave-wrap')) return;
  const wrap = document.createElement('div');
  wrap.id = 'autosave-wrap';
  wrap.style.cssText = 'display:flex;align-items:center;gap:5px;font-size:10px;color:rgba(255,255,255,0.45);margin-top:7px;padding-top:7px;border-top:1px solid rgba(255,255,255,0.08)';
  wrap.innerHTML = '<div id="autosave-dot"></div><span id="autosave-txt">All changes saved</span>';
  footer.appendChild(wrap);
}

function flashAutosave() {
  const dot = document.getElementById('autosave-dot');
  const txt = document.getElementById('autosave-txt');
  if (!dot || !txt) return;
  dot.classList.add('saving');
  txt.textContent = 'Saving…';
  setTimeout(() => {
    dot.classList.remove('saving');
    txt.textContent = 'All changes saved';
  }, 900);
}

// Patch saveDB to trigger autosave indicator
const _origSaveDB = window.saveDB;
if (typeof _origSaveDB === 'function') {
  window.saveDB = function() {
    _origSaveDB.apply(this, arguments);
    flashAutosave();
  };
}

// ── 5. NAV COUNT BADGES ──────────────────────────────────────
function updateNavBadges() {
  if (typeof DB === 'undefined') return;
  try {
    const term = (DB.settings && DB.settings.term) || 2;
    // Students badge
    const stBadge = document.getElementById('nav-badge-students');
    if (stBadge) stBadge.textContent = DB.students ? DB.students.length : '';

    // Fee alerts badge (outstanding)
    const feeBadge = document.getElementById('nav-badge-fees');
    if (feeBadge && DB.students && typeof getBalance === 'function') {
      const n = DB.students.filter(s => getBalance(s.id, term) > 0).length;
      feeBadge.textContent = n || '';
      feeBadge.className = 'nav-count' + (n > 0 ? ' alert' : '');
      feeBadge.style.display = n > 0 ? '' : 'none';
    }

    // Staff badge
    const sfBadge = document.getElementById('nav-badge-staff');
    if (sfBadge) sfBadge.textContent = DB.staff ? DB.staff.length : '';
  } catch(e) {}
}

function injectNavBadges() {
  const badgeMap = [
    {navId:'nav-students', badgeId:'nav-badge-students'},
    {navId:'nav-fees', badgeId:'nav-badge-fees'},
    {navId:'nav-staff', badgeId:'nav-badge-staff'},
  ];
  badgeMap.forEach(({navId, badgeId}) => {
    const navEl = document.getElementById(navId);
    if (!navEl || document.getElementById(badgeId)) return;
    const badge = document.createElement('span');
    badge.id = badgeId;
    badge.className = 'nav-count';
    badge.style.display = 'none';
    navEl.appendChild(badge);
  });
}

// ── 6. BACK TO TOP ───────────────────────────────────────────
function initBackToTop() {
  const content = document.querySelector('.content');
  const btn = document.getElementById('back-to-top');
  if (!content || !btn) return;
  content.addEventListener('scroll', function() {
    btn.classList.toggle('visible', content.scrollTop > 250);
  }, {passive: true});
}

// ── 7. FEE PROGRESS DASHBOARD WIDGET ────────────────────────
function injectFeeWidget() {
  const dashPage = document.getElementById('page-dashboard');
  if (!dashPage || document.getElementById('dash-fee-widget')) return;
  const widget = document.createElement('div');
  widget.id = 'dash-fee-widget';
  widget.className = 'dash-fee-widget';
  widget.innerHTML = `
    <div class="fw-label">Term Fee Collection</div>
    <div class="fw-pct" id="fw-pct">—%</div>
    <div class="fw-sub" id="fw-sub">Loading…</div>
    <div class="fw-bar-track"><div class="fw-bar-fill" id="fw-bar" style="width:0%"></div></div>
    <div class="fw-stats">
      <div class="fw-stat"><div class="fw-stat-val" id="fw-exp">—</div><div class="fw-stat-lbl">Expected</div></div>
      <div class="fw-stat"><div class="fw-stat-val" id="fw-col">—</div><div class="fw-stat-lbl">Collected</div></div>
      <div class="fw-stat"><div class="fw-stat-val" id="fw-out">—</div><div class="fw-stat-lbl">Outstanding</div></div>
    </div>`;
  // Insert as first child after metrics grid
  const metricsGrid = dashPage.querySelector('.g4');
  if (metricsGrid) metricsGrid.insertAdjacentElement('afterend', widget);
}

function updateFeeWidget() {
  if (typeof DB === 'undefined' || !DB.students) return;
  try {
    const t = (DB.settings && DB.settings.term) || 2;
    const exp = DB.students.reduce((a,s)=>a+(typeof getTotalOwed==='function'?getTotalOwed(s.id,t):0),0);
    const col = DB.students.reduce((a,s)=>a+(typeof getTotalPaid==='function'?getTotalPaid(s.id,t):0),0);
    const out = Math.max(0,exp-col);
    const pct = exp>0 ? Math.round(col/exp*100) : 0;
    const fmtVal = v => typeof fmt==='function' ? fmt(v) : v.toLocaleString();
    const el = id => document.getElementById(id);
    if(el('fw-pct')) el('fw-pct').textContent = pct+'%';
    if(el('fw-sub')) el('fw-sub').textContent = `Term ${t} · ${pct}% collected`;
    if(el('fw-bar')) el('fw-bar').style.width = Math.min(100,pct)+'%';
    if(el('fw-exp')) el('fw-exp').textContent = 'UGX '+fmtVal(exp);
    if(el('fw-col')) el('fw-col').textContent = 'UGX '+fmtVal(col);
    if(el('fw-out')) el('fw-out').textContent = 'UGX '+fmtVal(out);
  } catch(e){}
}

// ── 8. TODAY'S SUMMARY STRIP ─────────────────────────────────
function injectTodayStrip() {
  const dashPage = document.getElementById('page-dashboard');
  if (!dashPage || document.getElementById('today-strip')) return;
  const strip = document.createElement('div');
  strip.id = 'today-strip';
  strip.className = 'today-strip';
  dashPage.insertBefore(strip, dashPage.firstChild);
  updateTodayStrip();
}

function updateTodayStrip() {
  const strip = document.getElementById('today-strip');
  if (!strip || typeof DB === 'undefined') return;
  try {
    const now = new Date();
    const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const dateStr = `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
    const term = (DB.settings && DB.settings.term) || 2;
    const year = (DB.settings && DB.settings.year) || now.getFullYear();
    const totalStudents = (DB.students && DB.students.length) || 0;
    const boarders = DB.students ? DB.students.filter(s=>s.brd==='boarding').length : 0;
    const totalStaff = (DB.staff && DB.staff.length) || 0;

    // Today's attendance rate
    const todayKey = typeof today==='function' ? today() : now.toISOString().slice(0,10);
    const todayAtt = (DB.attendance && DB.attendance[todayKey]) ? DB.attendance[todayKey] : {};
    const attRecs = Object.values(todayAtt).filter(v=>['P','A','L'].includes(v));
    const attPct = attRecs.length ? Math.round(attRecs.filter(v=>v==='P').length/attRecs.length*100) : null;

    strip.innerHTML = `
      <div class="today-strip-item"><i class="ti ti-calendar"></i><span>${dateStr}</span></div>
      <div class="today-strip-divider"></div>
      <div class="today-strip-item"><i class="ti ti-users"></i><span><strong>${totalStudents}</strong> Students</span></div>
      <div class="today-strip-item"><i class="ti ti-home"></i><span><strong>${boarders}</strong> Boarders</span></div>
      <div class="today-strip-divider"></div>
      <div class="today-strip-item"><i class="ti ti-id"></i><span><strong>${totalStaff}</strong> Staff</span></div>
      <div class="today-strip-divider"></div>
      <div class="today-strip-item"><i class="ti ti-calendar-check"></i><span>Today's Attendance: <strong>${attPct !== null ? attPct+'%' : '—'}</strong></span></div>
      <div class="today-strip-divider"></div>
      <div class="today-strip-item"><i class="ti ti-school"></i><span>Term <strong>${term}</strong> · <strong>${year}</strong></span></div>`;
  } catch(e){}
}

// ── 9. IMPROVE QUICK ACTIONS (replace inline buttons with grid) ─
function upgradeQuickActions() {
  const qaBtnArea = document.querySelector('#page-dashboard .card div[style*="gap:8px"]');
  if (!qaBtnArea || qaBtnArea.classList.contains('qa-upgraded')) return;
  qaBtnArea.classList.add('qa-upgraded', 'qa-grid');
  qaBtnArea.style.cssText = '';
  // Replace existing buttons' styling
  qaBtnArea.querySelectorAll('.btn').forEach(btn => {
    btn.classList.add('qa-btn');
    btn.classList.remove('btn-primary','btn-success','btn-sm');
    // Make icon bigger and wrap text
    btn.style.cssText = '';
  });
}

// ── 10. MOBILE SIDEBAR TOGGLE ────────────────────────────────
function initMobileSidebar() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  if (!sidebar || !overlay) return;

  // Override toggleSidebar for mobile
  const _origToggle = window.toggleSidebar;
  window.toggleSidebar = function() {
    if (window.innerWidth <= 700) {
      sidebar.classList.toggle('mobile-open');
      overlay.classList.toggle('open');
    } else {
      if (_origToggle) _origToggle();
    }
  };
}

window.closeMobileSidebar = function() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  if (sidebar) sidebar.classList.remove('mobile-open');
  if (overlay) overlay.classList.remove('open');
};

// ── 11. QUICK ACTIONS: Add "Print Receipt" shortcut ──────────
function addPrintReceiptQuickAction() {
  const qaArea = document.querySelector('#page-dashboard .card div[style*="gap:8px"]');
  if (!qaArea || document.getElementById('qa-print-receipt')) return;
  const btn = document.createElement('button');
  btn.id = 'qa-print-receipt';
  btn.className = 'btn btn-sm';
  btn.innerHTML = '<i class="ti ti-receipt"></i>Print Receipt';
  btn.onclick = function() {
    if (typeof nav==='function') nav('fees', document.getElementById('nav-fees'));
    if (typeof openPayment==='function') setTimeout(openPayment, 100);
  };
  qaArea.appendChild(btn);
}

// ── 12. PATCH renderDashboard TO UPDATE NEW WIDGETS ──────────
const _origRenderDashboard = window.renderDashboard;
window.renderDashboard = function() {
  if (_origRenderDashboard) _origRenderDashboard.apply(this, arguments);
  setTimeout(() => {
    updateFeeWidget();
    updateTodayStrip();
    updateNavBadges();
  }, 120);
};

// ── 13. TERM PROGRESS BAR IN SIDEBAR ─────────────────────────
function injectTermProgress() {
  const termLabel = document.getElementById('sb-term-label');
  if (!termLabel || termLabel.parentElement.querySelector('.term-progress-bar')) return;
  const bar = document.createElement('div');
  bar.className = 'term-progress-bar';
  bar.innerHTML = '<div class="term-progress-fill" id="sb-term-prog" style="width:33%"></div>';
  termLabel.insertAdjacentElement('afterend', bar);

  // Estimate term progress (each term ~12 weeks)
  function updateTermProg() {
    if (typeof DB === 'undefined') return;
    const fill = document.getElementById('sb-term-prog');
    if (!fill) return;
    const term = (DB.settings && DB.settings.term) || 2;
    // Rough progress based on attendance data density
    const keys = Object.keys(DB.attendance || {}).sort();
    const pct = keys.length > 0 ? Math.min(95, Math.round((keys.length / 60) * 100)) : (term - 1) * 33;
    fill.style.width = Math.max(5, pct) + '%';
  }
  setTimeout(updateTermProg, 500);
}

// ── 14. IMPROVED WATERMARK ────────────────────────────────────
function updateWatermark() {
  const wm = document.querySelector('.watermark');
  if (wm) wm.textContent = 'SchoolMS Uganda v1.0 · WKJSoftwares · Wellborn Keys Junior';
}

// ── 15. DARK MODE QUICK TOGGLE ────────────────────────────────
function injectDarkToggle() {
  const topbarRight = document.querySelector('.topbar-right');
  if (!topbarRight || document.getElementById('dark-toggle')) return;
  const btn = document.createElement('button');
  btn.id = 'dark-toggle';
  btn.title = 'Toggle Night Mode';
  btn.innerHTML = '<i class="ti ti-moon"></i>';
  btn.onclick = function() {
    const current = document.documentElement.getAttribute('data-theme') || '';
    if (current === 'night') {
      const saved = localStorage.getItem('sms_prev_theme') || 'default';
      const swatch = document.querySelector('.theme-swatch[title="Forest"]') || document.querySelectorAll('.theme-swatch')[0];
      if (typeof setTheme === 'function') setTheme(saved, swatch);
      btn.innerHTML = '<i class="ti ti-moon"></i>';
    } else {
      localStorage.setItem('sms_prev_theme', current || 'default');
      const nightSwatch = document.querySelector('.theme-swatch[title="Night"]') || document.querySelectorAll('.theme-swatch')[3];
      if (typeof setTheme === 'function') setTheme('night', nightSwatch);
      btn.innerHTML = '<i class="ti ti-sun"></i>';
    }
  };
  // Insert after search button
  const searchBtn = topbarRight.querySelector('button');
  if (searchBtn) searchBtn.insertAdjacentElement('afterend', btn);
  else topbarRight.insertBefore(btn, topbarRight.firstChild);

  // Sync button icon with current theme
  if ((document.documentElement.getAttribute('data-theme')||'') === 'night') {
    btn.innerHTML = '<i class="ti ti-sun"></i>';
  }
}

// ── 16. PERIODIC BADGE UPDATE ─────────────────────────────────
let _badgeUpdateInterval = null;
function startPeriodicUpdates() {
  if (_badgeUpdateInterval) return;
  _badgeUpdateInterval = setInterval(() => {
    updateNavBadges();
  }, 60000); // every minute
}

// ── 17. PATCH SAVE FUNCTIONS TO UPDATE BADGES ─────────────────
// After any save, refresh badges
const _origSaveStudent = window.saveStudent;
if (typeof _origSaveStudent === 'function') {
  window.saveStudent = function() {
    _origSaveStudent.apply(this, arguments);
    setTimeout(updateNavBadges, 200);
  };
}

// ── 18. INITIALIZE ALL IMPROVEMENTS ──────────────────────────
function initV33Improvements() {
  injectSessionClock();
  injectAutoSaveIndicator();
  injectNavBadges();
  injectTodayStrip();
  initBackToTop();
  initMobileSidebar();
  injectDarkToggle();
  injectTermProgress();
  updateWatermark();
  updateNavBadges();
  updateTodayStrip();
  startPeriodicUpdates();

  // Fix settings tab sync log clear button to use renamed ID
  const syncLogClearSt = document.querySelector('[onclick="document.getElementById(\'sync-log\').innerHTML=\'\'"]');
  if (syncLogClearSt && syncLogClearSt.closest('#st-sync')) {
    syncLogClearSt.setAttribute('onclick', "document.getElementById('sync-log-st').innerHTML=''");
  }
}

// Run on load (wait for app to be ready)
if (document.readyState === 'complete') {
  initV33Improvements();
} else {
  window.addEventListener('load', initV33Improvements);
}

// Also re-run on nav to keep badges updated
const _origNavPatch = window.nav;
if (typeof _origNavPatch === 'function') {
  window.nav = function(page, el) {
    _origNavPatch.apply(this, arguments);
    setTimeout(updateNavBadges, 150);
    if (page === 'dashboard') setTimeout(() => { updateTodayStrip(); }, 200);
    if (window.innerWidth <= 700) closeMobileSidebar();
  };
}

// ── A. MARK ALL ATTENDANCE ───────────────────────────────────
window.markAllAttendance = function(status) {
  document.querySelectorAll('#att-rows select[id^="att-s-"]').forEach(sel => {
    sel.value = status;
    sel.dispatchEvent(new Event('change'));
  });
  updateAttSummaryBar();
  if (typeof toast === 'function') toast('All students marked as ' + (status==='P'?'Present':'Absent'), 'info', 2000);
};

function updateAttSummaryBar() {
  const rows = document.querySelectorAll('#att-rows select[id^="att-s-"]');
  if (!rows.length) return;
  const bar = document.getElementById('att-summary-bar');
  const total = rows.length;
  let p = 0, a = 0, l = 0;
  rows.forEach(sel => {
    if (sel.value === 'P') p++;
    else if (sel.value === 'A') a++;
    else if (sel.value === 'L') l++;
  });
  const pct = total > 0 ? Math.round(p/total*100) : 0;
  if (bar) {
    bar.style.display = 'flex';
    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
    set('att-count-total', total);
    set('att-count-p', p);
    set('att-count-a', a);
    set('att-count-l', l);
    set('att-count-pct', pct + '%');
  }
}

// Patch renderAttendance to update summary bar after render
const _origRenderAtt = window.renderAttendance;
if (typeof _origRenderAtt === 'function') {
  window.renderAttendance = function() {
    _origRenderAtt.apply(this, arguments);
    setTimeout(updateAttSummaryBar, 100);
  };
}

// ── B. STUDENT COUNT BADGE ────────────────────────────────────
const _origRenderStudents = window.renderStudents;
if (typeof _origRenderStudents === 'function') {
  window.renderStudents = function() {
    _origRenderStudents.apply(this, arguments);
    // Update count badge
    const badge = document.getElementById('st-count-badge');
    if (badge) {
      const rows = document.querySelectorAll('#st-rows tr');
      const n = rows.length;
      const isEmpty = document.querySelector('#st-rows td[colspan]');
      badge.textContent = isEmpty ? '' : n + ' student' + (n !== 1 ? 's' : '') + ' shown';
    }
  };
}

// ── C. MARKS PAGE: CLASS AVERAGE ROW ─────────────────────────
const _origSaveMarks = window.saveMarks;
if (typeof _origSaveMarks === 'function') {
  window.saveMarks = function() {
    _origSaveMarks.apply(this, arguments);
    updateNavBadges();
  };
}

// Inject class average footer into marks table after render
const _origRenderMarks = window.renderMarks;
if (typeof _origRenderMarks === 'function') {
  window.renderMarks = function() {
    _origRenderMarks.apply(this, arguments);
    setTimeout(injectMarksAvgRow, 100);
  };
}

function injectMarksAvgRow() {
  const rows = document.querySelectorAll('#mk-rows tr');
  if (!rows.length) return;
  const table = document.getElementById('mk-table');
  if (!table) return;
  // Remove previous avg footer if any
  const old = table.querySelector('tfoot.avg-footer');
  if (old) old.remove();
  // Collect numeric totals
  const totals = [];
  rows.forEach(row => {
    const cells = row.querySelectorAll('td');
    if (cells.length >= 7) {
      const totalText = cells[5] ? cells[5].textContent.trim() : '';
      const n = parseFloat(totalText);
      if (!isNaN(n)) totals.push(n);
    }
  });
  if (!totals.length) return;
  const avg = (totals.reduce((a, b) => a + b, 0) / totals.length).toFixed(1);
  const max = Math.max(...totals).toFixed(1);
  const min = Math.min(...totals).toFixed(1);
  const tf = document.createElement('tfoot');
  tf.className = 'avg-footer';
  tf.innerHTML = `<tr style="background:var(--primary-light);font-weight:700;border-top:2px solid var(--border)">
    <td colspan="5" style="padding:8px 12px;font-size:12px;color:var(--primary)">
      <i class="ti ti-chart-bar" style="margin-right:4px"></i>Class Stats — ${totals.length} students
    </td>
    <td style="padding:8px 12px;color:var(--primary)">Avg: ${avg}</td>
    <td colspan="2" style="padding:8px 12px;font-size:11px;color:var(--text2)">
      High: ${max} &nbsp;·&nbsp; Low: ${min}
    </td>
  </tr>`;
  table.appendChild(tf);
}

// ── D. EXPENSES SUMMARY: ENHANCED CHART ──────────────────────
const _origExpSummary = window.renderExpSummary;
if (typeof _origExpSummary === 'function') {
  window.renderExpSummary = function() {
    _origExpSummary.apply(this, arguments);
    setTimeout(injectExpensesChart, 150);
  };
}

function injectExpensesChart() {
  const el = document.getElementById('exp-summary-content');
  if (!el || !el.children.length || typeof DB === 'undefined') return;
  if (el.querySelector('#exp-chart-canvas')) return;

  // Build category totals
  const catTotals = {};
  (DB.expenses || []).forEach(e => {
    const cat = e.category || 'Other';
    catTotals[cat] = (catTotals[cat] || 0) + (e.amount || 0);
  });
  const sorted = Object.entries(catTotals).sort((a, b) => b[1] - a[1]);
  if (!sorted.length) return;

  const wrap = document.createElement('div');
  wrap.className = 'card';
  wrap.style.cssText = 'padding:16px;margin-top:14px';
  wrap.innerHTML = `<div class="section-hd">Expenses by Category</div>
    <div class="chart-wrap" style="height:180px"><canvas id="exp-chart-canvas"></canvas></div>`;
  el.appendChild(wrap);

  try {
    if (typeof Chart !== 'undefined') {
      new Chart(document.getElementById('exp-chart-canvas'), {
        type: 'doughnut',
        data: {
          labels: sorted.map(([k]) => k),
          datasets: [{
            data: sorted.map(([, v]) => v),
            backgroundColor: ['#1e4d35','#c8873a','#1a56db','#c0392b','#1e6b45','#d97706','#7c3aed','#0891b2','#374151','#ef4444'],
            borderWidth: 0,
            hoverOffset: 6
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false, cutout: '65%',
          plugins: {
            legend: { position: 'right', labels: { font: { size: 11 }, padding: 10 } },
            tooltip: { callbacks: { label: ctx => ctx.label + ': UGX ' + ctx.raw.toLocaleString() } }
          }
        }
      });
    }
  } catch(e) {}
}

// ── E. RECEIPT COPY TO CLIPBOARD ─────────────────────────────
// Patch showReceipt to add a copy button
const _origShowReceipt = window.showReceipt;
if (typeof _origShowReceipt === 'function') {
  window.showReceipt = function() {
    _origShowReceipt.apply(this, arguments);
    setTimeout(() => {
      const overlay = document.getElementById('receipt-overlay');
      if (!overlay) return;
      const actions = overlay.querySelector('div[style*="display:flex"]');
      if (!actions || actions.querySelector('.copy-receipt-btn')) return;
      const copyBtn = document.createElement('button');
      copyBtn.className = 'btn btn-sm copy-receipt-btn';
      copyBtn.innerHTML = '<i class="ti ti-copy"></i>Copy';
      copyBtn.onclick = function() {
        const paper = document.getElementById('receipt-content');
        if (!paper) return;
        navigator.clipboard?.writeText(paper.innerText)
          .then(() => { if (typeof toast === 'function') toast('Receipt text copied!', 'success', 2000); })
          .catch(() => {});
      };
      actions.appendChild(copyBtn);
    }, 100);
  };
}

// ── F. FEES LEDGER: PER-CLASS STATS IN TOOLBAR ───────────────
const _origRenderFees = window.renderFees;
if (typeof _origRenderFees === 'function') {
  window.renderFees = function() {
    _origRenderFees.apply(this, arguments);
    setTimeout(updateFeeClassStats, 100);
  };
}

function updateFeeClassStats() {
  if (typeof DB === 'undefined') return;
  const cls = document.getElementById('fee-filter-class')?.value;
  const termVal = document.getElementById('fee-filter-term')?.value;
  if (!cls) return; // only show when a class is selected

  const term = termVal === 'all' ? null : +termVal;
  const students = DB.students.filter(s => s.cls === cls);
  if (!students.length) return;

  const paid = students.reduce((a, s) => a + (term ? getTotalPaid(s.id, term) : [1,2,3].reduce((x,t)=>x+getTotalPaid(s.id,t),0)), 0);
  const owed = students.reduce((a, s) => a + (term ? getTotalOwed(s.id, term) : [1,2,3].reduce((x,t)=>x+getTotalOwed(s.id,t),0)), 0);
  const pct = owed > 0 ? Math.round(paid/owed*100) : 100;
  const debtors = students.filter(s => (term ? getBalance(s.id, term) : [1,2,3].reduce((x,t)=>x+getBalance(s.id,t),0)) > 0).length;

  // Show/update class stats chip near toolbar
  let statsEl = document.getElementById('fee-class-stats');
  if (!statsEl) {
    statsEl = document.createElement('div');
    statsEl.id = 'fee-class-stats';
    statsEl.style.cssText = 'display:flex;gap:10px;font-size:12px;padding:6px 12px;background:var(--primary-light);border-radius:var(--radius);border:1px solid color-mix(in srgb,var(--primary) 20%,var(--border));align-items:center;flex-wrap:wrap;margin-bottom:10px';
    const ledgerPanel = document.getElementById('ft-ledger');
    const toolbar = ledgerPanel?.querySelector('.toolbar');
    if (toolbar) toolbar.insertAdjacentElement('afterend', statsEl);
  }
  statsEl.style.display = 'flex';
  statsEl.innerHTML = `<span style="color:var(--primary);font-weight:700">${cls}</span>
    <span>·</span>
    <span>${students.length} students</span>
    <span style="color:var(--success)">✅ ${pct}% collected</span>
    <span style="color:var(--danger)">⚠️ ${debtors} with balance</span>
    <span style="color:var(--text3)">UGX ${typeof fmt==='function'?fmt(paid):paid.toLocaleString()} / ${typeof fmt==='function'?fmt(owed):owed.toLocaleString()}</span>`;
}

// ── G. EXPENSE LEDGER: RUNNING TOTAL IN TABLE ────────────────
const _origRenderExpenses = window.renderExpenses;
if (typeof _origRenderExpenses === 'function') {
  window.renderExpenses = function() {
    _origRenderExpenses.apply(this, arguments);
    setTimeout(injectExpRunningTotal, 100);
  };
}

function injectExpRunningTotal() {
  const tbody = document.getElementById('exp-rows');
  if (!tbody) return;
  const table = tbody.closest('table');
  if (!table) return;
  // Remove old tfoot
  const old = table.querySelector('tfoot.exp-total-foot');
  if (old) old.remove();
  const rows = tbody.querySelectorAll('tr');
  let total = 0;
  rows.forEach(row => {
    const cells = row.querySelectorAll('td');
    if (cells.length >= 5) {
      const amtText = cells[4] ? cells[4].textContent.replace(/,/g,'').trim() : '';
      const n = parseFloat(amtText);
      if (!isNaN(n)) total += n;
    }
  });
  if (!rows.length || rows[0].querySelector('td[colspan]')) return;
  const tf = document.createElement('tfoot');
  tf.className = 'exp-total-foot';
  tf.innerHTML = `<tr style="background:var(--danger-light);font-weight:700;border-top:2px solid var(--border)">
    <td colspan="4" style="padding:8px 12px;font-size:12px;color:var(--danger)">
      <i class="ti ti-sum" style="margin-right:4px"></i>Filtered Total (${rows.length} records)
    </td>
    <td style="padding:8px 12px;color:var(--danger);font-size:13px">UGX ${total.toLocaleString()}</td>
    <td colspan="3"></td>
  </tr>`;
  table.appendChild(tf);
}

// ── H. ACTIVITY LOG: ADD TIMESTAMP TO MARKS/FEES SAVES ──────
function _logActivity(msg) {
  if (typeof DB === 'undefined' || !DB.activities) return;
  DB.activities.unshift({ msg, time: new Date().toLocaleString('en-UG', {dateStyle:'short', timeStyle:'short'}) });
  if (DB.activities.length > 30) DB.activities.pop();
}

// ── I. ATTENDANCE SUMMARY BAR: UPDATE ON CHANGE ──────────────
document.addEventListener('change', function(e) {
  if (e.target?.id?.startsWith('att-s-')) {
    updateAttSummaryBar();
  }
});

// ── J. STUDENT TABLE: WHATSAPP QUICK CONTACT ─────────────────
const _v33OrigRenderStudents2 = window.renderStudents;
if (typeof _v33OrigRenderStudents2 === 'function') {
  window.renderStudents = function() {
    _v33OrigRenderStudents2.apply(this, arguments);
    // Inject WhatsApp quick contact buttons where phone is present
    document.querySelectorAll('#st-rows td').forEach(td => {
      const text = td.textContent.trim();
      if (/^\+?256/.test(text) && !td.querySelector('a')) {
        const clean = text.replace(/[^0-9+]/g,'');
        const original = td.innerHTML;
        td.innerHTML = `<span>${original}</span> <a href="https://wa.me/${clean}" target="_blank" style="color:#25d366;font-size:13px;text-decoration:none" title="WhatsApp ${text}"><i class="ti ti-brand-whatsapp"></i></a>`;
      }
    });
  };
}

// ── K. FEES PAGE: HIDE CLASS STATS WHEN NO CLASS SELECTED ────
document.addEventListener('change', function(e) {
  if (e.target?.id === 'fee-filter-class' && !e.target.value) {
    const el = document.getElementById('fee-class-stats');
    if (el) el.style.display = 'none';
  }
});

})(); // end v1.0 improvements
</script>
