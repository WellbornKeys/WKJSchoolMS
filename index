function renderBursaryTab() {
  const termFilter = document.getElementById('bursary-term-filter')?.value;
  const panel = document.getElementById('bursary-list-panel');
  if (!panel) return;
  const bursaries = (DB.bursaries||[]).filter(b=>
    !termFilter || (b.termScope||[]).includes(+termFilter)
  );
  if (!bursaries.length) {
    panel.innerHTML = '<div class="empty" style="padding:20px"><i class="ti ti-school"></i><p>No bursaries match the filter. Click "New Bursary" to create one.</p></div>';
    return;
  }
  panel.innerHTML = bursaries.map(b=>{
    const stuCount = (b.students||[]).length;
    const terms = (b.termScope||[]).map(t=>'T'+t).join(', ');
    const typeBadge = b.type==='full'
      ? `<span class="badge badge-success" style="font-size:10px">FULL</span>`
      : `<span class="badge badge-warning" style="font-size:10px">PARTIAL</span>`;
    const exemptSummary = b.type==='partial' ? (() => {
      const parts = [];
      if ((b.exemptFeeIds?.rec||[]).length) parts.push(`${b.exemptFeeIds.rec.length} recurring`);
      if ((b.exemptFeeIds?.other||[]).length) parts.push(`${b.exemptFeeIds.other.length} other fees`);
      if ((b.exemptFeeIds?.opt||[]).length) parts.push(`${b.exemptFeeIds.other.length} optional`);
      return parts.length ? `<span style="font-size:11px;color:var(--text3)">Exempts: ${parts.join(', ')}</span>` : '';
    })() : '<span style="font-size:11px;color:var(--text3)">All recurring &amp; other fees waived</span>';
    return `<div style="background:var(--surface2);border:1px solid #ede9fe;border-radius:var(--radius);padding:10px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
      <div style="flex:1;min-width:200px">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px">
          <span style="font-weight:700;font-size:13px">${b.name}</span>
          ${typeBadge}
          <span style="font-size:11px;color:var(--text3)">${terms}</span>
        </div>
        ${exemptSummary}
        ${b.note ? `<div style="font-size:11px;color:var(--text3);margin-top:2px">📌 ${b.note}</div>` : ''}
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-size:22px;font-weight:700;color:#7c3aed">${stuCount}</div>
        <div style="font-size:10.5px;color:var(--text3)">student${stuCount!==1?'s':''}</div>
      </div>
      <button class="btn btn-sm" style="border-color:#7c3aed;color:#7c3aed" onclick="openBursaryEditor('${b.id}')"><i class="ti ti-edit"></i>Edit</button>
    </div>`;
  }).join('');

  // Also refresh the recipient picker dropdown
  populateBursaryFilters();
  renderBursaryRecipients();
}

function renderBursaryRecipients() {
  const bId = document.getElementById('bursary-view-filter')?.value;
  const term = +(document.getElementById('bursary-term-view')?.value || DB.settings.term || 2);
  const panel = document.getElementById('bursary-recipients-panel');
  if (!panel) return;

  let students = DB.students.slice();
  let filterLabel = 'All Bursaries';

  if (bId) {
    const b = (DB.bursaries||[]).find(x=>x.id===bId);
    if (!b) { panel.innerHTML = '<div class="empty"><p>Bursary not found.</p></div>'; return; }
    // Only show students on this bursary that have it active for the selected term
    if (!(b.termScope||[]).includes(term)) {
      panel.innerHTML = `<div class="alert-box warning"><i class="ti ti-info-circle"></i> "${b.name}" does not apply to Term ${term}. Select a different term.</div>`;
      return;
    }
    students = students.filter(s=>(b.students||[]).includes(s.id));
    filterLabel = b.name;
  } else {
    // Show all students on ANY bursary active this term
    const activeBursaryStudentIds = new Set();
    (DB.bursaries||[]).forEach(b=>{
      if ((b.termScope||[]).includes(term)) (b.students||[]).forEach(id=>activeBursaryStudentIds.add(id));
    });
    students = students.filter(s=>activeBursaryStudentIds.has(s.id));
  }

  if (!students.length) {
    panel.innerHTML = `<div class="empty"><i class="ti ti-users"></i><p>No students on ${filterLabel} for Term ${term}.</p></div>`;
    return;
  }

  const rows = students.map(s=>{
    const studentBursaries = (DB.bursaries||[]).filter(b=>
      (b.students||[]).includes(s.id) && (b.termScope||[]).includes(term)
    );
    const bursaryBadges = studentBursaries.map(b=>
      `<span class="badge ${b.type==='full'?'badge-success':'badge-warning'}" style="font-size:10px;margin-right:2px">${b.name}</span>`
    ).join('');
    const discount = getBursaryRecurringDiscount(s.id, term);
    const optFees = getStudentOtherTotal(s.id, term);
    const termFee = getTermFeeTotal(s.id, term);
    return `<tr>
      <td><strong>${s.adm}</strong></td>
      <td>${s.fn} ${s.ln}</td>
      <td><span class="badge badge-info">${s.cls}</span></td>
      <td>${bursaryBadges}</td>
      <td style="color:var(--success);font-weight:600">${discount>0?'UGX '+fmt(discount):'—'}</td>
      <td style="font-size:11.5px;color:#7c3aed">${optFees>0?'UGX '+fmt(optFees):'—'}</td>
      <td><strong>UGX ${fmt(termFee)}</strong></td>
    </tr>`;
  }).join('');

  panel.innerHTML = `<table style="width:100%">
    <thead><tr><th>Adm No.</th><th>Student</th><th>Class</th><th>Bursary</th><th>Discount (UGX)</th><th>Other Fees</th><th>Net Term Fee</th></tr></thead>
    <tbody>${rows}</tbody>
    <tfoot><tr style="border-top:2px solid var(--border)">
      <td colspan="6" style="font-weight:700;padding-top:8px">Total students: ${students.length}</td>
      <td style="font-weight:700;color:var(--primary);padding-top:8px">UGX ${fmt(students.reduce((s,st)=>s+getTermFeeTotal(st.id,term),0))}</td>
    </tr></tfoot>
  </table>`;
}

function openBursaryEditor(bId) {
  // Populate class filter in student picker
  const classSel = document.getElementById('bursary-student-class-filter');
  if (classSel) classSel.innerHTML = '<option value="">All Classes</option>' + DB.classes.map(c=>`<option>${c}</option>`).join('');

  const b = bId ? (DB.bursaries||[]).find(x=>x.id===bId) : null;
  document.getElementById('bursary-modal-title').textContent = b ? '🎓 Edit Bursary' : '🎓 New Bursary';
  document.getElementById('bursary-edit-id').value = b ? b.id : '';
  document.getElementById('bursary-name').value = b ? b.name : '';
  document.getElementById('bursary-type').value = b ? b.type : 'full';
  document.getElementById('bursary-note').value = b ? (b.note||'') : '';
  document.getElementById('bursary-delete-btn').style.display = b ? '' : 'none';
  document.getElementById('bursary-t1').checked = b ? (b.termScope||[]).includes(1) : false;
  document.getElementById('bursary-t2').checked = b ? (b.termScope||[]).includes(2) : true;
  document.getElementById('bursary-t3').checked = b ? (b.termScope||[]).includes(3) : false;

  // Populate exemptions checkboxes
  populateBursaryExemptionPanels(b);
  onBursaryTypeChange();

  // Student picker
  window._bursarySelectedStudents = new Set((b ? b.students : []) || []);
  renderBursaryStudentPicker();

  openM('m-bursary-editor');
}

function populateBursaryExemptionPanels(b) {
  const recEl = document.getElementById('bursary-exempt-rec');
  const optEl = document.getElementById('bursary-exempt-other');
  const exemptRec = (b?.exemptFeeIds?.rec)||[];
  const exemptOpt = (b?.exemptFeeIds?.other)||[];

  recEl.innerHTML = (DB.recurringFees||[]).length
    ? (DB.recurringFees||[]).map(f=>`
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;margin-bottom:4px;font-weight:400">
          <input type="checkbox" id="bex-rec-${f.id}" ${exemptRec.includes(f.id)?'checked':''}>
          ${f.name}
        </label>`).join('')
    : '<span style="font-size:11px;color:var(--text3)">None defined</span>';

  optEl.innerHTML = (DB.otherFees||[]).length
    ? (DB.otherFees||[]).map(f=>`
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;margin-bottom:4px;font-weight:400">
          <input type="checkbox" id="bex-other-${f.id}" ${exemptOpt.includes(f.id)?'checked':''}>
          ${f.name}
        </label>`).join('')
    : '<span style="font-size:11px;color:var(--text3)">None defined</span>';
