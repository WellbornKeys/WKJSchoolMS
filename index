function doLogin() {
  const u = document.getElementById('li-user').value.trim();
  const p = document.getElementById('li-pass').value;
  const errEl = document.getElementById('li-err');
  const loginBtn = document.querySelector('.login-screen .btn-primary');

  // Show loading state
  if (loginBtn) { loginBtn.disabled = true; loginBtn.innerHTML = '<i class="ti ti-loader-2" style="animation:spin 0.7s linear infinite"></i> Signing in…'; }

  const user = DB.users.find(x=>x.username===u&&x.password===p);
  if (!user) {
    errEl.textContent='Invalid username or password.'; errEl.style.display='';
    if (loginBtn) { loginBtn.disabled=false; loginBtn.innerHTML='<i class="ti ti-login"></i>Sign In'; }
    return;
  }

  // STRICT LICENSE GATE
  const lic = DB.license || {};
  const hasKey = lic.key && lic.key.trim() !== '';
  const notExpired = lic.expires && lic.expires >= today(); // date-only, no status flag
  if (!hasKey || !notExpired) {
    errEl.innerHTML = '🔐 No valid license. Please activate a license in the <strong>License</strong> tab first.<br><span style="font-size:11px;color:var(--text3)">Your data is safe — a valid license is needed to access it.</span>';
    errEl.style.display = '';
    if (loginBtn) { loginBtn.disabled=false; loginBtn.innerHTML='<i class="ti ti-login"></i>Sign In'; }
    switchToLicenseTab();
    return;
  }

  // Remember me on trusted device
  if (document.getElementById('li-remember')?.checked) {
    localStorage.setItem('sms_trusted_user_v1', JSON.stringify({username:u, ts:Date.now()}));
  }

  currentUser = user;
  // Update last login
  const ui = DB.users.findIndex(x=>x.id===user.id);
  if (ui>=0) DB.users[ui].lastLogin = new Date().toLocaleString('en-UG');
  saveDB();
  errEl.style.display = 'none';
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'flex';
  if (loginBtn) { loginBtn.disabled=false; loginBtn.innerHTML='<i class="ti ti-login"></i>Sign In'; }
  applyRoleAccess();
  updateTopbarInfo();
  renderDashboard();
  checkOnlineStatus();
  scheduleAutoBackup(); // start 24-h backup cycle on login
}

