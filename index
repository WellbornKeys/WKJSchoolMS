function checkBirthdayReminders() {
  const today = new Date();
  const todayMD = String(today.getMonth()+1).padStart(2,'0')+'-'+String(today.getDate()).padStart(2,'0');
  const upcoming7 = [];

  DB.students.forEach(s=>{
    if (!s.dob) return;
    const dob = new Date(s.dob);
    const dobMD = String(dob.getMonth()+1).padStart(2,'0')+'-'+String(dob.getDate()).padStart(2,'0');
    if (dobMD === todayMD) {
      addNotification(`🎂 Birthday today: ${s.fn} ${s.ln} (${s.cls})`, 'success', false);
    } else {
      // Check next 7 days
      for (let i=1;i<=7;i++) {
        const d = new Date(today); d.setDate(d.getDate()+i);
        const dMD = String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
        if (dobMD === dMD) {
          upcoming7.push({name:`${s.fn} ${s.ln}`, cls:s.cls, days:i});
          break;
        }
      }
    }
  });

  if (upcoming7.length) {
    const names = upcoming7.slice(0,3).map(x=>`${x.name} (${x.days}d)`).join(', ');
    addNotification(`🎂 Upcoming birthdays: ${names}${upcoming7.length>3?` +${upcoming7.length-3} more`:''}`, 'info', false);
  }
}

