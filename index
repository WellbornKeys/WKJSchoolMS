function openEditUser(id) {
  const u = DB.users.find(x=>x.id===id); if(!u) return;
  _editUserId = id;
  document.getElementById('m-user-title').textContent = 'Edit User: '+u.username;
  document.getElementById('u-save-label').textContent = 'Save Changes';
  document.getElementById('u-pass-hint').textContent = '(leave blank to keep current)';
  document.getElementById('u-name').value = u.name||'';
  document.getElementById('u-user').value = u.username;
  document.getElementById('u-pass').value = '';
  document.getElementById('u-role').value = u.role;
  openM('m-user');
}

function saveUser() {
  const username = document.getElementById('u-user').value.trim();
  const pass = document.getElementById('u-pass').value;
  const name = document.getElementById('u-name').value.trim();
  const role = document.getElementById('u-role').value;
  if (!username) { showAlert('Enter a username.'); return; }
  if (_editUserId) {
    // Editing existing user
    const i = DB.users.findIndex(u=>u.id===_editUserId);
    if (DB.users.some((u,idx)=>u.username===username&&idx!==i)) { showAlert('Username already taken.'); return; }
    if (pass && pass.length<6) { showAlert('Password must be at least 6 characters.'); return; }
    DB.users[i].username = username;
    DB.users[i].name = name;
    DB.users[i].role = role;
    if (pass) DB.users[i].password = pass;
    saveDB(); closeM('m-user'); renderUsers();
    showAlert('User account updated.','✅ Updated');
    // Update current session if editing self
    if (currentUser && currentUser.id === _editUserId) {
      currentUser = DB.users[i];
      applyRoleAccess();
    }
  } else {
    if (!pass) { showAlert('Enter a password.'); return; }
    if (pass.length<6) { showAlert('Password must be at least 6 characters.'); return; }
    if (DB.users.some(u=>u.username===username)) { showAlert('Username already exists.'); return; }
    DB.users.push({id:genId('u'), username, password:pass, name, role, lastLogin:'Never'});
    saveDB(); closeM('m-user'); renderUsers();
    showAlert('User account created.','✅ Done');
  }
}

