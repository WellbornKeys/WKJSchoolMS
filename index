<script>
// ============================================================
//  NEW FEATURES — Quick Search, Charts, Notifications,
//  Fee Reminders, Photo Upload, Marks Excel, Toasts, Keyboard
// ============================================================

// ── TOAST NOTIFICATIONS ─────────────────────────────────────
function toast(msg, type='info', duration=3500) {
  const icons = {success:'ti-circle-check',danger:'ti-alert-circle',warning:'ti-alert-triangle',info:'ti-info-circle'};
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.innerHTML = `<i class="ti ${icons[type]||icons.info} toast-icon" style="color:var(--${type})"></i><span style="flex:1">${msg}</span><span class="toast-close" onclick="this.closest('.toast').remove()">×</span>`;
  document.getElementById('toast-container').appendChild(t);
  setTimeout(()=>{ t.classList.add('hiding'); setTimeout(()=>t.remove(), 300); }, duration);
}


// ── INPUT SANITIZATION HELPER ──────────────────────────────────
function _esc(str) {
  if (str === null || str === undefined) return '';
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#x27;');
}

// Override showAlert to also use toast for brief messages
const _origAlert = window.showAlert;
window.showAlert = function(msg, title, cb) {
  // Short messages — also show toast
  if (!cb && typeof msg === 'string' && msg.length < 120) {
    const type = (title||'').includes('✅')||msg.includes('✅') ? 'success'
               : (title||'').includes('❌')||msg.includes('❌') ? 'danger'
               : (title||'').includes('⚠️') ? 'warning' : 'info';
    toast(msg.replace(/✅|❌|⚠️|🔐/g,'').trim(), type);
  }
  if (_origAlert) _origAlert(msg, title, cb);
};

// ── NOTIFICATIONS ────────────────────────────────────────────
let _notifications = [];
let _notifOpen = false;

function addNotification(msg, type='info', urgent=false) {
  _notifications.unshift({id: Date.now(), msg, type, urgent, read: false, time: new Date().toLocaleTimeString('en-UG',{hour:'2-digit',minute:'2-digit'})});
  if (_notifications.length > 30) _notifications.pop();
  renderNotifBadge();
  if (urgent) toast(msg, 'warning', 5000);
}

function renderNotifBadge() {
  const unread = _notifications.filter(n=>!n.read).length;
  const badge = document.getElementById('notif-badge');
  if (badge) { badge.textContent = unread > 9 ? '9+' : unread; badge.style.display = unread > 0 ? '' : 'none'; }
}

function toggleNotifPanel() {
  _notifOpen = !_notifOpen;
  const panel = document.getElementById('notif-panel');
  if (!panel) return;
  if (_notifOpen) {
    renderNotifList();
    _notifications.forEach(n=>n.read=true);
    renderNotifBadge();
    panel.classList.add('open');
  } else { panel.classList.remove('open'); }
}

function renderNotifList() {
  const el = document.getElementById('notif-list');
  if (!el) return;
  if (!_notifications.length) { el.innerHTML='<div class="notif-item" style="color:var(--text3);font-style:italic">No notifications</div>'; return; }
  el.innerHTML = _notifications.slice(0,15).map(n=>`
    <div class="notif-item${n.urgent?' urgent':''}">
      <div>${n.msg}</div>
      <div class="ni-time">${n.time}</div>
    </div>`).join('');
}

function clearNotifications() {
  _notifications = [];
  renderNotifBadge();
  renderNotifList();
  document.getElementById('notif-panel')?.classList.remove('open');
  _notifOpen = false;
}

// Close notification panel on outside click
document.addEventListener('click', e => {
  if (_notifOpen && !document.getElementById('notif-wrapper')?.contains(e.target)) {
    document.getElementById('notif-panel')?.classList.remove('open');
    _notifOpen = false;
  }
});

// ── QUICK SEARCH ──────────────────────────────────────────────
let _qsIdx = -1;

function openQuickSearch() {
  document.getElementById('qs-overlay').classList.add('open');
  setTimeout(()=>document.getElementById('qs-input')?.focus(), 60);
  _qsIdx = -1;
  document.getElementById('qs-results').innerHTML = '<div class="qs-empty">Start typing to search…</div>';
}

function closeQuickSearch() {
  document.getElementById('qs-overlay').classList.remove('open');
  const inp = document.getElementById('qs-input'); if (inp) inp.value='';
}

function handleQSKey(e) {
  const items = document.querySelectorAll('.qs-item');
  if (e.key === 'ArrowDown') { e.preventDefault(); _qsIdx = Math.min(_qsIdx+1, items.length-1); items.forEach((x,i)=>x.classList.toggle('selected',i===_qsIdx)); }
  else if (e.key === 'ArrowUp') { e.preventDefault(); _qsIdx = Math.max(_qsIdx-1, 0); items.forEach((x,i)=>x.classList.toggle('selected',i===_qsIdx)); }
  else if (e.key === 'Enter') { e.preventDefault(); const sel = document.querySelector('.qs-item.selected'); if (sel) sel.click(); else if (items.length===1) items[0].click(); }
  else if (e.key === 'Escape') { closeQuickSearch(); }
}

function renderQSResults() {
  const q = (document.getElementById('qs-input')?.value||'').toLowerCase().trim();
  const el = document.getElementById('qs-results');
  _qsIdx = -1;
  if (!q) { el.innerHTML='<div class="qs-empty">Start typing to search…</div>'; return; }

  const pages = [
    {label:'Dashboard',icon:'ti-layout-dashboard',page:'dashboard'},
    {label:'Students',icon:'ti-users',page:'students'},
    {label:'Student Profiles',icon:'ti-id-badge-2',page:'student-dashboard'},
    {label:'Attendance',icon:'ti-calendar-check',page:'attendance'},
    {label:'Fees & Payments',icon:'ti-cash',page:'fees'},
    {label:'Marks Entry',icon:'ti-book',page:'marks'},
    {label:'Report Cards',icon:'ti-report',page:'reports'},
    {label:'Staff',icon:'ti-id',page:'staff'},
    {label:'Expenses',icon:'ti-receipt-2',page:'expenses'},
    {label:'Co-curricular',icon:'ti-trophy',page:'cca'},
    {label:'Online & Sync',icon:'ti-cloud',page:'sync'},
    {label:'Settings',icon:'ti-settings',page:'settings'},
  ].filter(p=>p.label.toLowerCase().includes(q));

  const students = (DB.students||[]).filter(s=>(s.fn+' '+s.ln+s.adm+s.cls).toLowerCase().includes(q)).slice(0,6);
  const staff = (DB.staff||[]).filter(s=>(s.fn+' '+s.ln+s.role).toLowerCase().includes(q)).slice(0,4);

  let html = '';
  if (pages.length) {
    html += '<div class="qs-section">Pages</div>';
    html += pages.map(p=>`<div class="qs-item" onclick="closeQuickSearch();nav('${p.page}',document.getElementById('nav-${p.page}'))"><i class="ti ${p.icon}"></i><span>${p.label}</span><span class="qs-sub">Page</span></div>`).join('');
  }
  if (students.length) {
    html += '<div class="qs-section">Students</div>';
    html += students.map(s=>`<div class="qs-item" onclick="closeQuickSearch();nav('students',document.getElementById('nav-students'));document.getElementById('st-search').value='${s.fn} ${s.ln}';renderStudents()"><i class="ti ti-user"></i><span>${s.fn} ${s.ln}</span><span class="qs-sub">${s.cls} · ${s.adm}</span></div>`).join('');
  }
  if (staff.length) {
    html += '<div class="qs-section">Staff</div>';
    html += staff.map(s=>`<div class="qs-item" onclick="closeQuickSearch();nav('staff',document.getElementById('nav-staff'))"><i class="ti ti-id"></i><span>${s.fn} ${s.ln}</span><span class="qs-sub">${s.role}</span></div>`).join('');
  }
  el.innerHTML = html || '<div class="qs-empty">No results found</div>';
}

// Keyboard shortcut: Ctrl+K / Cmd+K
document.addEventListener('keydown', e => {
  if ((e.ctrlKey||e.metaKey) && e.key==='k') { e.preventDefault(); openQuickSearch(); }
  if (e.key==='Escape') { closeQuickSearch(); }
});

// ── CHARTS ───────────────────────────────────────────────────
let _charts = {};

function destroyChart(id) { if (_charts[id]) { _charts[id].destroy(); delete _charts[id]; } }

function getCSSVar(v) { return getComputedStyle(document.documentElement).getPropertyValue(v).trim(); }

function renderDashboardCharts() {
  const t = DB.settings.term || 2;

  // Chart 1: Students per class (enrollment bar chart)
  destroyChart('students-class');
  const ctx1 = document.getElementById('chart-students-class');
  if (ctx1) {
    const labels = DB.classes.filter(c => DB.students.some(s=>s.cls===c));
    const counts = labels.map(c => DB.students.filter(s=>s.cls===c).length);
    _charts['students-class'] = new Chart(ctx1, {
      type:'bar',
      data:{
        labels,
        datasets:[{
          label:'Students',
          data:counts,
          backgroundColor:'rgba(30,77,53,0.65)',
          borderColor:'rgba(30,77,53,1)',
          borderWidth:1.5,borderRadius:4
        }]
      },
      options:{
        responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false},tooltip:{callbacks:{label:(c)=>c.raw+' students'}}},
        scales:{
          x:{ticks:{font:{size:10},color:'#9b9087'},grid:{display:false}},
