    <!-- FEES + ATTENDANCE + MARKS ROW -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:14px">
      <!-- FEES -->
      <div style="background:var(--accent-light);border-radius:var(--radius);padding:12px">
        <div style="font-size:10px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px">💰 Fees — ${termName}</div>
        <div style="font-size:11.5px;display:flex;justify-content:space-between;margin-bottom:3px"><span>Term Fee:</span><span>UGX ${fmt(termFee)}</span></div>
        ${bf>0?`<div style="font-size:11.5px;display:flex;justify-content:space-between;margin-bottom:3px;color:var(--warning)"><span>B/F Balance:</span><span>UGX ${fmt(bf)}</span></div>`:''}
        <div style="font-size:11.5px;display:flex;justify-content:space-between;margin-bottom:3px;color:var(--success)"><span>Paid:</span><span>UGX ${fmt(paid)}</span></div>
        <div style="border-top:1px dashed var(--border);margin-top:5px;padding-top:5px;display:flex;justify-content:space-between;font-weight:700;font-size:12.5px">
