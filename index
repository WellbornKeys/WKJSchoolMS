        </div>
        <div style="margin-top:8px"><div class="prog"><div class="prog-fill" style="width:${termFee+bf>0?Math.min(100,Math.round(paid/(termFee+bf)*100)):0}%;background:${feeStatusColor}"></div></div></div>
      </div>

      <!-- ATTENDANCE -->
      <div style="background:var(--primary-light);border-radius:var(--radius);padding:12px">
